---
// Metrics Section for Vorbia
---

<section id="metrics" class="py-24 bg-slate-950 border-y border-white/5" data-ps="src/components/home/Metrics.astro:m1">
  <div class="max-w-7xl mx-auto px-6" data-ps="src/components/home/Metrics.astro:m2">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-16 md:gap-8" data-ps="src/components/home/Metrics.astro:m3">
      <div class="reveal reveal-delay-1 flex flex-col items-center md:items-start" data-ps="src/components/home/Metrics.astro:m4">
        <div class="text-6xl md:text-7xl font-bold bg-gradient-to-b from-white to-slate-500 bg-clip-text text-transparent mb-2 tracking-tight" data-ps="src/components/home/Metrics.astro:m5">$2B+</div>
        <div class="text-xs uppercase tracking-[0.2em] text-blue-400 font-bold" data-ps="src/components/home/Metrics.astro:m6">Asset Value Protected</div>
      </div>
      <div class="reveal reveal-delay-2 flex flex-col items-center md:items-start" data-ps="src/components/home/Metrics.astro:m7">
        <div class="text-6xl md:text-7xl font-bold bg-gradient-to-b from-white to-slate-500 bg-clip-text text-transparent mb-2 tracking-tight" data-ps="src/components/home/Metrics.astro:m8">99.9%</div>
        <div class="text-xs uppercase tracking-[0.2em] text-blue-400 font-bold" data-ps="src/components/home/Metrics.astro:m9">Auth Confidence Score</div>
      </div>
      <div class="reveal reveal-delay-3 flex flex-col items-center md:items-start" data-ps="src/components/home/Metrics.astro:m10">
        <div class="text-6xl md:text-7xl font-bold bg-gradient-to-b from-white to-slate-500 bg-clip-text text-transparent mb-2 tracking-tight" data-ps="src/components/home/Metrics.astro:m11">10M+</div>
        <div class="text-xs uppercase tracking-[0.2em] text-blue-400 font-bold" data-ps="src/components/home/Metrics.astro:m12">Secure IDs Resolved</div>
      </div>
    </div>
  </div>
</section>
