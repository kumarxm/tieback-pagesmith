---
// Hero section for TieBack
---
<section class="relative min-h-screen flex items-center pt-24 overflow-hidden bg-slate-950" data-ps="src/components/home/Hero.astro:t1">
  <!-- Mesh Gradient Background -->
  <div class="absolute inset-0 z-0 overflow-hidden pointer-events-none opacity-40" data-ps="src/components/home/Hero.astro:iy4tag">
    <div class="absolute -top-[10%] -left-[10%] w-[50%] h-[50%] bg-blue-600/30 blur-[120px] rounded-full" data-ps="src/components/home/Hero.astro:iy4tah"></div>
    <div class="absolute top-[20%] -right-[10%] w-[40%] h-[60%] bg-cyan-500/20 blur-[120px] rounded-full" data-ps="src/components/home/Hero.astro:ecxgf3"></div>
    <div class="absolute bottom-0 left-[20%] w-[60%] h-[40%] bg-indigo-600/10 blur-[120px] rounded-full" data-ps="src/components/home/Hero.astro:ecxgf4"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10" data-ps="src/components/home/Hero.astro:ecxgf5">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center" data-ps="src/components/home/Hero.astro:ecxgf6">
      <div class="space-y-10" data-ps="src/components/home/Hero.astro:ecxgf7">
        <div class="space-y-6" data-ps="src/components/home/Hero.astro:ecxgfc">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-blue-400 text-xs font-semibold tracking-widest uppercase" data-ps="src/components/home/Hero.astro:eyp1">
            <span class="w-2 h-2 rounded-full bg-blue-500 animate-pulse" data-ps="src/components/home/Hero.astro:z1i1wj"></span>
            AI-Driven Digital Identity
          </div>
          <h1 class="text-6xl md:text-8xl font-bold text-white leading-[1.05] tracking-tight" data-ps="src/components/home/Hero.astro:307k1r">
            Physical items.<br /><span class="bg-gradient-to-r from-blue-400 to-cyan-400 bg-clip-text text-transparent" data-ps="src/components/home/Hero.astro:z1i1wj">Digital trust.</span>
          </h1>
        </div>
        
        <p class="text-xl text-slate-400 max-w-xl leading-relaxed font-light" data-ps="src/components/home/Hero.astro:6uykn0">
          The SaaS standard for GS1 Digital Link resolution, item-level authentication, and EU ESPR compliance. Built for enterprise scale, secured by AI.
        </p>

        <div class="flex flex-col sm:flex-row gap-5" data-ps="src/components/home/Hero.astro:ecxgf9">
          <a href="/request-access" class="px-10 py-4 rounded-xl bg-blue-600 text-white font-semibold text-lg hover:bg-blue-500 transition-all text-center shadow-[0_0_40px_-10px_rgba(37,99,235,0.4)]" data-ps="src/components/home/Hero.astro:8zc2o">
            Request Access
          </a>
          <a href="#how-it-works" class="px-10 py-4 rounded-xl bg-white/5 border border-white/10 text-white font-semibold text-lg hover:bg-white/10 transition-all text-center backdrop-blur-sm" data-ps="src/components/home/Hero.astro:8zc2p">
            See the Platform
          </a>
        </div>

        <div class="flex flex-wrap items-center gap-8 pt-6 border-t border-white/5" data-ps="src/components/home/Hero.astro:trustmarks">
          <div class="flex items-center gap-3 text-sm text-slate-400" data-ps="src/components/home/Hero.astro:tm1">
            <svg class="w-5 h-5 text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
            GS1 Native
          </div>
          <div class="flex items-center gap-3 text-sm text-slate-400" data-ps="src/components/home/Hero.astro:tm2">SOC2 aligned controls</div>
          <div class="flex items-center gap-3 text-sm text-slate-400" data-ps="src/components/home/Hero.astro:tm3">EU ESPR (DPP) Ready</div>
        </div>
      </div>

      <div class="relative group flex flex-col items-center" data-ps="src/components/home/Hero.astro:ecxgfa">
        
        {/* iPhone 17 Pro Max Frame in Hero */}
        <div class="relative mx-auto max-w-[320px] md:max-w-[380px] z-10" data-ps="src/components/home/Hero.astro:iphone-hero">
          <div class="relative overflow-hidden rounded-[3rem] border-[8px] border-slate-800 shadow-2xl bg-slate-900 aspect-[9/19.5]" data-ps="src/components/home/Hero.astro:qxj7f7">
            {/* Dynamic Island */}
            <div class="absolute top-4 left-1/2 -translate-x-1/2 w-24 h-6 bg-black rounded-full z-30" data-ps="src/components/home/Hero.astro:qxj7f8"></div>
            
            {/* Screen Content */}
            <div class="w-full h-full bg-slate-100 overflow-hidden relative" data-ps="src/components/home/Hero.astro:qxj7f9">
              <img 
                src="https://cdn.pagesmith.app/2372d62a/images/Screenshot-2026-03-14-at-19.14.19-768.webp" 
                alt="TieBack Interface on iPhone 17 Pro Max" 
                class="w-full h-full object-cover object-top hover:scale-105 transition-transform duration-700 ease-out"
                loading="eager" fetchpriority="high" data-ps="src/components/home/Hero.astro:2xpr82" />
            </div>
          </div>
        </div>


      </div>
    </div>
  </div>
</section>
