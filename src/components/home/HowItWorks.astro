---
// How It Works section for TieBack
---
<section id="how-it-works" class="py-32 bg-slate-950 overflow-hidden relative" data-ps="src/components/home/HowItWorks.astro:hiw1">
  <!-- Modern Mesh Gradient Background -->
  <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden" data-ps="src/components/home/HowItWorks.astro:bg-mesh">
    <div class="absolute -top-[20%] -left-[10%] w-[60%] h-[60%] bg-blue-600/10 rounded-full blur-[120px]" data-ps="src/components/home/HowItWorks.astro:ta5lfr"></div>
    <div class="absolute -bottom-[20%] -right-[10%] w-[60%] h-[60%] bg-indigo-600/10 rounded-full blur-[120px]" data-ps="src/components/home/HowItWorks.astro:ta5lfq"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10" data-ps="src/components/home/HowItWorks.astro:ta5lft">
    <div class="text-center max-w-3xl mx-auto mb-20" data-ps="src/components/home/HowItWorks.astro:ta5lfs">
      <div class="inline-block px-4 py-1.5 mb-6 text-sm font-medium tracking-wider text-blue-400 uppercase bg-blue-400/10 border border-blue-400/20 rounded-full" data-ps="src/components/home/HowItWorks.astro:eyebrow">
        The Workflow
      </div>
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-6 tracking-tight" data-ps="src/components/home/HowItWorks.astro:lj3dem">How TieBack Works</h2>
      <p class="text-slate-400 text-xl font-light" data-ps="src/components/home/HowItWorks.astro:mo0g8l">One identity. One scan. Infinite possibilities.</p>
    </div>

    <div class="relative max-w-6xl mx-auto" data-ps="src/components/home/HowItWorks.astro:process-container">
      <!-- Sophisticated Connection Line (Desktop) -->
      <div class="hidden md:block absolute top-[60px] left-[10%] right-[10%] h-[1px] bg-gradient-to-r from-transparent via-blue-500/30 to-transparent z-0" data-ps="src/components/home/HowItWorks.astro:line">
        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-blue-400 to-transparent blur-sm opacity-50" data-ps="src/components/home/HowItWorks.astro:ta5lfp"></div>
      </div>
      
      <div class="grid md:grid-cols-4 gap-6 lg:gap-8 relative z-10" data-ps="src/components/home/HowItWorks.astro:steps-grid">
        
        <!-- Step 1 -->
        <div class="group relative" data-ps="src/components/home/HowItWorks.astro:step-1">
          <div class="flex flex-col items-center text-center p-8 rounded-3xl bg-white/[0.03] border border-white/[0.08] backdrop-blur-sm transition-all duration-500 hover:bg-white/[0.06] hover:border-blue-500/50 hover:-translate-y-2 group" data-ps="src/components/home/HowItWorks.astro:card-1">
            <div class="w-20 h-20 rounded-2xl bg-slate-900 border border-white/10 flex items-center justify-center text-blue-400 mb-8 shadow-2xl shadow-blue-500/10 group-hover:shadow-blue-500/20 group-hover:scale-110 transition-all duration-500 relative" data-ps="src/components/home/HowItWorks.astro:icon-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-cpu"><rect width="16" height="16" x="4" y="4" rx="2"/><rect width="6" height="6" x="9" y="9" rx="1"/><path d="M15 2v2"/><path d="M15 20v2"/><path d="M2 15h2"/><path d="M2 9h2"/><path d="M20 15h2"/><path d="M20 9h2"/><path d="M9 2v2"/><path d="M9 20v2"/></svg>
              <div class="absolute -top-3 -right-3 w-8 h-8 bg-blue-600 text-white text-sm font-bold rounded-xl flex items-center justify-center shadow-lg" data-ps="src/components/home/HowItWorks.astro:num-1">01</div>
            </div>
            <h3 class="text-xl font-bold text-white mb-4 group-hover:text-blue-400 transition-colors" data-ps="src/components/home/HowItWorks.astro:l21q9p-0">Mint Identity</h3>
            <p class="text-slate-400 text-sm leading-relaxed font-light" data-ps="src/components/home/HowItWorks.astro:mo0g8m-0">
              Define products at SKU level and mint unique item-level identities by default with GS1 Digital Link.
            </p>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="group relative" data-ps="src/components/home/HowItWorks.astro:step-2">
          <div class="flex flex-col items-center text-center p-8 rounded-3xl bg-white/[0.03] border border-white/[0.08] backdrop-blur-sm transition-all duration-500 hover:bg-white/[0.06] hover:border-blue-500/50 hover:-translate-y-2 group" data-ps="src/components/home/HowItWorks.astro:card-2">
            <div class="w-20 h-20 rounded-2xl bg-slate-900 border border-white/10 flex items-center justify-center text-blue-400 mb-8 shadow-2xl shadow-blue-500/10 group-hover:shadow-blue-500/20 group-hover:scale-110 transition-all duration-500 relative" data-ps="src/components/home/HowItWorks.astro:icon-1">
              <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-database"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 21 19V5"/><path d="M3 12A9 3 0 0 0 21 12"/></svg>
              <div class="absolute -top-3 -right-3 w-8 h-8 bg-blue-600 text-white text-sm font-bold rounded-xl flex items-center justify-center shadow-lg" data-ps="src/components/home/HowItWorks.astro:num-2">02</div>
            </div>
            <h3 class="text-xl font-bold text-white mb-4 group-hover:text-blue-400 transition-colors" data-ps="src/components/home/HowItWorks.astro:l21q9p-1">Connect Data</h3>
            <p class="text-slate-400 text-sm leading-relaxed font-light" data-ps="src/components/home/HowItWorks.astro:mo0g8m-1">
              Attach EU DPP disclosures, compliance records, and lifecycle events directly to every physical unit.
            </p>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="group relative" data-ps="src/components/home/HowItWorks.astro:step-3">
          <div class="flex flex-col items-center text-center p-8 rounded-3xl bg-white/[0.03] border border-white/[0.08] backdrop-blur-sm transition-all duration-500 hover:bg-white/[0.06] hover:border-blue-500/50 hover:-translate-y-2 group" data-ps="src/components/home/HowItWorks.astro:card-3">
            <div class="w-20 h-20 rounded-2xl bg-slate-900 border border-white/10 flex items-center justify-center text-blue-400 mb-8 shadow-2xl shadow-blue-500/10 group-hover:shadow-blue-500/20 group-hover:scale-110 transition-all duration-500 relative" data-ps="src/components/home/HowItWorks.astro:icon-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-check"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
              <div class="absolute -top-3 -right-3 w-8 h-8 bg-blue-600 text-white text-sm font-bold rounded-xl flex items-center justify-center shadow-lg" data-ps="src/components/home/HowItWorks.astro:num-3">03</div>
            </div>
            <h3 class="text-xl font-bold text-white mb-4 group-hover:text-blue-400 transition-colors" data-ps="src/components/home/HowItWorks.astro:l21q9p-2">Track Events</h3>
            <p class="text-slate-400 text-sm leading-relaxed font-light" data-ps="src/components/home/HowItWorks.astro:mo0g8m-2">
              Record ownership transfers and tamper-evident event logs across the entire product lifespan.
            </p>
          </div>
        </div>

        <!-- Step 4 -->
        <div class="group relative" data-ps="src/components/home/HowItWorks.astro:step-4">
          <div class="flex flex-col items-center text-center p-8 rounded-3xl bg-white/[0.03] border border-white/[0.08] backdrop-blur-sm transition-all duration-500 hover:bg-white/[0.06] hover:border-blue-500/50 hover:-translate-y-2 group" data-ps="src/components/home/HowItWorks.astro:card-4">
            <div class="w-20 h-20 rounded-2xl bg-slate-900 border border-white/10 flex items-center justify-center text-blue-400 mb-8 shadow-2xl shadow-blue-500/10 group-hover:shadow-blue-500/20 group-hover:scale-110 transition-all duration-500 relative" data-ps="src/components/home/HowItWorks.astro:icon-3">
              <div class="relative w-10 h-10" data-ps="src/components/home/HowItWorks.astro:tags-icons">
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-qr-code cycle-icon cycle-1"><rect width="5" height="5" x="3" y="3" rx="1"/><rect width="5" height="5" x="16" y="3" rx="1"/><rect width="5" height="5" x="3" y="16" rx="1"/><path d="M21 16h-3a2 2 0 0 0-2 2v3"/><path d="M21 21v.01"/><path d="M12 7v3a2 2 0 0 1-2 2H7"/><path d="M3 12h.01"/><path d="M12 3h.01"/><path d="M16 12h1"/><path d="M21 12v.01"/><path d="M12 16v.01"/><path d="M16 16h.01"/><path d="M21 7h.01"/></svg>
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-nfc cycle-icon cycle-2"><path d="M6 10.11a7 7 0 0 1 5.02-4.79 33.34 33.34 0 0 1 8.13 0 7 7 0 0 1 5.02 4.79"/><path d="M22.17 4.62a15 15 0 0 0-20.34 0"/><path d="M12 12h.01"/><path d="M12 16h.01"/><path d="M12 20h.01"/><path d="M7 12h.01"/><path d="M7 16h.01"/><path d="M7 20h.01"/><path d="M17 12h.01"/><path d="M17 16h.01"/><path d="M17 20h.01"/></svg>
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-rss cycle-icon cycle-3"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
              </div>
              <div class="absolute -top-3 -right-3 w-8 h-8 bg-blue-600 text-white text-sm font-bold rounded-xl flex items-center justify-center shadow-lg" data-ps="src/components/home/HowItWorks.astro:num-4">04</div>
            </div>
            <h3 class="text-xl font-bold text-white mb-4 group-hover:text-blue-400 transition-colors" data-ps="src/components/home/HowItWorks.astro:l21q9p-3">Resolve Passport</h3>
            <p class="text-slate-400 text-sm leading-relaxed font-light" data-ps="src/components/home/HowItWorks.astro:mo0g8m-3">
              Trigger instant resolution via QR code, NFC, or RFID tags to a secure, branded Digital Product Passport with real-time updates.
            </p>
          </div>
        </div>

      </div>
    </div>
    
    <!-- Action CTA -->
    <div class="mt-24 text-center" data-ps="src/components/home/HowItWorks.astro:cta">
      <a href="#request-access" class="inline-flex items-center justify-center px-8 py-4 bg-[#0080FF] text-white font-medium rounded-full hover:bg-blue-600 transition-colors duration-300 group" data-ps="src/components/home/HowItWorks.astro:mw9o9f">Request Access</a>
    </div>
  </div>
</section>

<style>
  @keyframes slideIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .group:hover p {
    animation: slideIn 0.3s ease-out forwards;
  }

  @keyframes fadeCycle {
    0%, 25% { opacity: 1; transform: scale(1) translateY(0); }
    33%, 92% { opacity: 0; transform: scale(0.8) translateY(10px); }
    100% { opacity: 1; transform: scale(1) translateY(0); }
  }
  
  .cycle-icon {
    position: absolute;
    inset: 0;
    margin: auto;
    opacity: 0;
  }
  
  .cycle-1 { animation: fadeCycle 6s infinite; }
  .cycle-2 { animation: fadeCycle 6s infinite 2s; }
  .cycle-3 { animation: fadeCycle 6s infinite 4s; }
</style>
