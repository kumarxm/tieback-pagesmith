---
// Industries section for TieBack
---
<section class="py-32 bg-white" data-ps="src/components/home/Industries.astro:ind1">
  <div class="container mx-auto px-6" data-ps="src/components/home/Industries.astro:j6990e">
    <div class="grid lg:grid-cols-2 gap-20 items-center" data-ps="src/components/home/Industries.astro:j6990f">
      <div class="order-2 lg:order-1" data-ps="src/components/home/Industries.astro:j6990g">
        <div class="relative group" data-ps="src/components/home/Industries.astro:j6990h">
          <img
            src="https://cdn.pagesmith.app/2372d62a/images/level-4/Screenshot-2026-03-13-at-12.37.32-1536.webp"
            sizes="(max-width: 1024px) 100vw, 40vw"
            alt="Fashion and Luxury Goods" 
            class="relative rounded-3xl shadow-xl w-full h-[600px] object-cover border border-slate-100" data-ps="src/components/home/Industries.astro:aozpmv" />
        </div>
      </div>
      
      <div class="order-1 lg:order-2 space-y-10" data-ps="src/components/home/Industries.astro:j6990j">
        <div class="space-y-4" data-ps="src/components/home/Industries.astro:header">
          <span class="text-blue-600 font-medium tracking-wide uppercase text-sm" data-ps="src/components/home/Industries.astro:eb1">Industries</span>
          <h2 class="text-4xl md:text-5xl font-semibold text-slate-900 leading-tight tracking-tight" data-ps="src/components/home/Industries.astro:w0ndcz">Built for Fashion and <span class="text-blue-600" data-ps="src/components/home/Industries.astro:d0vy3m">Luxury Goods.</span></h2>
        </div>
        
        <div class="space-y-8" data-ps="src/components/home/Industries.astro:j6990k">
          <div class="group" data-ps="src/components/home/Industries.astro:j6990l">
            <h3 class="text-2xl font-semibold text-slate-900 mb-3" data-ps="src/components/home/Industries.astro:hc8g5d">Textiles & Apparel</h3>
            <p class="text-lg text-slate-500 font-light leading-relaxed" data-ps="src/components/home/Industries.astro:8nug8r">Digital Product Passport readiness, material transparency, care and recycling guidance, and resale continuity — designed to stay current over time.</p>
          </div>
          
          <div class="group" data-ps="src/components/home/Industries.astro:j6990m">
            <h3 class="text-2xl font-semibold text-slate-900 mb-3" data-ps="src/components/home/Industries.astro:hc8g5e">Luxury Goods</h3>
            <p class="text-lg text-slate-500 font-light leading-relaxed" data-ps="src/components/home/Industries.astro:8nug8q">Protect brand equity with unbreakable item-level authentication. Give your customers digital certificates of ownership and white-glove post-purchase experiences.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
