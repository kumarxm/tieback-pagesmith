---
// Footer component for Vorbia
import { SITE } from '@/config/site';
---

<footer class="bg-slate-950 text-white py-20 px-6 border-t border-slate-900" data-ps="src/components/Footer.astro:ikmf32">
  <div class="max-w-7xl mx-auto" data-ps="src/components/Footer.astro:p4vf87">
    <div class="mb-16 flex flex-col md:flex-row md:items-center justify-between gap-8" data-ps="src/components/Footer.astro:logo-row">
      <a href="/" class="flex items-center no-underline group" data-ps="src/components/Footer.astro:8o2pm">
        <span class="text-xl font-semibold tracking-[-0.5px] text-white" data-ps="src/components/Footer.astro:hzwfp9">tie<span class="text-[#0080FF] italic" data-ps="src/components/Footer.astro:hzwfp9">back</span></span>
      </a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16" data-ps="src/components/Footer.astro:p4vf88">
      
      <!-- Column 1 - Product & Platform -->
      <div data-ps="src/components/Footer.astro:l1">
        <h4 class="text-sm font-medium text-white mb-6" data-ps="src/components/Footer.astro:f0091f">Product & Platform</h4>
        <ul class="list-none p-0 m-0 flex flex-col gap-4">
          <li data-ps="src/components/Footer.astro:wyji7h"><a href="/platform/overview/" class="text-sm text-slate-400 no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqc0j">Platform Overview</a></li>
          <li data-ps="src/components/Footer.astro:sq28di"><a href="/pricing" class="text-sm text-slate-400 no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqc0l">Pricing</a></li>
          <li data-ps="src/components/Footer.astro:sq28dh"><a href="/platform/why-tieback/" class="text-sm text-slate-400 no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqc0m">Why TieBack</a></li>
        </ul>
      </div>

      <!-- Column 2 - Solutions -->
      <div data-ps="src/components/Footer.astro:l2">
        <h4 class="text-sm font-medium text-white mb-6" data-ps="src/components/Footer.astro:f0091f2">Solutions</h4>
        <ul class="list-none p-0 m-0 flex flex-col gap-4">
          <li data-ps="src/components/Footer.astro:sq28df"><a href="/use-cases/resale-circular-economy/" class="text-sm text-slate-400 no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqc0k2">Circularity & Experience</a></li>
          <li data-ps="src/components/Footer.astro:sq28de"><a href="/use-cases/authentication/" class="text-sm text-slate-400 no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqc0l2">Authentication & Trust</a></li>
          <li data-ps="src/components/Footer.astro:sq28dd"><a href="/use-cases/traceability/" class="text-sm text-slate-400 no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqc0m2">Traceability & Safety</a></li>
        </ul>
      </div>

      <!-- Column 3 - Industries -->
      <div data-ps="src/components/Footer.astro:l3">
        <h4 class="text-sm font-medium text-white mb-6" data-ps="src/components/Footer.astro:f0091f3">Industries</h4>
        <ul class="list-none p-0 m-0 flex flex-col gap-4">
          <li data-ps="src/components/Footer.astro:sq28dc"><a href="/industries/textiles" class="text-sm text-slate-400 no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqc0j3">Textiles & Apparel</a></li>
          <li data-ps="src/components/Footer.astro:sq28db"><a href="/industries/luxury-high-risk-goods/" class="text-sm text-slate-400 no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqc0k3">Luxury & High-Risk</a></li>
          <li data-ps="src/components/Footer.astro:sq28da"><a href="/industries/fmcg" class="text-sm text-slate-400 no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqc0l3">FMCG & Food</a></li>
          <li data-ps="src/components/Footer.astro:sq28dx"><a href="/industries/electronics" class="text-sm text-slate-400 no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqc0l4">Electronics & Devices</a></li>
          <li data-ps="src/components/Footer.astro:sq28dy"><a href="/industries/materials" class="text-sm text-slate-400 no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqc0l5">Materials & Suppliers</a></li>
        </ul>
      </div>

      <!-- Column 4 - Company & Resources -->
      <div data-ps="src/components/Footer.astro:l4">
        <h4 class="text-sm font-medium text-white mb-6" data-ps="src/components/Footer.astro:f0091f4">Company & Resources</h4>
        <ul class="list-none p-0 m-0 flex flex-col gap-4">
          <li data-ps="src/components/Footer.astro:sq28dz"><a href="/about" class="text-sm text-slate-400 no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqc0l6">About Us</a></li>
          <li data-ps="src/components/Footer.astro:journal-footer-li"><a href="/journal/" class="text-sm text-slate-400 no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:journal-footer-link">Journal</a></li>
          <li data-ps="src/components/Footer.astro:sq28d1"><a href="https://tieback.io/docs" class="text-sm text-slate-400 no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqc0l7">Docs</a></li>
          <li data-ps="src/components/Footer.astro:sq28d2"><a href="/faq" class="text-sm text-slate-400 no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqc0l8">FAQs</a></li>
          <li data-ps="src/components/Footer.astro:sq28d3"><a href="/support" class="text-sm text-slate-400 no-underline hover:text-white transition-colors" data-ps="src/components/Footer.astro:7gqc0l9">Contact Support</a></li>
        </ul>
      </div>

    </div>

    <!-- Bottom Legal Bar -->
    <div class="border-t border-slate-900 pt-12 flex flex-col items-center md:items-start gap-4" data-ps="src/components/Footer.astro:p4vf8b">
      <div class="flex items-center gap-6" data-ps="src/components/Footer.astro:social-links-bottom">
        <a href="https://www.linkedin.com/company/tieback" target="_blank" rel="noopener noreferrer" class="text-slate-400 hover:text-[#0077b5] transition-all duration-300" aria-label="LinkedIn" data-ps="src/components/Footer.astro:linkedin-link-new">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="lucide lucide-linkedin"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
        </a>
      </div>
      
      <div class="w-full flex flex-col md:flex-row justify-between items-center gap-6" data-ps="src/components/Footer.astro:p4vf8b">
        <p class="text-sm text-slate-400" data-ps="src/components/Footer.astro:euol">
          © 2026 TieBack. All rights reserved.
        </p>
      <div class="flex flex-wrap justify-center gap-4 text-sm text-slate-400" data-ps="src/components/Footer.astro:p4vf8b">
        <a href="/terms-of-use/" class="hover:text-white transition-colors" data-ps="src/components/Footer.astro:8o2pi">Terms of Use</a>
        <span class="hidden md:inline" data-ps="src/components/Footer.astro:hzwfpb">|</span>
        <a href="/privacy-policy/" class="hover:text-white transition-colors" data-ps="src/components/Footer.astro:8o2pj">Privacy Policy</a>
        <span class="hidden md:inline" data-ps="src/components/Footer.astro:hzwfpa">|</span>
        <a href="/cookie-policy/" class="hover:text-white transition-colors" data-ps="src/components/Footer.astro:8o2pk">Cookie Policy</a>
      </div>
    </div>
  </div>
</footer>
