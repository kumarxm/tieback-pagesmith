        <!-- Pillar 4: Rollout (Supply Chain/Nodes) -->
        <div class="group bg-white p-10 rounded-[2rem] border border-slate-200 hover:border-blue-200 hover:shadow-xl hover:shadow-blue-500/5 transition-all duration-500 flex flex-col h-full opacity-0 translate-y-12 data-reveal-delay-300" data-reveal="fade-up" data-ps="src/pages/industries/textiles.astro:pillar-4">
