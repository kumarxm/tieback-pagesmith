        <!-- Pillar 1: Safety communication -->
        <div class="group bg-white p-10 rounded-[2rem] border border-slate-200 hover:border-blue-200 hover:shadow-xl hover:shadow-blue-500/5 transition-all duration-500 flex flex-col h-full opacity-0 translate-y-12 data-reveal-delay-100" data-reveal="fade-up" data-ps="src/pages/industries/fmcg.astro:pillar-1">
