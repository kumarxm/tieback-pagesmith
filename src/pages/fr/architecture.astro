        <h3 class="text-2xl font-bold text-white mb-4" data-ps="src/pages/architecture.astro:n2hhrg">Dynamic Identifier Architecture</h3>
        <p class="text-slate-400 leading-relaxed" data-ps="src/pages/architecture.astro:rjvw9z">
