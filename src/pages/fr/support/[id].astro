---
export const prerender = false;

import BaseLayout from '@/layouts/BaseLayout.astro';

const runtime = Astro.locals.runtime;
if (!runtime?.env?.DB) {
  return new Response('Service unavailable', { status: 503 });
}

const db = runtime.env.DB;
const { id } = Astro.params;

let error = '';
let success = false;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const message = formData.get('message')?.toString();

  if (message) {
    try {
      await db.prepare('INSERT INTO support_messages (ticket_id, sender, message) VALUES (?, ?, ?)')
        .bind(id, 'User', message).run();
      await db.prepare("UPDATE support_tickets SET updated_at = CURRENT_TIMESTAMP WHERE id = ?").bind(id).run();
      success = true;
    } catch(err) {
      error = 'Failed to post reply.';
    }
  }
}

let ticket: any = null;
let messages: any[] = [];

try {
  ticket = await db.prepare('SELECT * FROM support_tickets WHERE id = ?').bind(id).first();
  if (ticket) {
    const { results } = await db.prepare('SELECT * FROM support_messages WHERE ticket_id = ? ORDER BY created_at ASC').bind(id).all();
    messages = results;
  }
} catch(err) {
  console.error("DB error", err);
}

if (!ticket) {
  return Astro.redirect('/404');
}
---

<BaseLayout title={`${ticket.ticket_number} - Support | TieBack`} description="Ticket Details">
  <div class="max-w-4xl mx-auto px-6 py-16" data-ps="src/pages/support/[id].astro:kvyu08">
    <div class="mb-8 flex flex-col md:flex-row md:items-center justify-between gap-4" data-ps="src/pages/support/[id].astro:kvyu09">
      <div data-ps="src/pages/support/[id].astro:kvyu0a">
        <a href="/support" class="text-slate-400 hover:text-white flex items-center gap-2 text-sm font-medium mb-4 transition-colors" data-ps="src/pages/support/[id].astro:lw28ox">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to Tickets
        </a>
        <div class="flex items-center gap-4" data-ps="src/pages/support/[id].astro:m8m8yq">
          <h1 class="text-3xl font-bold text-white" data-ps="src/pages/support/[id].astro:bx7srl">{ticket.subject}</h1>
          <span class={`px-3 py-1 rounded-full text-xs font-medium border ${
            ticket.status === 'Open' ? 'bg-blue-500/10 text-blue-400 border-blue-500/20' :
            ticket.status === 'Closed' ? 'bg-slate-500/10 text-slate-400 border-slate-500/20' :
            'bg-amber-500/10 text-amber-400 border-amber-500/20'
          }`} data-ps="src/pages/support/[id].astro:ho2cee">
            {ticket.status}
          </span>
        </div>
        <p class="text-slate-400 mt-2 font-mono text-sm" data-ps="src/pages/support/[id].astro:es4bz7">{ticket.ticket_number}</p>
      </div>
    </div>

    <div class="space-y-6 mb-8" data-ps="src/pages/support/[id].astro:m8m8yp">
      {messages.map((msg, __psIdx) => (
        <div class={`p-6 rounded-2xl border ${msg.sender === 'User' ? 'bg-slate-900 border-slate-800' : 'bg-blue-900/10 border-blue-900/30'}`} data-ps={`src/pages/support/[id].astro:m8m8yo-${__psIdx}`}>
          <div class="flex items-center justify-between mb-4" data-ps={`src/pages/support/[id].astro:m8m8yn-${__psIdx}`}>
            <div class="flex items-center gap-3" data-ps={`src/pages/support/[id].astro:m8m8ym-${__psIdx}`}>
              <div class={`w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold ${msg.sender === 'User' ? 'bg-slate-800 text-slate-300' : 'bg-blue-500 text-white'}`} data-ps={`src/pages/support/[id].astro:m8m8yl-${__psIdx}`}>
                {msg.sender === 'User' ? 'U' : 'TB'}
              </div>
              <span class="font-medium text-white" data-ps={`src/pages/support/[id].astro:ho2ced-${__psIdx}`}>{msg.sender === 'User' ? 'You' : 'TieBack Support'}</span>
            </div>
            <span class="text-sm text-slate-500" data-ps={`src/pages/support/[id].astro:ho2cec-${__psIdx}`}>{new Date(msg.created_at).toLocaleString()}</span>
          </div>
          <div class="text-slate-300 whitespace-pre-wrap" data-ps={`src/pages/support/[id].astro:m8m8yk-${__psIdx}`}>{msg.message}</div>
        </div>
      ))}
    </div>

    {ticket.status !== 'Closed' && (
      <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 shadow-xl" data-ps="src/pages/support/[id].astro:m8m8yj">
        <h3 class="text-lg font-bold text-white mb-4" data-ps="src/pages/support/[id].astro:tr2ese">Reply to Ticket</h3>
        {error && <div class="bg-red-500/10 border border-red-500/50 text-red-400 px-4 py-3 rounded-lg mb-4" data-ps="src/pages/support/[id].astro:m8m8yi">{error}</div>}
        <form method="POST" class="space-y-4">
          <textarea id="message" name="message" rows="4" required placeholder="Type your message here..."
            class="w-full px-4 py-3 bg-slate-950 border border-slate-800 rounded-xl focus:ring-2 focus:ring-[#0080FF] focus:border-transparent text-white"></textarea>
          <div class="flex justify-end" data-ps="src/pages/support/[id].astro:m8m8yh">
            <button type="submit"
              class="px-6 py-2 bg-[#0080FF] hover:bg-[#0070E0] text-white rounded-xl font-medium transition-colors" data-ps="src/pages/support/[id].astro:oamt0j">
              Send Reply
            </button>
          </div>
        </form>
      </div>
    )}
  </div>
</BaseLayout>,---
