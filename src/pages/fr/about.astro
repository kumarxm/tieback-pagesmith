<BaseLayout
  title="About — TieBack"
  description="Why TieBack exists: structured digital identity for physical products, designed for transparency, trust, and Digital Product Passport readiness."
>

  <style>
    .scroll-reveal &lt;astro-expr id=&quot;13&quot;&gt;&lt;/astro-expr&gt;
    
    .scroll-reveal.active &lt;astro-expr id=&quot;14&quot;&gt;&lt;/astro-expr&gt;

    .scroll-reveal:nth-child(2) &lt;astro-expr id=&quot;15&quot;&gt;&lt;/astro-expr&gt;
    .scroll-reveal:nth-child(3) &lt;astro-expr id=&quot;16&quot;&gt;&lt;/astro-expr&gt;
    .scroll-reveal:nth-child(4) &lt;astro-expr id=&quot;17&quot;&gt;&lt;/astro-expr&gt;
  </style>
  <script>
    import { createIcons, Eye, ShieldCheck, Network, Leaf, Target, Sparkles, Box, Repeat, Globe, TrendingUp, Shield, FileCheck, UserCheck, BarChart } from 'lucide';

    // Initialize Lucide icons - Ensure all used icons are registered
    createIcons({
      icons: { 
        Eye, 
        ShieldCheck, 
        Network, 
        Leaf, 
        Target, 
        Sparkles, 
        Box, 
        Repeat, 
        Globe, 
        TrendingUp,
        Shield,
        FileCheck,
        UserCheck,
        BarChart
      }
    });

    // Intersection Observer for scroll animations
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.1
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, observerOptions);

    document.querySelectorAll('.scroll-reveal').forEach(el => observer.observe(el));
  </script>
</BaseLayout>
