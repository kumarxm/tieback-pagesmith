            <li class="flex items-start gap-3" data-ps="src/pages/use-cases/eu-dpp.astro:cap-li-1-2"><svg class="w-5 h-5 text-emerald-700 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Clear separation between recommended vs required fields</li>
            <li class="flex items-start gap-3" data-ps="src/pages/use-cases/eu-dpp.astro:cap-li-1-3"><svg class="w-5 h-5 text-emerald-700 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Version history from day one</li>
            <li class="flex items-start gap-3" data-ps="src/pages/use-cases/eu-dpp.astro:cap-li-1-4"><svg class="w-5 h-5 text-emerald-700 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Market-aware presentation</li>
          </ul>
        </div>

        <!-- Card 2 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-emerald-200 transition-all duration-300 hover:shadow-2xl hover:shadow-emerald-100/30 overflow-hidden" data-ps="src/pages/use-cases/eu-dpp.astro:cap-card-2">
          <div class="absolute top-0 right-0 w-32 h-32 bg-emerald-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/eu-dpp.astro:cap-card-deco-2"></div>
          <div class="w-14 h-14 bg-emerald-700 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-emerald-200" data-ps="src/pages/use-cases/eu-dpp.astro:cap-icon-2">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
