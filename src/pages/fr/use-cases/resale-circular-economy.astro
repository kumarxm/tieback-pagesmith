                <div class="w-px h-10 bg-white/10" data-ps="src/pages/use-cases/resale-circular-economy.astro:stat-sep"></div>
                <div data-ps="src/pages/use-cases/resale-circular-economy.astro:stat-2">
                  <div class="text-3xl font-bold text-blue-400" data-ps="src/pages/use-cases/resale-circular-economy.astro:stat-val-2">True</div>
                  <div class="text-xs uppercase tracking-widest text-slate-400 font-bold" data-ps="src/pages/use-cases/resale-circular-economy.astro:stat-lbl-2">Item-Level Identity</div>
                </div>
             </div>
           </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Final CTA (Premium Styling) -->
  <section id="request-access" class="py-32 bg-white relative overflow-hidden" data-ps="src/pages/use-cases/resale-circular-economy.astro:cloe6u">
