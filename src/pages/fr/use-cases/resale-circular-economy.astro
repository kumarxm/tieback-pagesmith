---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/config/site';

const title = "Resale & Circular Economy — TieBack";
const description = "Preserve trust as products change hands. TieBack keeps identity and product context intact across resale, gifting, and circular programmes.";
---

<BaseLayout title={title} description={description}>
  <!-- 1. Use Case Hero (Enhanced with Depth) -->
  <section class="relative pt-32 pb-24 md:pt-52 md:pb-40 overflow-hidden bg-white" data-ps="src/pages/use-cases/resale-circular-economy.astro:cloe6q">
    <!-- Subtle Background Accents -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-7xl pointer-events-none" data-ps="src/pages/use-cases/resale-circular-economy.astro:bg-accents">
      <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-blue-50/50 blur-[120px]" data-ps="src/pages/use-cases/resale-circular-economy.astro:accent-1"></div>
      <div class="absolute bottom-[10%] right-[-5%] w-[30%] h-[30%] rounded-full bg-slate-50 blur-[100px]" data-ps="src/pages/use-cases/resale-circular-economy.astro:accent-2"></div>
    </div>

    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/use-cases/resale-circular-economy.astro:6g628h">
      <div class="max-w-4xl mx-auto text-center" data-ps="src/pages/use-cases/resale-circular-economy.astro:6g627v">
        <div class="inline-flex items-center gap-2 py-1 px-3 mb-8 text-[11px] font-bold tracking-widest text-blue-600 uppercase bg-blue-50/80 backdrop-blur-sm border border-blue-100 rounded-full" data-ps="src/pages/use-cases/resale-circular-economy.astro:771h9b">
          <span class="w-1.5 h-1.5 rounded-full bg-blue-600 animate-pulse" data-ps="src/pages/use-cases/resale-circular-economy.astro:9eb0t6"></span>
          Resale & Handover
        </div>
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight text-slate-900 mb-8 leading-[1.05]" data-ps="src/pages/use-cases/resale-circular-economy.astro:jg65d">
          Resale & <span class="text-blue-600" data-ps="src/pages/use-cases/resale-circular-economy.astro:9eb0t5">Circular Economy</span>
        </h1>
        <p class="text-xl md:text-2xl text-slate-600 mb-12 leading-relaxed max-w-2xl mx-auto" data-ps="src/pages/use-cases/resale-circular-economy.astro:8k945v">
          Built for products that move beyond the first transaction. TieBack keeps identity and product context intact as ownership changes, so trust and guidance travel with the item.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-5" data-ps="src/pages/use-cases/resale-circular-economy.astro:6g627u">
          <a href="#request-access" class="w-full sm:w-auto px-10 py-4 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl transition-all duration-300 shadow-xl shadow-blue-200 hover:-translate-y-1" data-ps="src/pages/use-cases/resale-circular-economy.astro:1gb7hr">
            Request Access
          </a>
          <a href="/platform/why-tieback/" class="w-full sm:w-auto px-10 py-4 bg-white border border-slate-200 text-slate-700 font-semibold rounded-xl hover:bg-slate-50 transition-all duration-300 hover:border-slate-300" data-ps="src/pages/use-cases/resale-circular-economy.astro:1gb7hq">
            Platform Overview
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. The Reality of Resale (Challenge section) -->
  <section class="py-32 bg-slate-50 border-y border-slate-200/60 relative overflow-hidden" data-ps="src/pages/use-cases/resale-circular-economy.astro:cloe6r">
    <div class="container mx-auto px-6" data-ps="src/pages/use-cases/resale-circular-economy.astro:6g627t">
      <div class="grid lg:grid-cols-2 gap-20 items-center" data-ps="src/pages/use-cases/resale-circular-economy.astro:6g627s">
        <div class="relative" data-ps="src/pages/use-cases/resale-circular-economy.astro:6g627r">
          <div class="absolute -top-12 -left-12 w-24 h-24 bg-blue-100/50 rounded-full blur-2xl" data-ps="src/pages/use-cases/resale-circular-economy.astro:accent-3"></div>
          <h2 class="text-4xl md:text-5xl font-bold text-slate-900 leading-[1.15] relative" data-ps="src/pages/use-cases/resale-circular-economy.astro:e4yr2w">
            Most brands have no structured way to support trust once a product <span class="italic font-serif text-blue-600" data-ps="src/pages/use-cases/resale-circular-economy.astro:9eb0t4">changes hands</span>.
          </h2>
          <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-1 gap-8" data-ps="src/pages/use-cases/resale-circular-economy.astro:list-wrapper">
             <div class="flex gap-6 group bg-white/50 backdrop-blur-sm p-6 rounded-2xl border border-slate-200 transition-all hover:border-blue-200 hover:shadow-lg hover:shadow-blue-50" data-ps="src/pages/use-cases/resale-circular-economy.astro:list-item-1">
                <div class="w-12 h-12 rounded-xl bg-blue-600 flex items-center justify-center shrink-0 shadow-lg shadow-blue-100" data-ps="src/pages/use-cases/resale-circular-economy.astro:icon-box-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-alert-circle"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
                </div>
                <div data-ps="src/pages/use-cases/resale-circular-economy.astro:8ygl37">
                  <h4 class="font-bold text-slate-900 mb-1" data-ps="src/pages/use-cases/resale-circular-economy.astro:list-h-1">Context Gap</h4>
                  <p class="text-slate-600 text-sm" data-ps="src/pages/use-cases/resale-circular-economy.astro:list-p-1">Resale buyers lack reliable context and care instructions, leading to misuse or loss of value.</p>
                </div>
             </div>
             <div class="flex gap-6 group bg-white/50 backdrop-blur-sm p-6 rounded-2xl border border-slate-200 transition-all hover:border-blue-200 hover:shadow-lg hover:shadow-blue-50" data-ps="src/pages/use-cases/resale-circular-economy.astro:list-item-2">
                <div class="w-12 h-12 rounded-xl bg-blue-600 flex items-center justify-center shrink-0 shadow-lg shadow-blue-100" data-ps="src/pages/use-cases/resale-circular-economy.astro:icon-box-2">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-user-minus"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="22" x2="16" y1="11" y2="11"/></svg>
                </div>
                <div data-ps="src/pages/use-cases/resale-circular-economy.astro:8ygl38">
                  <h4 class="font-bold text-slate-900 mb-1" data-ps="src/pages/use-cases/resale-circular-economy.astro:list-h-2">Visibility Loss</h4>
                  <p class="text-slate-600 text-sm" data-ps="src/pages/use-cases/resale-circular-economy.astro:list-p-2">Brands typically lose all visibility and engagement potential after the first transaction.</p>
                </div>
             </div>
          </div>
        </div>
        <div class="relative" data-ps="src/pages/use-cases/resale-circular-economy.astro:6g627q">
          <div class="bg-white p-8 md:p-12 rounded-[2rem] border border-slate-200 shadow-2xl shadow-slate-200/50" data-ps="src/pages/use-cases/resale-circular-economy.astro:6g627p">
            <p class="text-2xl text-slate-800 leading-relaxed mb-8 font-medium" data-ps="src/pages/use-cases/resale-circular-economy.astro:8k945u">
              Secondary markets are growing. Authenticity becomes a dispute, and sustainability guidance is lost without persistent identity.
            </p>
            <div class="h-px bg-slate-100 mb-8" data-ps="src/pages/use-cases/resale-circular-economy.astro:divider"></div>
            <div class="grid gap-6" data-ps="src/pages/use-cases/resale-circular-economy.astro:grid-info">
              <div class="flex items-start gap-4" data-ps="src/pages/use-cases/resale-circular-economy.astro:ddzuom">
                <span class="w-2 h-2 rounded-full bg-blue-600 mt-2.5 shrink-0" data-ps="src/pages/use-cases/resale-circular-economy.astro:771h98"></span>
                <p class="text-slate-600 text-lg" data-ps="src/pages/use-cases/resale-circular-economy.astro:771h98_p">Establishing a clean reference point for ownership transfer ensures continuity of the product record.</p>
              </div>
              <div class="flex items-start gap-4" data-ps="src/pages/use-cases/resale-circular-economy.astro:ddzuol">
                <span class="w-2 h-2 rounded-full bg-blue-600 mt-2.5 shrink-0" data-ps="src/pages/use-cases/resale-circular-economy.astro:771h97"></span>
                <p class="text-slate-600 text-lg" data-ps="src/pages/use-cases/resale-circular-economy.astro:771h97_p">Transfers are not only operational; they are a chance to welcome the next owner into a branded experience.</p>
              </div>
            </div>
          </div>
          <!-- Decorative element -->
          <div class="absolute -bottom-6 -right-6 w-32 h-32 border-b-2 border-r-2 border-blue-100 rounded-br-3xl pointer-events-none" data-ps="src/pages/use-cases/resale-circular-economy.astro:deco-corner"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. How TieBack structures resale (3-Column Card Grid) -->
  <section class="py-32 bg-white" data-ps="src/pages/use-cases/resale-circular-economy.astro:cloe6s">
    <div class="container mx-auto px-6" data-ps="src/pages/use-cases/resale-circular-economy.astro:6g627o">
      <div class="max-w-3xl mb-20" data-ps="src/pages/use-cases/resale-circular-economy.astro:6g627n">
        <span class="text-blue-600 font-bold uppercase tracking-wider text-xs block mb-4" data-ps="src/pages/use-cases/resale-circular-economy.astro:label">Capabilities</span>
        <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6" data-ps="src/pages/use-cases/resale-circular-economy.astro:e4yr2a">Continuity beyond first sale.</h2>
        <p class="text-slate-600 text-xl leading-relaxed" data-ps="src/pages/use-cases/resale-circular-economy.astro:8k945t">TieBack structures the lifecycle of products so identity, context, and trust remain intact across every handover.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-ps="src/pages/use-cases/resale-circular-economy.astro:6g627m">
        <!-- Card 1 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/resale-circular-economy.astro:6g6270">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/resale-circular-economy.astro:card-deco-1"></div>
          <div class="w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/resale-circular-economy.astro:6g626z">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7h8a2 2 0 012 2v10a2 2 0 01-2 2H8a2 2 0 01-2-2V9a2 2 0 012-2z" /><path stroke-linecap="round" stroke-linejoin="round" d="M16 3v4M8 3v4M3 11h18" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/use-cases/resale-circular-economy.astro:stdoaj">Controlled Transfer</h3>
          <p class="text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/use-cases/resale-circular-economy.astro:8k9457">Identity persists as products move. Ownership transfer workflows ensure a clean handover and continuity of the product record.</p>
          <ul class="space-y-4 text-slate-700 font-medium" data-ps="src/pages/use-cases/resale-circular-economy.astro:card-list-1">
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/resale-circular-economy.astro:ddzuok"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Secure Handover</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/resale-circular-economy.astro:ddzuoj"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Record Continuity</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/resale-circular-economy.astro:ddzunx"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Status Transparency</li>
          </ul>
        </div>

        <!-- Card 2 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/resale-circular-economy.astro:6g626y">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/resale-circular-economy.astro:card-deco-2"></div>
          <div class="w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/resale-circular-economy.astro:6g626x">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5a2 2 0 10-2 2h2z" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/use-cases/resale-circular-economy.astro:stdoai">Branded Handover</h3>
          <p class="text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/use-cases/resale-circular-economy.astro:8k9456">A chance to welcome the next owner. Provide a calm handover experience with care, maintenance, and guidance.</p>
          <ul class="space-y-4 text-slate-700 font-medium" data-ps="src/pages/use-cases/resale-circular-economy.astro:card-list-2">
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/resale-circular-economy.astro:ddzunv"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Handover Packs</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/resale-circular-economy.astro:ddzunu"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Care & Maintenance</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/resale-circular-economy.astro:ddzunt"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Onboarding Pathways</li>
          </ul>
        </div>

        <!-- Card 3 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/resale-circular-economy.astro:6g626w">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/resale-circular-economy.astro:card-deco-3"></div>
          <div class="w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/resale-circular-economy.astro:6g626v">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/use-cases/resale-circular-economy.astro:stdoah">Circular Programmes</h3>
          <p class="text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/use-cases/resale-circular-economy.astro:8k9455">Refurbishment and reuse workflows. Maintain second-life guidance and lifecycle continuity across repair and reissue.</p>
          <ul class="space-y-4 text-slate-700 font-medium" data-ps="src/pages/use-cases/resale-circular-economy.astro:card-list-3">
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/resale-circular-economy.astro:ddzunr"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Refurbishment Logs</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/resale-circular-economy.astro:ddzunq"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Second-Life Support</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/resale-circular-economy.astro:ddzunp"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Provenance Continuity</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Visual Separator Section: Circularity in Practice -->
  <section class="py-24 bg-slate-950 text-white relative overflow-hidden" data-ps="src/pages/use-cases/resale-circular-economy.astro:evidence-section">
    <div class="absolute inset-0 opacity-30" data-ps="src/pages/use-cases/resale-circular-economy.astro:img-container">
      <img crossorigin="anonymous"
        src="https://images.unsplash.com/photo-1741176505729-420c765386fd?auto=format&w=1200&q=80"
        srcset="https://images.unsplash.com/photo-1741176505729-420c765386fd?auto=format&w=320&q=80 320w, https://images.unsplash.com/photo-1741176505729-420c765386fd?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1741176505729-420c765386fd?auto=format&w=640&q=80 640w, https://images.unsplash.com/photo-1741176505729-420c765386fd?auto=format&w=768&q=80 768w, https://images.unsplash.com/photo-1741176505729-420c765386fd?auto=format&w=1024&q=80 1024w, https://images.unsplash.com/photo-1741176505729-420c765386fd?auto=format&w=1280&q=80 1280w, https://images.unsplash.com/photo-1741176505729-420c765386fd?auto=format&w=1920&q=80 1920w"
        sizes="100vw"
        alt="Sustainably focused high-end products" class="w-full h-full object-cover" data-ps="src/pages/use-cases/resale-circular-economy.astro:kwsdk2" />
      <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/80 to-transparent" data-ps="src/pages/use-cases/resale-circular-economy.astro:8ygl33"></div>
    </div>
    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/use-cases/resale-circular-economy.astro:evidence-content">
      <div class="max-w-5xl mx-auto" data-ps="src/pages/use-cases/resale-circular-economy.astro:evidence-grid-wrap">
        <h2 class="text-3xl md:text-5xl font-bold mb-16 text-center" data-ps="src/pages/use-cases/resale-circular-economy.astro:evidence-h">Designed for continuity.</h2>
        <div class="grid lg:grid-cols-2 gap-16 items-center" data-ps="src/pages/use-cases/resale-circular-economy.astro:evidence-grid">
           <div class="bg-white/5 backdrop-blur-xl p-10 rounded-[2.5rem] border border-white/10 shadow-2xl" data-ps="src/pages/use-cases/resale-circular-economy.astro:evidence-box-1">
             <div class="flex items-center gap-4 mb-8" data-ps="src/pages/use-cases/resale-circular-economy.astro:8ygl34">
               <div class="w-10 h-10 rounded-xl bg-blue-500/20 flex items-center justify-center" data-ps="src/pages/use-cases/resale-circular-economy.astro:8ygl35">
                 <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#60a5fa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-repeat"><path d="m17 2 4 4-4 4"/><path d="M3 11v-1a4 4 0 0 1 4-4h14"/><path d="m7 22-4-4 4-4"/><path d="M21 13v1a4 4 0 0 1-4 4H3"/></svg>
               </div>
               <h4 class="text-blue-400 font-bold uppercase tracking-widest text-xs" data-ps="src/pages/use-cases/resale-circular-economy.astro:evidence-label-1">Lifecycle Integrity</h4>
             </div>
             <ul class="space-y-6" data-ps="src/pages/use-cases/resale-circular-economy.astro:evidence-list-1">
               <li class="flex items-center gap-4 group" data-ps="src/pages/use-cases/resale-circular-economy.astro:evidence-li-1">
                 <div class="w-2 h-2 rounded-full bg-blue-500 shadow-[0_0_10px_#3b82f6]" data-ps="src/pages/use-cases/resale-circular-economy.astro:8ygl36"></div>
                 <span class="text-lg font-medium text-slate-200" data-ps="src/pages/use-cases/resale-circular-economy.astro:evidence-txt-1">Provenance Continuity</span>
               </li>
               <li class="flex items-center gap-4 group" data-ps="src/pages/use-cases/resale-circular-economy.astro:evidence-li-2">
                 <div class="w-2 h-2 rounded-full bg-blue-500 shadow-[0_0_10px_#3b82f6]" data-ps="src/pages/use-cases/resale-circular-economy.astro:8ygl37"></div>
