---
import BaseLayout from &#x27;@/layouts/BaseLayout.astro&#x27;;
import { SITE } from &#x27;@/config/site&#x27;;

const title = &quot;Revente et économie circulaire — TieBack&quot;;
const description = &quot;Préservez la confiance lorsque les produits changent de mains. TieBack conserve l&#x27;identité et le contexte du produit intacts lors de la revente, des dons et des programmes circulaires.&quot;;
---

<BaseLayout title=<astro-expr id="1">
  description={description}
  &gt;
  <!-- 1. Use Case Hero (Enhanced with Depth) -->
  <section class="relative pt-32 pb-24 md:pt-52 md:pb-40 overflow-hidden bg-white" data-ps="src/pages/use-cases/resale-circular-economy.astro:cloe6q">
    <!-- Subtle Background Accents -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-7xl pointer-events-none" data-ps="src/pages/use-cases/resale-circular-economy.astro:bg-accents">
      <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-blue-50/50 blur-[120px]" data-ps="src/pages/use-cases/resale-circular-economy.astro:accent-1"></div>
      <div class="absolute bottom-[10%] right-[-5%] w-[30%] h-[30%] rounded-full bg-slate-50 blur-[100px]" data-ps="src/pages/use-cases/resale-circular-economy.astro:accent-2"></div>
    </div>

    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/use-cases/resale-circular-economy.astro:6g628h">
      <div class="max-w-4xl mx-auto text-center" data-ps="src/pages/use-cases/resale-circular-economy.astro:6g627v">
        <div class="inline-flex items-center gap-2 py-1 px-3 mb-8 text-[11px] font-bold tracking-widest text-blue-600 uppercase bg-blue-50/80 backdrop-blur-sm border border-blue-100 rounded-full" data-ps="src/pages/use-cases/resale-circular-economy.astro:771h9b">
          <span class="w-1.5 h-1.5 rounded-full bg-blue-600 animate-pulse" data-ps="src/pages/use-cases/resale-circular-economy.astro:9eb0t6"></span>
          Revente et remise des clés
        </div>
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight text-slate-900 mb-8 leading-[1.05]" data-ps="src/pages/use-cases/resale-circular-economy.astro:jg65d">
        
          Revente et <span class="text-blue-600" data-ps="src/pages/use-cases/resale-circular-economy.astro:9eb0t5">économie circulaire</span>
        </h1>
        <p class="text-xl md:text-2xl text-slate-600 mb-12 leading-relaxed max-w-2xl mx-auto" data-ps="src/pages/use-cases/resale-circular-economy.astro:8k945v">
          Conçu pour les produits qui vont au-delà de la première transaction. TieBack préserve l&#x27;identité et le contexte du produit lors des changements de propriétaire, afin que la confiance et les informations d&#x27;accompagnement suivent l&#x27;article.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-5" data-ps="src/pages/use-cases/resale-circular-economy.astro:6g627u">
          <a href="#request-access" class="w-full sm:w-auto px-10 py-4 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl transition-all duration-300 shadow-xl shadow-blue-200 hover:-translate-y-1" data-ps="src/pages/use-cases/resale-circular-economy.astro:1gb7hr">
            Demander l&#x27;accès
          </a>
          
          <a href="/platform/why-tieback/" class="w-full sm:w-auto px-10 py-4 bg-white border border-slate-200 text-slate-700 font-semibold rounded-xl hover:bg-slate-50 transition-all duration-300 hover:border-slate-300" data-ps="src/pages/use-cases/resale-circular-economy.astro:1gb7hq">
            Présentation de la plateforme
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. The Reality of Resale (Challenge section) -->
  <section class="py-32 bg-slate-50 border-y border-slate-200/60 relative overflow-hidden" data-ps="src/pages/use-cases/resale-circular-economy.astro:cloe6r">
    <div class="container mx-auto px-6" data-ps="src/pages/use-cases/resale-circular-economy.astro:6g627t">
      <div class="grid lg:grid-cols-2 gap-20 items-center" data-ps="src/pages/use-cases/resale-circular-economy.astro:6g627s">
        <div class="relative" data-ps="src/pages/use-cases/resale-circular-economy.astro:6g627r">
          <div class="absolute -top-12 -left-12 w-24 h-24 bg-blue-100/50 rounded-full blur-2xl" data-ps="src/pages/use-cases/resale-circular-economy.astro:accent-3"></div>
          <h2 class="text-4xl md:text-5xl font-bold text-slate-900 leading-[1.15] relative" data-ps="src/pages/use-cases/resale-circular-economy.astro:e4yr2w">
            La plupart des marques ne disposent d&#x27;aucun moyen structuré pour garantir la confiance une fois qu&#x27;un produit <span class="italic font-serif text-blue-600" data-ps="src/pages/use-cases/resale-circular-economy.astro:9eb0t4">change de mains</span>.
          </h2>
          <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-1 gap-8" data-ps="src/pages/use-cases/resale-circular-economy.astro:list-wrapper">
             <div class="flex gap-6 group bg-white/50 backdrop-blur-sm p-6 rounded-2xl border border-slate-200 transition-all hover:border-blue-200 hover:shadow-lg hover:shadow-blue-50" data-ps="src/pages/use-cases/resale-circular-economy.astro:list-item-1">
                <div class="w-12 h-12 rounded-xl bg-blue-600 flex items-center justify-center shrink-0 shadow-lg shadow-blue-100" data-ps="src/pages/use-cases/resale-circular-economy.astro:icon-box-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-alert-circle"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
                </div>
                <div data-ps="src/pages/use-cases/resale-circular-economy.astro:8ygl37">
                  <h4 class="font-bold text-slate-900 mb-1" data-ps="src/pages/use-cases/resale-circular-economy.astro:list-h-1">Manque de contexte</h4>
                  <p class="text-slate-600 text-sm" data-ps="src/pages/use-cases/resale-circular-economy.astro:list-p-1">Les acheteurs de produits d&#x27;occasion manquent de contexte fiable et d&#x27;instructions d&#x27;entretien, ce qui conduit à une mauvaise utilisation ou à une perte de valeur.</p>
                </div>
             </div>
             <div class="flex gap-6 group bg-white/50 backdrop-blur-sm p-6 rounded-2xl border border-slate-200 transition-all hover:border-blue-200 hover:shadow-lg hover:shadow-blue-50" data-ps="src/pages/use-cases/resale-circular-economy.astro:list-item-2">
                <div class="w-12 h-12 rounded-xl bg-blue-600 flex items-center justify-center shrink-0 shadow-lg shadow-blue-100" data-ps="src/pages/use-cases/resale-circular-economy.astro:icon-box-2">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-user-minus"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="22" x2="16" y1="11" y2="11"/></svg>
                </div>
                <div data-ps="src/pages/use-cases/resale-circular-economy.astro:8ygl38">
                  <h4 class="font-bold text-slate-900 mb-1" data-ps="src/pages/use-cases/resale-circular-economy.astro:list-h-2">Perte de visibilité</h4>
                  <p class="text-slate-600 text-sm" data-ps="src/pages/use-cases/resale-circular-economy.astro:list-p-2">Les marques perdent généralement toute visibilité et tout potentiel d&#x27;engagement après la première transaction.</p>
                </div>
             </div>
          </div>
        </div>
        <div class="relative" data-ps="src/pages/use-cases/resale-circular-economy.astro:6g627q">
          <div class="bg-white p-8 md:p-12 rounded-[2rem] border border-slate-200 shadow-2xl shadow-slate-200/50" data-ps="src/pages/use-cases/resale-circular-economy.astro:6g627p">
            <p class="text-2xl text-slate-800 leading-relaxed mb-8 font-medium" data-ps="src/pages/use-cases/resale-circular-economy.astro:8k945u">
              Les marchés secondaires sont en pleine croissance. L&#x27;authenticité devient un sujet de litige, et les conseils en matière de durabilité sont perdus sans identité persistante.
            </p>
            <div class="h-px bg-slate-100 mb-8" data-ps="src/pages/use-cases/resale-circular-economy.astro:divider"></div>
            <div class="grid gap-6" data-ps="src/pages/use-cases/resale-circular-economy.astro:grid-info">
              <div class="flex items-start gap-4" data-ps="src/pages/use-cases/resale-circular-economy.astro:ddzuom">
                <span class="w-2 h-2 rounded-full bg-blue-600 mt-2.5 shrink-0" data-ps="src/pages/use-cases/resale-circular-economy.astro:771h98"></span>
                <p class="text-slate-600 text-lg" data-ps="src/pages/use-cases/resale-circular-economy.astro:771h98_p">L&#x27;établissement d&#x27;un point de référence clair pour le transfert de propriété garantit la continuité de l&#x27;historique du produit.</p>
              </div>
              <div class="flex items-start gap-4" data-ps="src/pages/use-cases/resale-circular-economy.astro:ddzuol">
                <span class="w-2 h-2 rounded-full bg-blue-600 mt-2.5 shrink-0" data-ps="src/pages/use-cases/resale-circular-economy.astro:771h97"></span>
                <p class="text-slate-600 text-lg" data-ps="src/pages/use-cases/resale-circular-economy.astro:771h97_p">Les transferts ne sont pas seulement opérationnels ; ils constituent une occasion d&#x27;accueillir le prochain propriétaire dans une expérience de marque.</p>
              </div>
            </div>
          </div>
          <!-- Decorative element -->
          <div class="absolute -bottom-6 -right-6 w-32 h-32 border-b-2 border-r-2 border-blue-100 rounded-br-3xl pointer-events-none" data-ps="src/pages/use-cases/resale-circular-economy.astro:deco-corner"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. How TieBack structures resale (3-Column Card Grid) -->
  <section class="py-32 bg-white" data-ps="src/pages/use-cases/resale-circular-economy.astro:cloe6s">
    <div class="container mx-auto px-6" data-ps="src/pages/use-cases/resale-circular-economy.astro:6g627o">
      <div class="max-w-3xl mb-20" data-ps="src/pages/use-cases/resale-circular-economy.astro:6g627n">
