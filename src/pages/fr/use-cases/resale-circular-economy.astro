        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/resale-circular-economy.astro:6g6270">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/resale-circular-economy.astro:card-deco-1"></div>
