                </div>
                <div class="w-px h-10 bg-white/10" data-ps="src/pages/use-cases/warranty-aftercare.astro:stat-sep"></div>
                <div data-ps="src/pages/use-cases/warranty-aftercare.astro:stat-2">
                  <div class="text-3xl font-bold text-blue-400" data-ps="src/pages/use-cases/warranty-aftercare.astro:stat-v2">Low</div>
                  <div class="text-xs uppercase tracking-widest text-slate-400 font-bold" data-ps="src/pages/use-cases/warranty-aftercare.astro:stat-l2">Support Effort</div>
                </div>
             </div>
           </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Final CTA (Premium Styling) -->
  <section id="request-access" class="py-32 bg-white relative overflow-hidden" data-ps="src/pages/use-cases/warranty-aftercare.astro:cta-section">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_left,_var(--tw-gradient-stops))] from-blue-50/50 via-transparent to-transparent pointer-events-none" data-ps="src/pages/use-cases/warranty-aftercare.astro:cta-grad"></div>
    <div class="container mx-auto px-6 relative z-10 text-center" data-ps="src/pages/use-cases/warranty-aftercare.astro:cta-container">
      <div class="max-w-4xl mx-auto" data-ps="src/pages/use-cases/warranty-aftercare.astro:cta-content">
        <h2 class="text-5xl md:text-6xl font-bold text-slate-900 mb-8 tracking-tight" data-ps="src/pages/use-cases/warranty-aftercare.astro:cta-h">A product record that stays <span class="text-blue-600" data-ps="src/pages/use-cases/warranty-aftercare.astro:cta-accent">useful over time.</span></h2>
        <p class="text-xl text-slate-600 mb-12 max-w-2xl mx-auto leading-relaxed" data-ps="src/pages/use-cases/warranty-aftercare.astro:cta-p">
          Build a verifiable reference for warranty and service. Join the organizations managing their product aftercare strategy on TieBack.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-6" data-ps="src/pages/use-cases/warranty-aftercare.astro:cta-buttons">
          <button class="w-full sm:w-auto px-12 py-5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-2xl transition-all duration-300 shadow-2xl shadow-blue-200 hover:-translate-y-1" data-ps="src/pages/use-cases/warranty-aftercare.astro:btn-main">
            Request Early Access
          </button>
          <div class="flex flex-col gap-2" data-ps="src/pages/use-cases/warranty-aftercare.astro:related-links">
            <a href="/use-cases/resale-circular-economy/" class="group text-slate-900 font-bold flex items-center gap-3 transition-colors hover:text-blue-600 text-sm" data-ps="src/pages/use-cases/warranty-aftercare.astro:link-1">
              Resale & Circular Economy <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
            <a href="/use-cases/product-safety-recalls/" class="group text-slate-900 font-bold flex items-center gap-3 transition-colors hover:text-blue-600 text-sm" data-ps="src/pages/use-cases/warranty-aftercare.astro:link-2">
              Product Safety & Recalls <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
