---,
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/config/site';

const title = "Ownership, Warranty & Aftercare — TieBack";
const description = "Structured aftercare beyond the point of sale. TieBack keeps ownership, eligibility, and service history attached to the product.";
,

<BaseLayout title={title} description={description}>
  <!-- 1. Use Case Hero (Enhanced with Depth) -->
  <section class="relative pt-32 pb-24 md:pt-52 md:pb-40 overflow-hidden bg-white" data-ps="src/pages/use-cases/warranty-aftercare.astro:hero">
    <!-- Subtle Background Accents -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-7xl pointer-events-none" data-ps="src/pages/use-cases/warranty-aftercare.astro:bg-accents">
      <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-blue-50/50 blur-[120px]" data-ps="src/pages/use-cases/warranty-aftercare.astro:accent-1"></div>
      <div class="absolute bottom-[10%] right-[-5%] w-[30%] h-[30%] rounded-full bg-slate-50 blur-[100px]" data-ps="src/pages/use-cases/warranty-aftercare.astro:accent-2"></div>
    </div>

    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/use-cases/warranty-aftercare.astro:hero-container">
      <div class="max-w-4xl mx-auto text-center" data-ps="src/pages/use-cases/warranty-aftercare.astro:hero-content">
        <div class="inline-flex items-center gap-2 py-1 px-3 mb-8 text-[11px] font-bold tracking-widest text-blue-600 uppercase bg-blue-50/80 backdrop-blur-sm border border-blue-100 rounded-full" data-ps="src/pages/use-cases/warranty-aftercare.astro:label-box">
          <span class="w-1.5 h-1.5 rounded-full bg-blue-600 animate-pulse" data-ps="src/pages/use-cases/warranty-aftercare.astro:pulse"></span>
          Aftercare & service
        </div>
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight text-slate-900 mb-8 leading-[1.05]" data-ps="src/pages/use-cases/warranty-aftercare.astro:title">
          Ownership, Warranty <span class="text-blue-600" data-ps="src/pages/use-cases/warranty-aftercare.astro:title-accent">& Aftercare</span>
        </h1>
        <p class="text-xl md:text-2xl text-slate-600 mb-12 leading-relaxed max-w-2xl mx-auto" data-ps="src/pages/use-cases/warranty-aftercare.astro:hero-description">
          Built for products that require service, warranty validation, or support verification. TieBack keeps ownership status, eligibility, and service history attached to the product.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-5" data-ps="src/pages/use-cases/warranty-aftercare.astro:hero-ctas">
          <a href="#request-access" class="w-full sm:w-auto px-10 py-4 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl transition-all duration-300 shadow-xl shadow-blue-200 hover:-translate-y-1" data-ps="src/pages/use-cases/warranty-aftercare.astro:cta-primary">
            Request Access
          </a>
          <a href="/platform/why-tieback/" class="w-full sm:w-auto px-10 py-4 bg-white border border-slate-200 text-slate-700 font-semibold rounded-xl hover:bg-slate-50 transition-all duration-300 hover:border-slate-300" data-ps="src/pages/use-cases/warranty-aftercare.astro:cta-secondary">
            Platform Overview
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. The Challenge (Impactful Layout) -->
  <section class="py-32 bg-slate-50 border-y border-slate-200/60 relative overflow-hidden" data-ps="src/pages/use-cases/warranty-aftercare.astro:friction-section">
    <div class="container mx-auto px-6" data-ps="src/pages/use-cases/warranty-aftercare.astro:friction-container">
      <div class="grid lg:grid-cols-2 gap-20 items-center" data-ps="src/pages/use-cases/warranty-aftercare.astro:friction-grid">
        <div class="relative" data-ps="src/pages/use-cases/warranty-aftercare.astro:friction-left">
          <div class="absolute -top-12 -left-12 w-24 h-24 bg-blue-100/50 rounded-full blur-2xl" data-ps="src/pages/use-cases/warranty-aftercare.astro:friction-accent"></div>
          <h2 class="text-4xl md:text-5xl font-bold text-slate-900 leading-[1.15] relative" data-ps="src/pages/use-cases/warranty-aftercare.astro:friction-title">
            Aftercare becomes a <span class="italic font-serif text-blue-600" data-ps="src/pages/use-cases/warranty-aftercare.astro:friction-title-accent">structured workflow</span>, not a ticket trail.
          </h2>
          <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-1 gap-8" data-ps="src/pages/use-cases/warranty-aftercare.astro:friction-list">
             <div class="flex gap-6 group bg-white/50 backdrop-blur-sm p-6 rounded-2xl border border-slate-200 transition-all hover:border-blue-200 hover:shadow-lg hover:shadow-blue-50" data-ps="src/pages/use-cases/warranty-aftercare.astro:friction-item-1">
                <div class="w-12 h-12 rounded-xl bg-blue-600 flex items-center justify-center shrink-0 shadow-lg shadow-blue-100" data-ps="src/pages/use-cases/warranty-aftercare.astro:friction-icon-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-search-check"><path d="m8 11 2 2 4-4"/><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                </div>
                <div data-ps="src/pages/use-cases/warranty-aftercare.astro:friction-text-1">
                  <h4 class="font-bold text-slate-900 mb-1" data-ps="src/pages/use-cases/warranty-aftercare.astro:friction-h-1">Fragmented Identity</h4>
                  <p class="text-slate-600 text-sm" data-ps="src/pages/use-cases/warranty-aftercare.astro:friction-p-1">Proof is scattered across receipts, emails, and portals, leading to validation friction.</p>
                </div>
             </div>
             <div class="flex gap-6 group bg-white/50 backdrop-blur-sm p-6 rounded-2xl border border-slate-200 transition-all hover:border-blue-200 hover:shadow-lg hover:shadow-blue-50" data-ps="src/pages/use-cases/warranty-aftercare.astro:friction-item-2">
                <div class="w-12 h-12 rounded-xl bg-blue-600 flex items-center justify-center shrink-0 shadow-lg shadow-blue-100" data-ps="src/pages/use-cases/warranty-aftercare.astro:friction-icon-2">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-history"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M12 7v5l4 2"/></svg>
                </div>
                <div data-ps="src/pages/use-cases/warranty-aftercare.astro:friction-text-2">
                  <h4 class="font-bold text-slate-900 mb-1" data-ps="src/pages/use-cases/warranty-aftercare.astro:friction-h-2">Inconsistent Records</h4>
                  <p class="text-slate-600 text-sm" data-ps="src/pages/use-cases/warranty-aftercare.astro:friction-p-2">Service history doesn't travel with the product, creating uncertainty for second owners.</p>
                </div>
             </div>
          </div>
        </div>
        <div class="relative" data-ps="src/pages/use-cases/warranty-aftercare.astro:friction-right">
          <div class="bg-white p-8 md:p-12 rounded-[2rem] border border-slate-200 shadow-2xl shadow-slate-200/50" data-ps="src/pages/use-cases/warranty-aftercare.astro:friction-card">
            <p class="text-2xl text-slate-800 leading-relaxed mb-8 font-medium" data-ps="src/pages/use-cases/warranty-aftercare.astro:friction-intro">
              TieBack keeps aftercare fast, calm, and consistent by attaching eligibility to the product identity.
            </p>
            <div class="h-px bg-slate-100 mb-8" data-ps="src/pages/use-cases/warranty-aftercare.astro:friction-divider"></div>
            <div class="grid gap-6" data-ps="src/pages/use-cases/warranty-aftercare.astro:friction-points">
              <div class="flex items-start gap-4" data-ps="src/pages/use-cases/warranty-aftercare.astro:point-1">
                <span class="w-2 h-2 rounded-full bg-blue-600 mt-2.5 shrink-0" data-ps="src/pages/use-cases/warranty-aftercare.astro:dot-1"></span>
                <p class="text-slate-600 text-lg" data-ps="src/pages/use-cases/warranty-aftercare.astro:p-1">Support teams shouldn't have to "re-prove" the product every time; they need a consistent product record.</p>
              </div>
              <div class="flex items-start gap-4" data-ps="src/pages/use-cases/warranty-aftercare.astro:point-2">
                <span class="w-2 h-2 rounded-full bg-blue-600 mt-2.5 shrink-0" data-ps="src/pages/use-cases/warranty-aftercare.astro:dot-2"></span>
                <p class="text-slate-600 text-lg" data-ps="src/pages/use-cases/warranty-aftercare.astro:p-2">Establishing a clean reference point for warranty and service workflows reduces manual back-and-forth.</p>
              </div>
            </div>
          </div>
          <!-- Decorative element -->
          <div class="absolute -bottom-6 -right-6 w-32 h-32 border-b-2 border-r-2 border-blue-100 rounded-br-3xl pointer-events-none" data-ps="src/pages/use-cases/warranty-aftercare.astro:deco-corner"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. The Solution / Capabilities (3-Column Card Grid) -->
  <section class="py-32 bg-white" data-ps="src/pages/use-cases/warranty-aftercare.astro:capabilities-section">
    <div class="container mx-auto px-6" data-ps="src/pages/use-cases/warranty-aftercare.astro:capabilities-container">
      <div class="max-w-3xl mb-20" data-ps="src/pages/use-cases/warranty-aftercare.astro:capabilities-intro">
        <span class="text-blue-600 font-bold uppercase tracking-wider text-xs block mb-4" data-ps="src/pages/use-cases/warranty-aftercare.astro:capabilities-label">Capabilities</span>
        <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6" data-ps="src/pages/use-cases/warranty-aftercare.astro:capabilities-title">Structured Lifecycle Aftercare.</h2>
        <p class="text-slate-600 text-xl leading-relaxed" data-ps="src/pages/use-cases/warranty-aftercare.astro:capabilities-p">TieBack structures aftercare as a lifecycle reference, ensuring continuity across ownership transfers and service events.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-ps="src/pages/use-cases/warranty-aftercare.astro:capabilities-grid">
        <!-- Card 1 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/warranty-aftercare.astro:card-1">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/warranty-aftercare.astro:card-deco-1"></div>
          <div class="w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/warranty-aftercare.astro:card-icon-1">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/use-cases/warranty-aftercare.astro:card-h-1">Ownership Reference</h3>
          <p class="text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/use-cases/warranty-aftercare.astro:card-p-1">Ownership as a structured event tied to the product record, not just a marketing sign-up.</p>
          <ul class="space-y-4 text-slate-700 font-medium" data-ps="src/pages/use-cases/warranty-aftercare.astro:card-list-1">
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/warranty-aftercare.astro:li-1-1"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Ownership claim</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/warranty-aftercare.astro:li-1-2"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Timestamped starts</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/warranty-aftercare.astro:li-1-3"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Item identity linkage</li>
          </ul>
        </div>

        <!-- Card 2 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/warranty-aftercare.astro:card-2">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/warranty-aftercare.astro:card-deco-2"></div>
          <div class="w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/warranty-aftercare.astro:card-icon-2">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/use-cases/warranty-aftercare.astro:card-h-2">Validation Engine</h3>
          <p class="text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/use-cases/warranty-aftercare.astro:card-p-2">When a product is presented for service, teams need a fast, defensible answer on eligibility and authenticity.</p>
          <ul class="space-y-4 text-slate-700 font-medium" data-ps="src/pages/use-cases/warranty-aftercare.astro:card-list-2">
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/warranty-aftercare.astro:li-2-1"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Authenticity confirmation</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/warranty-aftercare.astro:li-2-2"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Ownership-aware checks</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/warranty-aftercare.astro:li-2-3"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Warranty visibility</li>
          </ul>
        </div>

        <!-- Card 3 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/warranty-aftercare.astro:card-3">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/warranty-aftercare.astro:card-deco-3"></div>
          <div class="w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/warranty-aftercare.astro:card-icon-3">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/use-cases/warranty-aftercare.astro:card-h-3">Service Continuity</h3>
          <p class="text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/use-cases/warranty-aftercare.astro:card-p-3">Repair and service events remain attached to the product identity, ensuring history travels with the item.</p>
          <ul class="space-y-4 text-slate-700 font-medium" data-ps="src/pages/use-cases/warranty-aftercare.astro:card-list-3">
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/warranty-aftercare.astro:li-3-1"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Logged service events</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/warranty-aftercare.astro:li-3-2"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Versioned history</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/warranty-aftercare.astro:li-3-3"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Continuity across time</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Visual Separator Section: The Continuity Model -->
  <section class="py-24 bg-slate-950 text-white relative overflow-hidden" data-ps="src/pages/use-cases/warranty-aftercare.astro:continuity-section">
    <div class="absolute inset-0 opacity-30" data-ps="src/pages/use-cases/warranty-aftercare.astro:img-container">
      <img crossorigin="anonymous"
        src="https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&w=1200&q=80"
        srcset="https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&w=320&q=80 320w, https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&w=640&q=80 640w, https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&w=768&q=80 768w, https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&w=1024&q=80 1024w, https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&w=1280&q=80 1280w, https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&w=1920&q=80 1920w"
        sizes="100vw"
        alt="Technical support and service" class="w-full h-full object-cover" data-ps="src/pages/use-cases/warranty-aftercare.astro:img" />
      <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/80 to-transparent" data-ps="src/pages/use-cases/warranty-aftercare.astro:img-grad"></div>
    </div>
    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/use-cases/warranty-aftercare.astro:continuity-container">
      <div class="max-w-5xl mx-auto" data-ps="src/pages/use-cases/warranty-aftercare.astro:continuity-grid-wrap">
        <h2 class="text-3xl md:text-5xl font-bold mb-16 text-center" data-ps="src/pages/use-cases/warranty-aftercare.astro:continuity-h">Built for continuity.</h2>
        <div class="grid lg:grid-cols-2 gap-16 items-center" data-ps="src/pages/use-cases/warranty-aftercare.astro:continuity-grid">
           <div class="bg-white/5 backdrop-blur-xl p-10 rounded-[2.5rem] border border-white/10 shadow-2xl" data-ps="src/pages/use-cases/warranty-aftercare.astro:continuity-box">
             <div class="flex items-center gap-4 mb-8" data-ps="src/pages/use-cases/warranty-aftercare.astro:continuity-header">
               <div class="w-10 h-10 rounded-xl bg-blue-500/20 flex items-center justify-center" data-ps="src/pages/use-cases/warranty-aftercare.astro:continuity-icon-box">
                 <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#60a5fa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-repeat"><path d="m17 2 4 4-4 4"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><path d="m7 22-4-4 4-4"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
               </div>
               <h4 class="text-blue-400 font-bold uppercase tracking-widest text-xs" data-ps="src/pages/use-cases/warranty-aftercare.astro:continuity-label">Service Handover</h4>
             </div>
             <ul class="space-y-6" data-ps="src/pages/use-cases/warranty-aftercare.astro:continuity-list">
               <li class="flex items-center gap-4 group" data-ps="src/pages/use-cases/warranty-aftercare.astro:li-1">
                 <div class="w-2 h-2 rounded-full bg-blue-500 shadow-[0_0_10px_#3b82f6]" data-ps="src/pages/use-cases/warranty-aftercare.astro:dot-1"></div>
                 <span class="text-lg font-medium text-slate-200" data-ps="src/pages/use-cases/warranty-aftercare.astro:txt-1">Reduced Warranty Friction</span>
               </li>
               <li class="flex items-center gap-4 group" data-ps="src/pages/use-cases/warranty-aftercare.astro:li-2">
                 <div class="w-2 h-2 rounded-full bg-blue-500 shadow-[0_0_10px_#3b82f6]" data-ps="src/pages/use-cases/warranty-aftercare.astro:dot-2"></div>
                 <span class="text-lg font-medium text-slate-200" data-ps="src/pages/use-cases/warranty-aftercare.astro:txt-2">Faster Support Workflows</span>
               </li>
               <li class="flex items-center gap-4 group" data-ps="src/pages/use-cases/warranty-aftercare.astro:li-3">
                 <div class="w-2 h-2 rounded-full bg-blue-500 shadow-[0_0_10px_#3b82f6]" data-ps="src/pages/use-cases/warranty-aftercare.astro:dot-3"></div>
                 <span class="text-lg font-medium text-slate-200" data-ps="src/pages/use-cases/warranty-aftercare.astro:txt-3">Consistent Eligibility Rules</span>
               </li>
             </ul>
           </div>
