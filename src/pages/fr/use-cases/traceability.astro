---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = "Traceability & Safety — TieBack";
const description = "End-to-end supply chain visibility and product safety tracking with TieBack.";
---



<BaseLayout title={title} description={description}>
  <section class="relative pt-32 pb-24 md:pt-52 md:pb-40 overflow-hidden bg-white" data-ps="src/pages/use-cases/traceability.astro:hero">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-7xl pointer-events-none" data-ps="src/pages/use-cases/traceability.astro:bg-accents">
      <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-indigo-50/50 blur-[120px]" data-ps="src/pages/use-cases/traceability.astro:accent-1"></div>
      <div class="absolute bottom-[10%] right-[-5%] w-[30%] h-[30%] rounded-full bg-slate-50 blur-[100px]" data-ps="src/pages/use-cases/traceability.astro:accent-2"></div>
    </div>

    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/use-cases/traceability.astro:hero-container">
      <div class="max-w-4xl mx-auto text-center" data-ps="src/pages/use-cases/traceability.astro:hero-content">
        <div class="inline-flex items-center gap-2 py-1 px-3 mb-8 text-[11px] font-bold tracking-widest text-indigo-700 uppercase bg-indigo-50/80 backdrop-blur-sm border border-indigo-100 rounded-full" data-ps="src/pages/use-cases/traceability.astro:eyebrow">
          <span class="w-1.5 h-1.5 rounded-full bg-indigo-600 animate-pulse" data-ps="src/pages/use-cases/traceability.astro:pulse"></span>
          Cas d'utilisation
        </div>
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight text-slate-900 mb-8 leading-[1.05]" data-ps="src/pages/use-cases/traceability.astro:title">
        
          Traçabilité et <span class="text-indigo-600" data-ps="src/pages/use-cases/traceability.astro:title-indigo">sécurité</span>
        </h1>
        <p class="text-xl md:text-2xl text-slate-600 mb-12 leading-relaxed max-w-2xl mx-auto" data-ps="src/pages/use-cases/traceability.astro:subtext">
          Cartographiez votre chaîne d'approvisionnement, des matières premières aux produits finis. Réagissez rapidement aux incidents de sécurité grâce à une traçabilité précise, au niveau de chaque article.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-5" data-ps="src/pages/use-cases/traceability.astro:buttons">
          <a href="/request-access" class="w-full sm:w-auto px-10 py-4 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-xl transition-all duration-300 shadow-xl shadow-indigo-200 hover:-translate-y-1" data-ps="src/pages/use-cases/traceability.astro:btn-primary">
            Demander l'accès
          </a>
          
          <a href="/platform" class="w-full sm:w-auto px-10 py-4 bg-white border border-slate-200 text-slate-700 font-semibold rounded-xl hover:bg-slate-50 transition-all duration-300 hover:border-slate-300" data-ps="src/pages/use-cases/traceability.astro:btn-secondary">
            Présentation de la plateforme
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-32 bg-slate-50 border-y border-slate-200/60 relative overflow-hidden" data-ps="src/pages/use-cases/traceability.astro:content">
    <div class="container mx-auto px-6 text-center max-w-3xl" data-ps="src/pages/use-cases/traceability.astro:content-container">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-6" data-ps="src/pages/use-cases/traceability.astro:h2">Sécurisation de la chaîne d'approvisionnement</h2>
      <p class="text-lg text-slate-600 mb-8" data-ps="src/pages/use-cases/traceability.astro:p1">
        Les chaînes d'approvisionnement modernes exigent une transparence absolue. TieBack fournit l'infrastructure nécessaire pour suivre en toute sécurité l'origine, les mouvements et la chaîne de traçabilité au niveau de chaque article.
      </p>
      <p class="text-lg text-slate-600" data-ps="src/pages/use-cases/traceability.astro:p2">
        En cas de rappel de produit ou d'avis de sécurité, identifiez précisément les articles concernés et informez directement les utilisateurs via l'identité numérique du produit.
      </p>
    </div>
  </section>
</BaseLayout>
