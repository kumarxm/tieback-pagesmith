---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/config/site';

const title = "Product as a Channel — TieBack";
const description = "Turn physical products into structured digital endpoints with persistent identity, market-aware content, and campaign routing.";
---






<baselayout title="{title}" description="{description}">
  <!-- 1. Use Case Hero -->
  <section class="relative pt-32 pb-24 md:pt-52 md:pb-40 overflow-hidden bg-white" data-ps="src/pages/use-cases/product-as-a-channel.astro:cloe6q">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-7xl pointer-events-none" data-ps="src/pages/use-cases/product-as-a-channel.astro:bg-accents">
      <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-blue-50/50 blur-[120px]" data-ps="src/pages/use-cases/product-as-a-channel.astro:accent-1"></div>
      <div class="absolute bottom-[10%] right-[-5%] w-[30%] h-[30%] rounded-full bg-slate-50 blur-[100px]" data-ps="src/pages/use-cases/product-as-a-channel.astro:accent-2"></div>
    </div>
</section></baselayout>


    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/use-cases/product-as-a-channel.astro:6g628h">
      <div class="max-w-4xl mx-auto text-center" data-ps="src/pages/use-cases/product-as-a-channel.astro:6g627v">
        <div class="inline-flex items-center gap-2 py-1 px-3 mb-8 text-[11px] font-bold tracking-widest text-blue-600 uppercase bg-blue-50/80 backdrop-blur-sm border border-blue-100 rounded-full" data-ps="src/pages/use-cases/product-as-a-channel.astro:771h9b">
          <span class="w-1.5 h-1.5 rounded-full bg-blue-600 animate-pulse" data-ps="src/pages/use-cases/product-as-a-channel.astro:9eb0t6"></span>
          Cas n° 10
        </div>
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight text-slate-900 mb-8 leading-[1.05]" data-ps="src/pages/use-cases/product-as-a-channel.astro:jg65d">
        
          Le produit comme <span class="text-blue-600" data-ps="src/pages/use-cases/product-as-a-channel.astro:9eb0t5">canal</span>
        </h1>
        <p class="text-xl md:text-2xl text-slate-600 mb-12 leading-relaxed max-w-2xl mx-auto" data-ps="src/pages/use-cases/product-as-a-channel.astro:8k945v">
          Transformer les produits physiques en terminaux numériques structurés.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-5" data-ps="src/pages/use-cases/product-as-a-channel.astro:6g627u">
          <a href="#request-access" class="w-full sm:w-auto px-10 py-4 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl transition-all duration-300 shadow-xl shadow-blue-200 hover:-translate-y-1" data-ps="src/pages/use-cases/product-as-a-channel.astro:1gb7hr">
            Demander l'accès
          </a>
          
          <a href="/platform/why-tieback/" class="w-full sm:w-auto px-10 py-4 bg-white border border-slate-200 text-slate-700 font-semibold rounded-xl hover:bg-slate-50 transition-all duration-300 hover:border-slate-300" data-ps="src/pages/use-cases/product-as-a-channel.astro:1gb7hq">
            Présentation de la plateforme
          </a>
        </div>
      </div>
    </div>
  



  <!-- 2. The Challenge -->
  <section class="py-32 bg-slate-50 border-y border-slate-200/60 relative overflow-hidden" data-ps="src/pages/use-cases/product-as-a-channel.astro:cloe6r">
    <div class="container mx-auto px-6" data-ps="src/pages/use-cases/product-as-a-channel.astro:6g627t">
      <div class="grid lg:grid-cols-2 gap-20 items-center" data-ps="src/pages/use-cases/product-as-a-channel.astro:6g627s">
        <div class="relative" data-ps="src/pages/use-cases/product-as-a-channel.astro:6g627r">
          <div class="absolute -top-12 -left-12 w-24 h-24 bg-blue-100/50 rounded-full blur-2xl" data-ps="src/pages/use-cases/product-as-a-channel.astro:accent-3"></div>
          <h2 class="text-4xl md:text-5xl font-bold text-slate-900 leading-[1.15] relative" data-ps="src/pages/use-cases/product-as-a-channel.astro:e4yr2w">
            Conçu pour les marques qui considèrent leurs produits comme <span class="italic font-serif text-blue-600" data-ps="src/pages/use-cases/product-as-a-channel.astro:9eb0t4">des points de contact permanents</span>.
          </h2>
          <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-1 gap-8" data-ps="src/pages/use-cases/product-as-a-channel.astro:list-wrapper">
             <div class="flex gap-6 group bg-white/50 backdrop-blur-sm p-6 rounded-2xl border border-slate-200 transition-all hover:border-blue-200 hover:shadow-lg hover:shadow-blue-50" data-ps="src/pages/use-cases/product-as-a-channel.astro:list-item-1">
                <div class="w-12 h-12 rounded-xl bg-blue-600 flex items-center justify-center shrink-0 shadow-lg shadow-blue-100" data-ps="src/pages/use-cases/product-as-a-channel.astro:icon-box-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-package-search"><path d="M21 10V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l2-1.14"/><path d="m7.5 4.27 9 5.15"/><polyline points="3.29 7 12 12 20.71 7"/><line x1="12" x2="12" y1="22" y2="12"/><circle cx="18.5" cy="15.5" r="2.5"/><path d="M20.27 17.27 22 19"/></svg>
                </div>
                <div data-ps="src/pages/use-cases/product-as-a-channel.astro:8ygl37">
                  <h4 class="font-bold text-slate-900 mb-1" data-ps="src/pages/use-cases/product-as-a-channel.astro:list-h-1">Au-delà de l'emballage statique</h4>
                  <p class="text-slate-600 text-sm" data-ps="src/pages/use-cases/product-as-a-channel.astro:list-p-1">Chaque scan n'est pas seulement une obligation réglementaire. C'est une interface qui reste stable au fil du temps.</p>
                </div>
             </div>
             <div class="flex gap-6 group bg-white/50 backdrop-blur-sm p-6 rounded-2xl border border-slate-200 transition-all hover:border-blue-200 hover:shadow-lg hover:shadow-blue-50" data-ps="src/pages/use-cases/product-as-a-channel.astro:list-item-2">
                <div class="w-12 h-12 rounded-xl bg-blue-600 flex items-center justify-center shrink-0 shadow-lg shadow-blue-100" data-ps="src/pages/use-cases/product-as-a-channel.astro:icon-box-2">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-refresh-cw"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M8 16H3v5"/></svg>
                </div>
                <div data-ps="src/pages/use-cases/product-as-a-channel.astro:8ygl38">
                  <h4 class="font-bold text-slate-900 mb-1" data-ps="src/pages/use-cases/product-as-a-channel.astro:list-h-2">Évolution après-vente</h4>
                  <p class="text-slate-600 text-sm" data-ps="src/pages/use-cases/product-as-a-channel.astro:list-p-2">Le produit physique peut faire évoluer sa présence numérique une fois expédié.</p>
                </div>
             </div>
          </div>
        </div>
        <div class="relative" data-ps="src/pages/use-cases/product-as-a-channel.astro:6g627q">
          <div class="bg-white p-8 md:p-12 rounded-[2rem] border border-slate-200 shadow-2xl shadow-slate-200/50" data-ps="src/pages/use-cases/product-as-a-channel.astro:6g627p">
            <p class="text-2xl text-slate-800 leading-relaxed mb-8 font-medium" data-ps="src/pages/use-cases/product-as-a-channel.astro:8k945u">
              Un produit ne disparaît pas après sa vente. Il reste dans les foyers, continue d'être utilisé et reste en circulation.
            </p>
            <div class="h-px bg-slate-100 mb-8" data-ps="src/pages/use-cases/product-as-a-channel.astro:divider"></div>
            <div class="grid gap-6" data-ps="src/pages/use-cases/product-as-a-channel.astro:grid-info">
              <div class="flex items-start gap-4" data-ps="src/pages/use-cases/product-as-a-channel.astro:ddzuom">
                <span class="w-2 h-2 rounded-full bg-blue-600 mt-2.5 shrink-0" data-ps="src/pages/use-cases/product-as-a-channel.astro:771h98"></span>
                <p class="text-slate-600 text-lg" data-ps="src/pages/use-cases/product-as-a-channel.astro:771h98_p">L'emballage traditionnel est statique. Le passeport numérique du produit le rend dynamique et actualisable.</p>
              </div>
              <div class="flex items-start gap-4" data-ps="src/pages/use-cases/product-as-a-channel.astro:ddzuol">
                <span class="w-2 h-2 rounded-full bg-blue-600 mt-2.5 shrink-0" data-ps="src/pages/use-cases/product-as-a-channel.astro:771h97"></span>
                <p class="text-slate-600 text-lg" data-ps="src/pages/use-cases/product-as-a-channel.astro:771h97_p">TieBack des structures qui s'interfacent pour qu'il reste contrôlé, cohérent et adapté au marché.</p>
              </div>
            </div>
          </div>
          <div class="absolute -bottom-6 -right-6 w-32 h-32 border-b-2 border-r-2 border-blue-100 rounded-br-3xl pointer-events-none" data-ps="src/pages/use-cases/product-as-a-channel.astro:deco-corner"></div>
        </div>
      </div>
    </div>
  </section>



  <!-- 3. Capabilities -->
  <section class="py-32 bg-white" data-ps="src/pages/use-cases/product-as-a-channel.astro:cloe6s">
    <div class="container mx-auto px-6" data-ps="src/pages/use-cases/product-as-a-channel.astro:6g627o">
      <div class="max-w-3xl mb-20" data-ps="src/pages/use-cases/product-as-a-channel.astro:6g627n">
        <span class="text-blue-600 font-bold uppercase tracking-wider text-xs block mb-4" data-ps="src/pages/use-cases/product-as-a-channel.astro:label">Comment ça marche</span>
        <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6" data-ps="src/pages/use-cases/product-as-a-channel.astro:e4yr2a">Structurer l'interface.</h2>
        <p class="text-slate-600 text-xl leading-relaxed" data-ps="src/pages/use-cases/product-as-a-channel.astro:8k945t">TieBack permet aux marques de transformer leurs produits physiques en points de terminaison numériques persistants avec un contrôle granulaire.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-ps="src/pages/use-cases/product-as-a-channel.astro:6g627m">
        <!-- Card 1 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/product-as-a-channel.astro:6g6270">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/product-as-a-channel.astro:card-deco-1"></div>
          <div class="w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/product-as-a-channel.astro:6g626z">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/use-cases/product-as-a-channel.astro:stdoaj">Identité permanente</h3>
          <p class="text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/use-cases/product-as-a-channel.astro:8k9457">Chaque produit éligible est associé à un passeport numérique structuré qui reste stable dans le temps.</p>
          <ul class="space-y-4 text-slate-700 font-medium" data-ps="src/pages/use-cases/product-as-a-channel.astro:card-list-1">
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/product-as-a-channel.astro:ddzuok"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Mise à jour sans reconditionnement</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/product-as-a-channel.astro:ddzuoj"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Statut réglementaire actuel</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/product-as-a-channel.astro:ddzunx"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Historique du cycle de vie</li>
          </ul>
        </div>
</div></div></section>


        <!-- Card 2 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/product-as-a-channel.astro:6g626y">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/product-as-a-channel.astro:card-deco-2"></div>
          <div class="w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/product-as-a-channel.astro:6g626x">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/use-cases/product-as-a-channel.astro:stdoai">Couches contrôlées</h3>
          <p class="text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/use-cases/product-as-a-channel.astro:8k9456">Regroupez les informations réglementaires, les conseils de soins et les données relatives au développement durable au sein d'une même couche.</p>
          <ul class="space-y-4 text-slate-700 font-medium" data-ps="src/pages/use-cases/product-as-a-channel.astro:card-list-2">
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/product-as-a-channel.astro:ddzunv"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Couches d'informations structurées</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/product-as-a-channel.astro:ddzunu"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Routage tenant compte du marché</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/product-as-a-channel.astro:ddzunt"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Contenu limité dans le temps</li>
          </ul>
        </div>



        <!-- Card 3 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/product-as-a-channel.astro:6g626w">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/product-as-a-channel.astro:card-deco-3"></div>
          <div class="w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/product-as-a-channel.astro:6g626v">
