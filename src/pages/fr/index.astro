---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/home/Hero.astro';
import HowItWorks from '@/components/home/HowItWorks.astro';
import Industries from '@/components/home/Industries.astro';
import Features from '@/components/home/Features.astro';
import CTA from '@/components/home/CTA.astro';
import { SITE } from '@/config/site';
---



<BaseLayout
  title={SITE.title}
  description={SITE.description}
  type="website"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: SITE.name,
    url: new URL(Astro.url.pathname, SITE.url).toString(),
    sameAs: Object.values(SITE.socials),
  }}
>
  <Hero />
  <HowItWorks />
  <Industries />
  <Features />
  <CTA />
</BaseLayout>

