          <button class="w-full sm:w-auto px-12 py-5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-2xl transition-all duration-300 shadow-2xl shadow-blue-500/20 hover:-translate-y-1" data-ps="src/pages/industries/materials.astro:y4h3dh">
            Request Demo Access
          </button>
          <a href="/platform/why-tieback/" class="group text-slate-900 font-bold flex items-center gap-3 transition-colors hover:text-blue-600" data-ps="src/pages/industries/materials.astro:ehtnal">
