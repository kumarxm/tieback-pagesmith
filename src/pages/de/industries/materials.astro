---,
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = "Materials & Suppliers — TieBack";
const description = "Structured upstream product data and downstream-ready handoff for suppliers supporting compliance and traceability programmes.";
,

<BaseLayout title={title} description={description}>
  <!-- 1. Industry Hero -->
  <section class="relative pt-32 pb-24 md:pt-52 md:pb-40 overflow-hidden bg-slate-950" data-ps="src/pages/industries/materials.astro:hero">
    <div class="absolute inset-0 opacity-40 transition-transform duration-1000 scale-105" data-reveal="zoom-out" data-ps="src/pages/industries/materials.astro:9uui1r">
       <img crossorigin="anonymous"
        src="https://images.unsplash.com/photo-1760328715293-6410199deca5?auto=format&w=1200&q=80"
        srcset="https://images.unsplash.com/photo-1760328715293-6410199deca5?auto=format&w=320&q=80 320w, https://images.unsplash.com/photo-1760328715293-6410199deca5?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1760328715293-6410199deca5?auto=format&w=640&q=80 640w, https://images.unsplash.com/photo-1760328715293-6410199deca5?auto=format&w=768&q=80 768w, https://images.unsplash.com/photo-1760328715293-6410199deca5?auto=format&w=1024&q=80 1024w, https://images.unsplash.com/photo-1760328715293-6410199deca5?auto=format&w=1280&q=80 1280w, https://images.unsplash.com/photo-1760328715293-6410199deca5?auto=format&w=1920&q=80 1920w"
        sizes="100vw"
        alt="Industrial materials production" class="w-full h-full object-cover" data-ps="src/pages/industries/materials.astro:7cldq3" />
       <div class="absolute inset-0 bg-gradient-to-b from-slate-950/80 via-slate-950/40 to-slate-950" data-ps="src/pages/industries/materials.astro:9uui1s"></div>
    </div>

    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/industries/materials.astro:9uui2e">
      <div class="max-w-4xl mx-auto text-center opacity-0 translate-y-8 transition-all duration-1000" data-reveal="fade-up" data-ps="src/pages/industries/materials.astro:9uui2f">
        <div class="inline-flex items-center gap-2 py-1 px-3 mb-8 text-[11px] font-bold tracking-widest text-blue-400 uppercase bg-blue-500/10 backdrop-blur-md border border-blue-500/20 rounded-full" data-ps="src/pages/industries/materials.astro:9uui2g">
          <span class="w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse" data-ps="src/pages/industries/materials.astro:ijv2zo"></span>
          B2B Industry Focus
        </div>
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight text-white mb-8 leading-[1.05]" data-ps="src/pages/industries/materials.astro:o7jkvt">
          Materials & <span class="text-blue-500" data-ps="src/pages/industries/materials.astro:yyuua5">Suppliers</span>
        </h1>
        <p class="text-xl md:text-2xl text-slate-300 mb-12 leading-relaxed max-w-2xl mx-auto" data-ps="src/pages/industries/materials.astro:lbp7bb">
          Upstream suppliers are becoming part of compliance and transparency programmes by default. TieBack provides a structured way to publish material and component information so downstream brands can assemble product passports without fragmented document chains.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-5" data-ps="src/pages/industries/materials.astro:9uui2h">
          <a href="#request-access" class="w-full sm:w-auto px-10 py-4 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl transition-all duration-300 shadow-xl shadow-blue-500/20 hover:-translate-y-1" data-ps="src/pages/industries/materials.astro:ehtnaq">
            Request Demo
          </a>
          <a href="/platform/why-tieback/" class="w-full sm:w-auto px-10 py-4 bg-white/5 backdrop-blur-md border border-white/10 text-white font-semibold rounded-xl hover:bg-white/10 transition-all duration-300" data-ps="src/pages/industries/materials.astro:ehtnap">
            Platform Overview
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. The Reality Section -->
  <section class="py-32 bg-white relative overflow-hidden" data-ps="src/pages/industries/materials.astro:u9arge">
    <div class="container mx-auto px-6" data-ps="src/pages/industries/materials.astro:9uui2i">
      <div class="grid lg:grid-cols-2 gap-20 items-center" data-ps="src/pages/industries/materials.astro:9uui2j">
        <div class="relative opacity-0 -translate-x-12 transition-all duration-1000" data-reveal="fade-right" data-ps="src/pages/industries/materials.astro:9uui2k">
          <div class="absolute -top-12 -left-12 w-24 h-24 bg-blue-100/50 rounded-full blur-2xl" data-ps="src/pages/industries/materials.astro:9uui2l"></div>
          <h2 class="text-4xl md:text-5xl font-bold text-slate-900 leading-[1.15] relative" data-ps="src/pages/industries/materials.astro:9j4no4">
            Suppliers don't just ship materials — they provide the <span class="italic font-serif text-blue-600" data-ps="src/pages/industries/materials.astro:yyuua4">data</span> that brands will rely on.
          </h2>
          <div class="mt-12 space-y-8" data-ps="src/pages/industries/materials.astro:9uui2m">
            <p class="text-lg text-slate-600 leading-relaxed" data-ps="src/pages/industries/materials.astro:lbp7ba">
              TieBack helps upstream organisations contribute structured product information that remains usable downstream, removing the friction of manual document requests.
            </p>
            <p class="text-lg text-slate-600 leading-relaxed font-medium text-slate-900" data-ps="src/pages/industries/materials.astro:lbp7b9">
              By publishing structured material records, suppliers ensure compliance readiness for their brand customers while establishing a governed, versioned history of their own assets.
            </p>
          </div>
        </div>
        <div class="relative group opacity-0 translate-x-12 transition-all duration-1000" data-reveal="fade-left" data-ps="src/pages/industries/materials.astro:9uui2n">
           <div class="absolute inset-0 bg-blue-600 rounded-[2.5rem] rotate-2 scale-95 opacity-10 group-hover:rotate-1 transition-transform duration-500" data-ps="src/pages/industries/materials.astro:9uui39"></div>
           <img crossorigin="anonymous"
            src="https://images.unsplash.com/photo-1679207751072-aa076562a4f6?auto=format&w=1200&q=80"
            srcset="https://images.unsplash.com/photo-1679207751072-aa076562a4f6?auto=format&w=320&q=80 320w, https://images.unsplash.com/photo-1679207751072-aa076562a4f6?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1679207751072-aa076562a4f6?auto=format&w=640&q=80 640w, https://images.unsplash.com/photo-1679207751072-aa076562a4f6?auto=format&w=768&q=80 768w, https://images.unsplash.com/photo-1679207751072-aa076562a4f6?auto=format&w=1024&q=80 1024w, https://images.unsplash.com/photo-1679207751072-aa076562a4f6?auto=format&w=1280&q=80 1280w, https://images.unsplash.com/photo-1679207751072-aa076562a4f6?auto=format&w=1920&q=80 1920w"
            sizes="(max-width: 768px) 100vw, 50vw"
            alt="Sustainable raw materials" class="relative z-10 w-full aspect-[4/3] object-cover rounded-[2.5rem] shadow-2xl" data-ps="src/pages/industries/materials.astro:7cldq4" />
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Why TieBack (Pillars) -->
  <section class="py-32 bg-slate-50" data-ps="src/pages/industries/materials.astro:u9argd">
    <div class="container mx-auto px-6" data-ps="src/pages/industries/materials.astro:9uui3a">
      <div class="text-center max-w-3xl mx-auto mb-20" data-ps="src/pages/industries/materials.astro:9uui3b">
        <h2 class="text-4xl font-bold text-slate-900 mb-6" data-ps="src/pages/industries/materials.astro:9j4no5">Why TieBack</h2>
        <p class="text-xl text-slate-600" data-ps="src/pages/industries/materials.astro:lbp7b8">A structured way to publish upstream product information — in a consistent format that brands can reuse at scale.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8" data-ps="src/pages/industries/materials.astro:9uui3c">
        
        <!-- Pillar 1 -->
        <div class="group bg-white p-10 rounded-[2rem] border border-slate-200 hover:border-blue-200 hover:shadow-xl hover:shadow-blue-500/5 transition-all duration-500 flex flex-col h-full opacity-0 translate-y-12 data-reveal-delay-100" data-reveal="fade-up" data-ps="src/pages/industries/materials.astro:9uui3d">
          <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center mb-8 group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300 relative" data-ps="src/pages/industries/materials.astro:9uui3e">
            <svg class="w-7 h-7 group-hover:scale-110 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
              <polyline points="3.29 7 12 12 20.71 7"/>
              <line x1="12" y1="22" x2="12" y2="12"/>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-6" data-ps="src/pages/industries/materials.astro:55a9jk">Structured data, not document chains</h3>
          
          <div class="space-y-6 flex-grow" data-ps="src/pages/industries/materials.astro:9uui3f">
            <div data-ps="src/pages/industries/materials.astro:9uui3g">
              <span class="text-blue-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/materials.astro:yyuua3">TieBack Solution</span>
              <p class="text-slate-700 leading-relaxed" data-ps="src/pages/industries/materials.astro:lbp7b7">A structured way to publish upstream product information — composition, certifications, origin attributes, and safety data — in a format that brands can reuse effortlessly.</p>
            </div>
            <div class="pt-6 border-t border-slate-100 mt-auto" data-ps="src/pages/industries/materials.astro:9uui3h">
              <span class="text-slate-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/materials.astro:yyuua2">The Gap</span>
              <p class="text-slate-600 text-sm leading-relaxed" data-ps="src/pages/industries/materials.astro:lbp7b6">Data is shared through PDFs, email threads, and spreadsheets. It's difficult to keep current, hard to validate, and painful to reuse at scale.</p>
            </div>
          </div>
        </div>

        <!-- Pillar 2 -->
        <div class="group bg-white p-10 rounded-[2rem] border border-slate-200 hover:border-blue-200 hover:shadow-xl hover:shadow-blue-500/5 transition-all duration-500 flex flex-col h-full opacity-0 translate-y-12 data-reveal-delay-300" data-reveal="fade-up" data-ps="src/pages/industries/materials.astro:9uui3i">
          <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center mb-8 group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300" data-ps="src/pages/industries/materials.astro:9uui44">
            <svg class="w-7 h-7 group-hover:animate-pulse" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 3h5v5"/>
              <path d="M8 3H3v5"/>
              <path d="M12 22v-8.3a4 4 0 0 0-1.172-2.828L3 3"/>
              <path d="m15 15.172 6 6"/>
              <path d="m12 14.3 6-6.3"/>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-6" data-ps="src/pages/industries/materials.astro:55a9jj">Downstream-ready handoff</h3>
          
          <div class="space-y-6 flex-grow" data-ps="src/pages/industries/materials.astro:9uui45">
            <div data-ps="src/pages/industries/materials.astro:9uui46">
              <span class="text-blue-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/materials.astro:yyuua1">TieBack Solution</span>
              <p class="text-slate-700 leading-relaxed" data-ps="src/pages/industries/materials.astro:lbp7b5">Supplier records can be referenced in downstream product builds, supporting traceability and reducing repeated data requests across multiple brand customers and markets.</p>
            </div>
            <div class="pt-6 border-t border-slate-100 mt-auto" data-ps="src/pages/industries/materials.astro:9uui47">
              <span class="text-slate-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/materials.astro:yyuua0">The Gap</span>
              <p class="text-slate-600 text-sm leading-relaxed" data-ps="src/pages/industries/materials.astro:lbp7b4">Every brand asks for the same information in a different format. Suppliers repeatedly repackage data, and downstream teams struggle to normalise it.</p>
            </div>
          </div>
        </div>

        <!-- Pillar 3 -->
        <div class="group bg-white p-10 rounded-[2rem] border border-slate-200 hover:border-blue-200 hover:shadow-xl hover:shadow-blue-500/5 transition-all duration-500 flex flex-col h-full opacity-0 translate-y-12 data-reveal-delay-100" data-reveal="fade-up" data-ps="src/pages/industries/materials.astro:9uui48">
          <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center mb-8 group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300" data-ps="src/pages/industries/materials.astro:9uui49">
            <svg class="w-7 h-7 group-hover:rotate-180 transition-transform duration-700 ease-in-out" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <line x1="2" y1="12" x2="22" y2="12"/>
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-6" data-ps="src/pages/industries/materials.astro:55a9ji">Market readiness without rework</h3>
          
          <div class="space-y-6 flex-grow" data-ps="src/pages/industries/materials.astro:9uui4a">
            <div data-ps="src/pages/industries/materials.astro:9uui4b">
              <span class="text-blue-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/materials.astro:yyuu9z">TieBack Solution</span>
              <p class="text-slate-700 leading-relaxed" data-ps="src/pages/industries/materials.astro:lbp7b3">Market-aware structure that supports regulated disclosures and localisation needs — helping teams prepare for compliance without reinventing the data model.</p>
            </div>
            <div class="pt-6 border-t border-slate-100 mt-auto" data-ps="src/pages/industries/materials.astro:9uui4c">
              <span class="text-slate-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/materials.astro:yyuu9y">The Gap</span>
              <p class="text-slate-600 text-sm leading-relaxed" data-ps="src/pages/industries/materials.astro:lbp7ah">Compliance preparation happens late and manually. Teams scramble to map supplier documentation into whatever system the brand is using.</p>
            </div>
          </div>
        </div>

        <!-- Pillar 4 -->
        <div class="group bg-white p-10 rounded-[2rem] border border-slate-200 hover:border-blue-200 hover:shadow-xl hover:shadow-blue-500/5 transition-all duration-500 flex flex-col h-full opacity-0 translate-y-12 data-reveal-delay-300" data-reveal="fade-up" data-ps="src/pages/industries/materials.astro:9uui4d">
          <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center mb-8 group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300" data-ps="src/pages/industries/materials.astro:9uui4z">
            <svg class="w-7 h-7 group-hover:scale-110 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              <path d="m9 12 2 2 4-4"/>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-6" data-ps="src/pages/industries/materials.astro:55a9jh">Governance, auditability, and control</h3>
          
          <div class="space-y-6 flex-grow" data-ps="src/pages/industries/materials.astro:9uui50">
            <div data-ps="src/pages/industries/materials.astro:9uui51">
              <span class="text-blue-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/materials.astro:yyuu9x">TieBack Solution</span>
              <p class="text-slate-700 leading-relaxed" data-ps="src/pages/industries/materials.astro:lbp7ag">Governed workspaces and versioned updates so suppliers can show what changed, when, and why — providing confidence for auditors and compliance teams.</p>
            </div>
            <div class="pt-6 border-t border-slate-100 mt-auto" data-ps="src/pages/industries/materials.astro:9uui52">
              <span class="text-slate-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/materials.astro:yyuu9w">The Gap</span>
              <p class="text-slate-600 text-sm leading-relaxed" data-ps="src/pages/industries/materials.astro:lbp7af">There is no reliable change history. Updates are scattered, and proof becomes a manual exercise when brands need audit-ready evidence.</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Large Visual Block -->
  <section class="py-24 bg-white" data-ps="src/pages/industries/materials.astro:u9argc">
     <div class="container mx-auto px-6" data-ps="src/pages/industries/materials.astro:9uui53">
        <div class="relative h-[600px] rounded-[3rem] overflow-hidden group shadow-2xl bg-slate-900" data-ps="src/pages/industries/materials.astro:9uui54">
           <img crossorigin="anonymous"
            src="https://images.unsplash.com/photo-1465844880937-7c02addc633b?auto=format&w=1200&q=80"
            srcset="https://images.unsplash.com/photo-1465844880937-7c02addc633b?auto=format&w=320&q=80 320w, https://images.unsplash.com/photo-1465844880937-7c02addc633b?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1465844880937-7c02addc633b?auto=format&w=640&q=80 640w, https://images.unsplash.com/photo-1465844880937-7c02addc633b?auto=format&w=768&q=80 768w, https://images.unsplash.com/photo-1465844880937-7c02addc633b?auto=format&w=1024&q=80 1024w, https://images.unsplash.com/photo-1465844880937-7c02addc633b?auto=format&w=1280&q=80 1280w, https://images.unsplash.com/photo-1465844880937-7c02addc633b?auto=format&w=1920&q=80 1920w"
            sizes="100vw"
            alt="Logistics and supply chain digital tracking" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" data-ps="src/pages/industries/materials.astro:7cldq5" />
           <div class="absolute inset-0 bg-slate-900/40 group-hover:bg-slate-900/30 transition-colors" data-ps="src/pages/industries/materials.astro:9uui55"></div>
           <div class="absolute bottom-0 left-0 p-12 md:p-20 text-white max-w-2xl" data-ps="src/pages/industries/materials.astro:9uui56">
              <h2 class="text-4xl md:text-5xl font-bold mb-6" data-ps="src/pages/industries/materials.astro:9j4no6">From upstream to handoff.</h2>
              <p class="text-lg text-slate-300 leading-relaxed" data-ps="src/pages/industries/materials.astro:lbp7ae">TieBack ensures that material records published at the source remain useful, verifiable, and connected as they move through the value chain.</p>
           </div>
        </div>
     </div>
  </section>

  <!-- Relevant Use Cases -->
  <section class="py-32 bg-slate-50 border-y border-slate-200" data-ps="src/pages/industries/materials.astro:u9argb">
    <div class="container mx-auto px-6" data-ps="src/pages/industries/materials.astro:9uui57">
      <div class="max-w-6xl mx-auto" data-ps="src/pages/industries/materials.astro:9uui58">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6" data-ps="src/pages/industries/materials.astro:we9s6k">
          <div data-ps="src/pages/industries/materials.astro:we9s6l">
            <h2 class="text-4xl font-bold text-slate-900 mb-4" data-ps="src/pages/industries/materials.astro:9j4no7">Relevant Use Cases</h2>
            <p class="text-slate-600 text-lg" data-ps="src/pages/industries/materials.astro:lbp7ad">How TieBack enables upstream visibility and downstream compliance.</p>
          </div>
          <a href="/use-cases/" class="text-blue-600 font-bold flex items-center gap-2 hover:gap-3 transition-all" data-ps="src/pages/industries/materials.astro:ehtnao">
            View All Use Cases <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
        <div class="grid md:grid-cols-3 gap-8" data-ps="src/pages/industries/materials.astro:we9s6m">
           <a href="/use-cases/suppliers-upstream-manufacturers/" class="group bg-white p-8 rounded-3xl border border-slate-200 hover:border-blue-300 hover:shadow-xl hover:shadow-blue-500/5 transition-all" data-ps="src/pages/industries/materials.astro:ehtnan">
             <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center mb-6 group-hover:bg-blue-600 group-hover:text-white transition-colors" data-ps="src/pages/industries/materials.astro:we9s6n">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
             </div>
             <h4 class="text-xl font-bold mb-3 text-slate-900" data-ps="src/pages/industries/materials.astro:jtp6rr">Upstream Suppliers</h4>
             <p class="text-slate-600 text-sm leading-relaxed" data-ps="src/pages/industries/materials.astro:lbp7ac">Enable suppliers to publish material and component data that remains usable for downstream brands.</p>
           </a>
           <a href="/use-cases/eu-dpp/" class="group bg-white p-8 rounded-3xl border border-slate-200 hover:border-blue-300 hover:shadow-xl hover:shadow-blue-500/5 transition-all" data-ps="src/pages/industries/materials.astro:ehtnam">
             <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center mb-6 group-hover:bg-blue-600 group-hover:text-white transition-colors" data-ps="src/pages/industries/materials.astro:we9s6o">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
             </div>
             <h4 class="text-xl font-bold mb-3 text-slate-900" data-ps="src/pages/industries/materials.astro:jtp6rq">Compliance Readiness</h4>
