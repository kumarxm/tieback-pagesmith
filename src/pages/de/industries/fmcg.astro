  <section id="request-access" class="py-32 bg-white relative overflow-hidden" data-ps="src/pages/industries/fmcg.astro:cloe6u">
    <script>
      const observerOptions = {
        root: null,
        rootMargin: '0px',
        threshold: 0.1
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const delay = el.getAttribute('data-reveal-delay-100') ? 100 : 
                          el.getAttribute('data-reveal-delay-300') ? 300 : 0;
            
            setTimeout(() => {
              el.classList.remove('opacity-0', 'translate-y-12', 'translate-y-8', '-translate-x-12', 'translate-x-12', 'scale-105');
              el.classList.add('opacity-100', 'translate-y-0', 'translate-x-0', 'scale-100');
            }, delay);
            
            observer.unobserve(el);
          }
        });
      }, observerOptions);

      document.querySelectorAll('[data-reveal]').forEach(el => observer.observe(el));
    </script>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_left,_var(--tw-gradient-stops))] from-blue-50/50 via-transparent to-transparent pointer-events-none" data-ps="src/pages/industries/fmcg.astro:cta-grad"></div>
