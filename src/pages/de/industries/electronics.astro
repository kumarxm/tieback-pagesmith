---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = "Electronics & Devices — TieBack";
const description = "Serialised identity, warranty and aftercare workflows, and lifecycle continuity for electronics and device brands.";
---

<BaseLayout title={title} description={description}>
  <!-- 1. Industry Hero -->
  <section class="relative pt-32 pb-24 md:pt-52 md:pb-40 overflow-hidden bg-slate-950" data-ps="src/pages/industries/electronics.astro:hero">
    <div class="absolute inset-0 opacity-40 transition-transform duration-1000 scale-105" data-reveal="zoom-out" data-ps="src/pages/industries/electronics.astro:hero-img-wrap">
       <img crossorigin="anonymous"
        src="https://images.unsplash.com/photo-1703756883533-640863c56e4e?auto=format&w=1200&q=80"
        srcset="https://images.unsplash.com/photo-1703756883533-640863c56e4e?auto=format&w=320&q=80 320w, https://images.unsplash.com/photo-1703756883533-640863c56e4e?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1703756883533-640863c56e4e?auto=format&w=640&q=80 640w, https://images.unsplash.com/photo-1703756883533-640863c56e4e?auto=format&w=768&q=80 768w, https://images.unsplash.com/photo-1703756883533-640863c56e4e?auto=format&w=1024&q=80 1024w, https://images.unsplash.com/photo-1703756883533-640863c56e4e?auto=format&w=1280&q=80 1280w, https://images.unsplash.com/photo-1703756883533-640863c56e4e?auto=format&w=1920&q=80 1920w"
        sizes="100vw"
        alt="Premium electronics" class="w-full h-full object-cover" data-ps="src/pages/industries/electronics.astro:hero-img" />
       <div class="absolute inset-0 bg-gradient-to-b from-slate-950/80 via-slate-950/40 to-slate-950" data-ps="src/pages/industries/electronics.astro:hero-overlay"></div>
    </div>

    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/industries/electronics.astro:hero-content">
      <div class="max-w-4xl mx-auto text-center opacity-0 translate-y-8 transition-all duration-1000" data-reveal="fade-up" data-ps="src/pages/industries/electronics.astro:hero-text">
        <div class="inline-flex items-center gap-2 py-1 px-3 mb-8 text-[11px] font-bold tracking-widest text-blue-400 uppercase bg-blue-500/10 backdrop-blur-md border border-blue-500/20 rounded-full" data-ps="src/pages/industries/electronics.astro:hero-tag">
          <span class="w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse" data-ps="src/pages/industries/electronics.astro:6lp6sm"></span>
          Industry Focus
        </div>
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight text-white mb-8 leading-[1.05]" data-ps="src/pages/industries/electronics.astro:hero-h1">
          Electronics & <span class="text-blue-500" data-ps="src/pages/industries/electronics.astro:6lp6sn">Devices</span>
        </h1>
        <p class="text-xl md:text-2xl text-slate-300 mb-12 leading-relaxed max-w-2xl mx-auto" data-ps="src/pages/industries/electronics.astro:hero-p">
          Electronics brands need a durable way to connect warranty, service, and lifecycle status to each device. TieBack provides a living digital identity layer so aftercare stays easy for owners, serialised identity remains consistent, and lifecycle journeys such as repair and resale keep continuity over time.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-5" data-ps="src/pages/industries/electronics.astro:hero-btns">
          <a href="#request-access" class="w-full sm:w-auto px-10 py-4 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl transition-all duration-300 shadow-xl shadow-blue-500/20 hover:-translate-y-1" data-ps="src/pages/industries/electronics.astro:7qu1ig">
            Request Access
          </a>
          <a href="/use-cases/warranty-aftercare/" class="w-full sm:w-auto px-10 py-4 bg-white/5 backdrop-blur-md border border-white/10 text-white font-semibold rounded-xl hover:bg-white/10 transition-all duration-300" data-ps="src/pages/industries/electronics.astro:7qu1ih">
            Warranty & Aftercare
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. The Landscape -->
  <section class="py-32 bg-white relative overflow-hidden" data-ps="src/pages/industries/electronics.astro:landscape">
    <div class="container mx-auto px-6" data-ps="src/pages/industries/electronics.astro:dz28d7">
      <div class="grid lg:grid-cols-2 gap-20 items-center" data-ps="src/pages/industries/electronics.astro:dz28d6">
        <div class="relative opacity-0 -translate-x-12 transition-all duration-1000" data-reveal="fade-right" data-ps="src/pages/industries/electronics.astro:dz28d5">
          <div class="absolute -top-12 -left-12 w-24 h-24 bg-blue-100/50 rounded-full blur-2xl" data-ps="src/pages/industries/electronics.astro:dz28d4"></div>
          <h2 class="text-4xl md:text-5xl font-bold text-slate-900 leading-[1.15] relative" data-ps="src/pages/industries/electronics.astro:hs97tp">
            For electronics, the product relationship <span class="italic font-serif text-blue-600" data-ps="src/pages/industries/electronics.astro:6lp6t9">continues</span> long after purchase.
          </h2>
          <div class="mt-12 space-y-8" data-ps="src/pages/industries/electronics.astro:dz28d3">
            <p class="text-lg text-slate-600 leading-relaxed" data-ps="src/pages/industries/electronics.astro:mw4ua">
              TieBack helps brands connect warranty, service, and lifecycle status to the device — in a way that stays verifiable over time.
            </p>
            <p class="text-lg text-slate-600 leading-relaxed font-medium text-slate-900" data-ps="src/pages/industries/electronics.astro:mw4ub">
              TieBack gives devices a living digital identity so warranty, service, repair guidance, and lifecycle events remain attached to the product — not scattered across receipts and support tickets.
            </p>
          </div>
        </div>
        <div class="relative group opacity-0 translate-x-12 transition-all duration-1000" data-reveal="fade-left" data-ps="src/pages/industries/electronics.astro:dz28d2">
           <div class="absolute inset-0 bg-blue-600 rounded-[2.5rem] rotate-2 scale-95 opacity-10 group-hover:rotate-1 transition-transform duration-500" data-ps="src/pages/industries/electronics.astro:dz28cg"></div>
           <img crossorigin="anonymous"
            src="https://images.unsplash.com/photo-1651964178942-ccecb82a18be?auto=format&w=1200&q=80"
            srcset="https://images.unsplash.com/photo-1651964178942-ccecb82a18be?auto=format&w=320&q=80 320w, https://images.unsplash.com/photo-1651964178942-ccecb82a18be?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1651964178942-ccecb82a18be?auto=format&w=640&q=80 640w, https://images.unsplash.com/photo-1651964178942-ccecb82a18be?auto=format&w=768&q=80 768w, https://images.unsplash.com/photo-1651964178942-ccecb82a18be?auto=format&w=1024&q=80 1024w, https://images.unsplash.com/photo-1651964178942-ccecb82a18be?auto=format&w=1280&q=80 1280w, https://images.unsplash.com/photo-1651964178942-ccecb82a18be?auto=format&w=1920&q=80 1920w"
            sizes="(max-width: 768px) 100vw, 50vw"
            alt="Circuit board technology minimal" class="relative z-10 w-full aspect-[4/3] object-cover rounded-[2.5rem] shadow-2xl" data-ps="src/pages/industries/electronics.astro:ghbcpe" />
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Core Pillars -->
  <section class="py-32 bg-slate-50" data-ps="src/pages/industries/electronics.astro:injwvr">
    <div class="container mx-auto px-6" data-ps="src/pages/industries/electronics.astro:dz28cf">
      <div class="text-center max-w-3xl mx-auto mb-20" data-ps="src/pages/industries/electronics.astro:dz28ce">
        <h2 class="text-4xl font-bold text-slate-900 mb-6" data-ps="src/pages/industries/electronics.astro:hs97tq">Why TieBack</h2>
        <p class="text-xl text-slate-600" data-ps="src/pages/industries/electronics.astro:mw4uc">TieBack runs the living system behind the device — enabling seamless aftercare, verifiable identity, and connected lifecycle journeys.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8" data-ps="src/pages/industries/electronics.astro:dz28cd">
        
        <!-- Pillar 1 -->
        <div class="group bg-white p-10 rounded-[2rem] border border-slate-200 hover:border-blue-200 hover:shadow-xl hover:shadow-blue-500/5 transition-all duration-500 flex flex-col h-full opacity-0 translate-y-12 data-reveal-delay-100" data-reveal="fade-up" data-ps="src/pages/industries/electronics.astro:dz28cc">
          <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center mb-8 group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300 relative" data-ps="src/pages/industries/electronics.astro:dz28cb">
            <svg class="w-7 h-7 group-hover:scale-110 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              <path d="m9 12 2 2 4-4"/>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-6" data-ps="src/pages/industries/electronics.astro:33ualg">Warranty & aftercare that's easy to use</h3>
          
          <div class="space-y-6 flex-grow" data-ps="src/pages/industries/electronics.astro:dz28ca">
            <div data-ps="src/pages/industries/electronics.astro:dz28c9">
              <span class="text-blue-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/electronics.astro:6lp6ta">TieBack</span>
              <p class="text-slate-700 leading-relaxed" data-ps="src/pages/industries/electronics.astro:mw4ud">A branded device passport that can support warranty activation, service requests, and product-specific guidance — reducing friction for customers and reducing validation effort for support teams.</p>
            </div>
            <div class="pt-6 border-t border-slate-100 mt-auto" data-ps="src/pages/industries/electronics.astro:dz28c8">
              <span class="text-slate-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/electronics.astro:6lp6tb">The Gap</span>
              <p class="text-slate-600 text-sm leading-relaxed" data-ps="src/pages/industries/electronics.astro:mw4ue">Warranty flows are often fragmented across emails, portals, and receipts. Support teams spend time re-validating purchase details instead of resolving issues.</p>
            </div>
          </div>
        </div>

        <!-- Pillar 2 -->
        <div class="group bg-white p-10 rounded-[2rem] border border-slate-200 hover:border-blue-200 hover:shadow-xl hover:shadow-blue-500/5 transition-all duration-500 flex flex-col h-full opacity-0 translate-y-12 data-reveal-delay-300" data-reveal="fade-up" data-ps="src/pages/industries/electronics.astro:dz28c7">
          <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center mb-8 group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300" data-ps="src/pages/industries/electronics.astro:dz28bl">
            <svg class="w-7 h-7 group-hover:animate-pulse" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="m12 14 9-5-9-5-9 5 9 5z"/>
              <path d="m12 14 9-5-9-5-9 5 9 5z"/>
              <path d="m12 14 9-5-9-5-9 5 9 5z"/>
              <path d="m12 21 9-5-9-5-9 5 9 5z"/>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-6" data-ps="src/pages/industries/electronics.astro:33uam2">Serialised identity where it matters</h3>
          
          <div class="space-y-6 flex-grow" data-ps="src/pages/industries/electronics.astro:dz28bk">
            <div data-ps="src/pages/industries/electronics.astro:dz28bj">
              <span class="text-blue-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/electronics.astro:6lp6tc">TieBack</span>
              <p class="text-slate-700 leading-relaxed" data-ps="src/pages/industries/electronics.astro:mw4uf">Support for item-level identity and lifecycle events where serialisation is important — enabling consistent resolution, controlled status visibility, and a durable product history over time.</p>
            </div>
            <div class="pt-6 border-t border-slate-100 mt-auto" data-ps="src/pages/industries/electronics.astro:dz28bi">
              <span class="text-slate-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/electronics.astro:6lp6td">The Gap</span>
              <p class="text-slate-600 text-sm leading-relaxed" data-ps="src/pages/industries/electronics.astro:mw4ug">Serial numbers exist, but they aren't connected to a consistent, consumer-facing experience. Histories are trapped in internal systems and don't travel with the device.</p>
            </div>
          </div>
        </div>

        <!-- Pillar 3 -->
        <div class="group bg-white p-10 rounded-[2rem] border border-slate-200 hover:border-blue-200 hover:shadow-xl hover:shadow-blue-500/5 transition-all duration-500 flex flex-col h-full opacity-0 translate-y-12 data-reveal-delay-100" data-reveal="fade-up" data-ps="src/pages/industries/electronics.astro:dz28bh">
          <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center mb-8 group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300" data-ps="src/pages/industries/electronics.astro:dz28bg">
            <svg class="w-7 h-7 group-hover:rotate-180 transition-transform duration-700 ease-in-out" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
              <path d="M3 3v5h5"/>
              <path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/>
              <path d="M16 16h5v5"/>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-6" data-ps="src/pages/industries/electronics.astro:33uam3">Repair, reuse, and lifecycle continuity</h3>
          
          <div class="space-y-6 flex-grow" data-ps="src/pages/industries/electronics.astro:dz28bf">
            <div data-ps="src/pages/industries/electronics.astro:dz28be">
              <span class="text-blue-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/electronics.astro:6lp6te">TieBack</span>
              <p class="text-slate-700 leading-relaxed" data-ps="src/pages/industries/electronics.astro:mw4uh">A living record that can support repairability and reuse journeys — including status updates, care guidance, and continuity for second owners when products change hands.</p>
            </div>
            <div class="pt-6 border-t border-slate-100 mt-auto" data-ps="src/pages/industries/electronics.astro:dz28bd">
              <span class="text-slate-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/electronics.astro:6lp6tf">The Gap</span>
              <p class="text-slate-600 text-sm leading-relaxed" data-ps="src/pages/industries/electronics.astro:mw4ui">Lifecycle information disappears after first sale. Second-hand buyers lack clarity on service history, warranty status, and legitimacy.</p>
            </div>
          </div>
        </div>

        <!-- Pillar 4 -->
        <div class="group bg-white p-10 rounded-[2rem] border border-slate-200 hover:border-blue-200 hover:shadow-xl hover:shadow-blue-500/5 transition-all duration-500 flex flex-col h-full opacity-0 translate-y-12 data-reveal-delay-300" data-reveal="fade-up" data-ps="src/pages/industries/electronics.astro:dz28bc">
          <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center mb-8 group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300" data-ps="src/pages/industries/electronics.astro:dz28aq">
            <svg class="w-7 h-7 group-hover:scale-110 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect width="7" height="9" x="3" y="3" rx="1"/>
              <rect width="7" height="5" x="14" y="3" rx="1"/>
              <rect width="7" height="9" x="14" y="12" rx="1"/>
              <rect width="7" height="5" x="3" y="16" rx="1"/>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-6" data-ps="src/pages/industries/electronics.astro:33uam4">Operational control for global rollout</h3>
          
          <div class="space-y-6 flex-grow" data-ps="src/pages/industries/electronics.astro:dz28ap">
            <div data-ps="src/pages/industries/electronics.astro:dz28ao">
              <span class="text-blue-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/electronics.astro:6lp6tg">TieBack</span>
              <p class="text-slate-700 leading-relaxed" data-ps="src/pages/industries/electronics.astro:mw4uj">Governed workspaces, market-aware presentation, and rollout tooling that helps teams launch consistently across regions — and keep device information current without reissuing assets.</p>
            </div>
            <div class="pt-6 border-t border-slate-100 mt-auto" data-ps="src/pages/industries/electronics.astro:dz28an">
              <span class="text-slate-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/electronics.astro:6lp6th">The Gap</span>
              <p class="text-slate-600 text-sm leading-relaxed" data-ps="src/pages/industries/electronics.astro:mw4v5">Rollouts rely on one-off integrations and manual content updates. Consistency across markets becomes expensive, slow, and difficult to audit.</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Large Visual Block -->
  <section class="py-24 bg-white" data-ps="src/pages/industries/electronics.astro:injwvq">
     <div class="container mx-auto px-6" data-ps="src/pages/industries/electronics.astro:dz28am">
        <div class="relative h-[600px] rounded-[3rem] overflow-hidden group shadow-2xl bg-slate-900" data-ps="src/pages/industries/electronics.astro:dz28al">
           <img
            src="https://images.unsplash.com/photo-1689509973807-ab5a96012115?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w4MTQzNzh8MHwxfHNlYXJjaHwzfHxlbGVjdHJvbmljJTIwdG95c3xlbnwwfHx8fDE3NzMzNDI5Mjd8MA&ixlib=rb-4.1.0&q=80&w=1200&auto=format"
            sizes="100vw"
            alt="Smartphone repair and warranty" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" data-ps="src/pages/industries/electronics.astro:ghbcpd" crossorigin="anonymous" />
           <div class="absolute inset-0 bg-slate-900/40 group-hover:bg-slate-900/30 transition-colors" data-ps="src/pages/industries/electronics.astro:dz28ak"></div>
           <div class="absolute bottom-0 left-0 p-12 md:p-20 text-white max-w-2xl" data-ps="src/pages/industries/electronics.astro:dz28aj">
              <h2 class="text-4xl md:text-5xl font-bold mb-6" data-ps="src/pages/industries/electronics.astro:hs97tr">Identity that stays with the device.</h2>
              <p class="text-lg text-slate-300 leading-relaxed" data-ps="src/pages/industries/electronics.astro:mw4v6">From warranty activation to the secondary market, TieBack ensures the product's digital record remains its most valuable attribute.</p>
           </div>
        </div>
     </div>
  </section>

  <!-- Relevant Use Cases -->
  <section class="py-32 bg-slate-50 border-y border-slate-200" data-ps="src/pages/industries/electronics.astro:injwvp">
    <div class="container mx-auto px-6" data-ps="src/pages/industries/electronics.astro:dz28ai">
      <div class="max-w-6xl mx-auto" data-ps="src/pages/industries/electronics.astro:dz28ah">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6" data-ps="src/pages/industries/electronics.astro:44qwdd">
          <div data-ps="src/pages/industries/electronics.astro:44qwde">
            <h2 class="text-4xl font-bold text-slate-900 mb-4" data-ps="src/pages/industries/electronics.astro:hs97ts">Relevant Use Cases</h2>
            <p class="text-slate-600 text-lg" data-ps="src/pages/industries/electronics.astro:mw4v7">How TieBack solves specific challenges for electronics brands.</p>
          </div>
          <a href="/use-cases/" class="text-blue-600 font-bold flex items-center gap-2 hover:gap-3 transition-all" data-ps="src/pages/industries/electronics.astro:7qu1ii">
            View All Use Cases <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
        <div class="grid md:grid-cols-3 gap-8" data-ps="src/pages/industries/electronics.astro:44qwdf">
           <a href="/use-cases/warranty-aftercare/" class="group bg-white p-8 rounded-3xl border border-slate-200 hover:border-blue-300 hover:shadow-xl hover:shadow-blue-500/5 transition-all" data-ps="src/pages/industries/electronics.astro:7qu1ij">
             <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center mb-6 group-hover:bg-blue-600 group-hover:text-white transition-colors" data-ps="src/pages/industries/electronics.astro:44qwdg">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
             </div>
             <h4 class="text-xl font-bold mb-3 text-slate-900" data-ps="src/pages/industries/electronics.astro:bkkmm7">Ownership, Warranty & Aftercare</h4>
             <p class="text-slate-600 text-sm leading-relaxed" data-ps="src/pages/industries/electronics.astro:mw4v8">Empower owners with a seamless warranty and aftercare experience tied to the device.</p>
           </a>
           <a href="/use-cases/product-as-a-channel/" class="group bg-white p-8 rounded-3xl border border-slate-200 hover:border-blue-300 hover:shadow-xl hover:shadow-blue-500/5 transition-all" data-ps="src/pages/industries/electronics.astro:7qu1ik">
             <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center mb-6 group-hover:bg-blue-600 group-hover:text-white transition-colors" data-ps="src/pages/industries/electronics.astro:44qwdh">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>
             </div>
             <h4 class="text-xl font-bold mb-3 text-slate-900" data-ps="src/pages/industries/electronics.astro:bkkmm6">Product as a Channel</h4>
             <p class="text-slate-600 text-sm leading-relaxed" data-ps="src/pages/industries/electronics.astro:mw4v9">Turn every physical device into a secure digital gateway for customers and support teams.</p>
           </a>
           <a href="/use-cases/resale-circular-economy/" class="group bg-white p-8 rounded-3xl border border-slate-200 hover:border-blue-300 hover:shadow-xl hover:shadow-blue-500/5 transition-all">
             <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center mb-6 group-hover:bg-blue-600 group-hover:text-white transition-colors" data-ps="src/pages/industries/electronics.astro:44qwdi">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
             </div>
             <h4 class="text-xl font-bold mb-3 text-slate-900" data-ps="src/pages/industries/electronics.astro:bkkmm5">Secondary Market Visibility</h4>
             <p class="text-slate-600 text-sm leading-relaxed">Maintain visibility and offer continued support across ownership transfers and secondary markets.</p>
           </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section id="request-access" class="py-32 bg-white relative overflow-hidden" data-ps="src/pages/industries/electronics.astro:injwvo">
    <script>
      const observerOptions = {
        root: null,
        rootMargin: '0px',
        threshold: 0.1
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const delay = el.getAttribute('data-reveal-delay-100') ? 100 : 
                          el.getAttribute('data-reveal-delay-300') ? 300 : 0;
            
            setTimeout(() => {
              el.classList.remove('opacity-0', 'translate-y-12', 'translate-y-8', '-translate-x-12', 'translate-x-12', 'scale-105');
              el.classList.add('opacity-100', 'translate-y-0', 'translate-x-0', 'scale-100');
            }, delay);
            
            observer.unobserve(el);
          }
        });
      }, observerOptions);

      document.querySelectorAll('[data-reveal]').forEach(el => observer.observe(el));
    </script>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_left,_var(--tw-gradient-stops))] from-blue-50/50 via-transparent to-transparent pointer-events-none" data-ps="src/pages/industries/electronics.astro:44qwdj"></div>
    <div class="container mx-auto px-6 relative z-10 text-center" data-ps="src/pages/industries/electronics.astro:44qwdk">
      <div class="max-w-4xl mx-auto" data-ps="src/pages/industries/electronics.astro:44qwdl">
        <h2 class="text-5xl md:text-6xl font-bold text-slate-900 mb-8 tracking-tight" data-ps="src/pages/industries/electronics.astro:hs97tt">Ready to build <span class="text-blue-600" data-ps="src/pages/industries/electronics.astro:6lp6ti">lifecycle continuity?</span></h2>
        <p class="text-xl text-slate-600 mb-12 max-w-2xl mx-auto leading-relaxed" data-ps="src/pages/industries/electronics.astro:mw4va">
          Join the leading electronics and device brands building their digital identity strategy on TieBack.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-6" data-ps="src/pages/industries/electronics.astro:44qwdm">
          <button class="w-full sm:w-auto px-12 py-5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-2xl transition-all duration-300 shadow-2xl shadow-blue-500/20 hover:-translate-y-1" data-ps="src/pages/industries/electronics.astro:m3r65b">
            Request Early Access
          </button>
          <a href="/platform/why-tieback/" class="group text-slate-900 font-bold flex items-center gap-3 transition-colors hover:text-blue-600" data-ps="src/pages/industries/electronics.astro:7qu1il">
            Why TieBack <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
,---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = "Electronics & Devices — TieBack";
const description = "Serialised identity, warranty and aftercare workflows, and lifecycle continuity for electronics and device brands.";
---
,<BaseLayout title={title} description={description}>
  <!-- 1. Industry Hero -->
  <section class="relative pt-32 pb-24 md:pt-52 md:pb-40 overflow-hidden bg-slate-950" data-ps="src/pages/industries/electronics.astro:hero">
    <div class="absolute inset-0 opacity-40 transition-transform duration-1000 scale-105" data-reveal="zoom-out" data-ps="src/pages/industries/electronics.astro:hero-img-wrap">
       <img crossorigin="anonymous"
        src="https://images.unsplash.com/photo-1703756883533-640863c56e4e?auto=format&w=1200&q=80"
        srcset="https://images.unsplash.com/photo-1703756883533-640863c56e4e?auto=format&w=320&q=80 320w, https://images.unsplash.com/photo-1703756883533-640863c56e4e?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1703756883533-640863c56e4e?auto=format&w=640&q=80 640w, https://images.unsplash.com/photo-1703756883533-640863c56e4e?auto=format&w=768&q=80 768w, https://images.unsplash.com/photo-1703756883533-640863c56e4e?auto=format&w=1024&q=80 1024w, https://images.unsplash.com/photo-1703756883533-640863c56e4e?auto=format&w=1280&q=80 1280w, https://images.unsplash.com/photo-1703756883533-640863c56e4e?auto=format&w=1920&q=80 1920w"
        sizes="100vw"
        alt="Premium electronics" class="w-full h-full object-cover" data-ps="src/pages/industries/electronics.astro:hero-img" />
       <div class="absolute inset-0 bg-gradient-to-b from-slate-950/80 via-slate-950/40 to-slate-950" data-ps="src/pages/industries/electronics.astro:hero-overlay"></div>
    </div>

    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/industries/electronics.astro:hero-content">
      <div class="max-w-4xl mx-auto text-center opacity-0 translate-y-8 transition-all duration-1000" data-reveal="fade-up" data-ps="src/pages/industries/electronics.astro:hero-text">
        <div class="inline-flex items-center gap-2 py-1 px-3 mb-8 text-[11px] font-bold tracking-widest text-blue-400 uppercase bg-blue-500/10 backdrop-blur-md border border-blue-500/20 rounded-full" data-ps="src/pages/industries/electronics.astro:hero-tag">
          <span class="w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse" data-ps="src/pages/industries/electronics.astro:6lp6sm"></span>
          Industry Focus
        </div>
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight text-white mb-8 leading-[1.05]" data-ps="src/pages/industries/electronics.astro:hero-h1">
          Electronics & <span class="text-blue-500" data-ps="src/pages/industries/electronics.astro:6lp6sn">Devices</span>
        </h1>
        <p class="text-xl md:text-2xl text-slate-300 mb-12 leading-relaxed max-w-2xl mx-auto" data-ps="src/pages/industries/electronics.astro:hero-p">
          Electronics brands need a durable way to connect warranty, service, and lifecycle status to each device. TieBack provides a living digital identity layer so aftercare stays easy for owners, serialised identity remains consistent, and lifecycle journeys such as repair and resale keep continuity over time.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-5" data-ps="src/pages/industries/electronics.astro:hero-btns">
          <a href="#request-access" class="w-full sm:w-auto px-10 py-4 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl transition-all duration-300 shadow-xl shadow-blue-500/20 hover:-translate-y-1" data-ps="src/pages/industries/electronics.astro:7qu1ig">
            Request Access
          </a>
          <a href="/use-cases/warranty-aftercare/" class="w-full sm:w-auto px-10 py-4 bg-white/5 backdrop-blur-md border border-white/10 text-white font-semibold rounded-xl hover:bg-white/10 transition-all duration-300" data-ps="src/pages/industries/electronics.astro:7qu1ih">
            Warranty & Aftercare
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. The Landscape -->
  <section class="py-32 bg-white relative overflow-hidden" data-ps="src/pages/industries/electronics.astro:landscape">
    <div class="container mx-auto px-6" data-ps="src/pages/industries/electronics.astro:dz28d7">
      <div class="grid lg:grid-cols-2 gap-20 items-center" data-ps="src/pages/industries/electronics.astro:dz28d6">
        <div class="relative opacity-0 -translate-x-12 transition-all duration-1000" data-reveal="fade-right" data-ps="src/pages/industries/electronics.astro:dz28d5">
          <div class="absolute -top-12 -left-12 w-24 h-24 bg-blue-100/50 rounded-full blur-2xl" data-ps="src/pages/industries/electronics.astro:dz28d4"></div>
          <h2 class="text-4xl md:text-5xl font-bold text-slate-900 leading-[1.15] relative" data-ps="src/pages/industries/electronics.astro:hs97tp">
            For electronics, the product relationship <span class="italic font-serif text-blue-600" data-ps="src/pages/industries/electronics.astro:6lp6t9">continues</span> long after purchase.
          </h2>
          <div class="mt-12 space-y-8" data-ps="src/pages/industries/electronics.astro:dz28d3">
            <p class="text-lg text-slate-600 leading-relaxed" data-ps="src/pages/industries/electronics.astro:mw4ua">
              TieBack helps brands connect warranty, service, and lifecycle status to the device — in a way that stays verifiable over time.
            </p>
            <p class="text-lg text-slate-600 leading-relaxed font-medium text-slate-900" data-ps="src/pages/industries/electronics.astro:mw4ub">
              TieBack gives devices a living digital identity so warranty, service, repair guidance, and lifecycle events remain attached to the product — not scattered across receipts and support tickets.
            </p>
          </div>
        </div>
        <div class="relative group opacity-0 translate-x-12 transition-all duration-1000" data-reveal="fade-left" data-ps="src/pages/industries/electronics.astro:dz28d2">
           <div class="absolute inset-0 bg-blue-600 rounded-[2.5rem] rotate-2 scale-95 opacity-10 group-hover:rotate-1 transition-transform duration-500" data-ps="src/pages/industries/electronics.astro:dz28cg"></div>
           <img crossorigin="anonymous"
            src="https://images.unsplash.com/photo-1651964178942-ccecb82a18be?auto=format&w=1200&q=80"
            srcset="https://images.unsplash.com/photo-1651964178942-ccecb82a18be?auto=format&w=320&q=80 320w, https://images.unsplash.com/photo-1651964178942-ccecb82a18be?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1651964178942-ccecb82a18be?auto=format&w=640&q=80 640w, https://images.unsplash.com/photo-1651964178942-ccecb82a18be?auto=format&w=768&q=80 768w, https://images.unsplash.com/photo-1651964178942-ccecb82a18be?auto=format&w=1024&q=80 1024w, https://images.unsplash.com/photo-1651964178942-ccecb82a18be?auto=format&w=1280&q=80 1280w, https://images.unsplash.com/photo-1651964178942-ccecb82a18be?auto=format&w=1920&q=80 1920w"
            sizes="(max-width: 768px) 100vw, 50vw"
            alt="Circuit board technology minimal" class="relative z-10 w-full aspect-[4/3] object-cover rounded-[2.5rem] shadow-2xl" data-ps="src/pages/industries/electronics.astro:ghbcpe" />
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Core Pillars -->
  <section class="py-32 bg-slate-50" data-ps="src/pages/industries/electronics.astro:injwvr">
    <div class="container mx-auto px-6" data-ps="src/pages/industries/electronics.astro:dz28cf">
      <div class="text-center max-w-3xl mx-auto mb-20" data-ps="src/pages/industries/electronics.astro:dz28ce">
        <h2 class="text-4xl font-bold text-slate-900 mb-6" data-ps="src/pages/industries/electronics.astro:hs97tq">Why TieBack</h2>
        <p class="text-xl text-slate-600" data-ps="src/pages/industries/electronics.astro:mw4uc">TieBack runs the living system behind the device — enabling seamless aftercare, verifiable identity, and connected lifecycle journeys.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8" data-ps="src/pages/industries/electronics.astro:dz28cd">
        
        <!-- Pillar 1 -->
        <div class="group bg-white p-10 rounded-[2rem] border border-slate-200 hover:border-blue-200 hover:shadow-xl hover:shadow-blue-500/5 transition-all duration-500 flex flex-col h-full opacity-0 translate-y-12 data-reveal-delay-100" data-reveal="fade-up" data-ps="src/pages/industries/electronics.astro:dz28cc">
          <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center mb-8 group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300 relative" data-ps="src/pages/industries/electronics.astro:dz28cb">
            <svg class="w-7 h-7 group-hover:scale-110 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              <path d="m9 12 2 2 4-4"/>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-6" data-ps="src/pages/industries/electronics.astro:33ualg">Warranty & aftercare that's easy to use</h3>
          
          <div class="space-y-6 flex-grow" data-ps="src/pages/industries/electronics.astro:dz28ca">
            <div data-ps="src/pages/industries/electronics.astro:dz28c9">
              <span class="text-blue-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/electronics.astro:6lp6ta">TieBack</span>
              <p class="text-slate-700 leading-relaxed" data-ps="src/pages/industries/electronics.astro:mw4ud">A branded device passport that can support warranty activation, service requests, and product-specific guidance — reducing friction for customers and reducing validation effort for support teams.</p>
            </div>
            <div class="pt-6 border-t border-slate-100 mt-auto" data-ps="src/pages/industries/electronics.astro:dz28c8">
              <span class="text-slate-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/electronics.astro:6lp6tb">The Gap</span>
              <p class="text-slate-600 text-sm leading-relaxed" data-ps="src/pages/industries/electronics.astro:mw4ue">Warranty flows are often fragmented across emails, portals, and receipts. Support teams spend time re-validating purchase details instead of resolving issues.</p>
            </div>
          </div>
        </div>

        <!-- Pillar 2 -->
        <div class="group bg-white p-10 rounded-[2rem] border border-slate-200 hover:border-blue-200 hover:shadow-xl hover:shadow-blue-500/5 transition-all duration-500 flex flex-col h-full opacity-0 translate-y-12 data-reveal-delay-300" data-reveal="fade-up" data-ps="src/pages/industries/electronics.astro:dz28c7">
          <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center mb-8 group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300" data-ps="src/pages/industries/electronics.astro:dz28bl">
            <svg class="w-7 h-7 group-hover:animate-pulse" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="m12 14 9-5-9-5-9 5 9 5z"/>
              <path d="m12 14 9-5-9-5-9 5 9 5z"/>
              <path d="m12 14 9-5-9-5-9 5 9 5z"/>
              <path d="m12 21 9-5-9-5-9 5 9 5z"/>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-6" data-ps="src/pages/industries/electronics.astro:33uam2">Serialised identity where it matters</h3>
          
          <div class="space-y-6 flex-grow" data-ps="src/pages/industries/electronics.astro:dz28bk">
            <div data-ps="src/pages/industries/electronics.astro:dz28bj">
              <span class="text-blue-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/electronics.astro:6lp6tc">TieBack</span>
              <p class="text-slate-700 leading-relaxed" data-ps="src/pages/industries/electronics.astro:mw4uf">Support for item-level identity and lifecycle events where serialisation is important — enabling consistent resolution, controlled status visibility, and a durable product history over time.</p>
            </div>
            <div class="pt-6 border-t border-slate-100 mt-auto" data-ps="src/pages/industries/electronics.astro:dz28bi">
              <span class="text-slate-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/electronics.astro:6lp6td">The Gap</span>
              <p class="text-slate-600 text-sm leading-relaxed" data-ps="src/pages/industries/electronics.astro:mw4ug">Serial numbers exist, but they aren't connected to a consistent, consumer-facing experience. Histories are trapped in internal systems and don't travel with the device.</p>
            </div>
          </div>
        </div>

        <!-- Pillar 3 -->
        <div class="group bg-white p-10 rounded-[2rem] border border-slate-200 hover:border-blue-200 hover:shadow-xl hover:shadow-blue-500/5 transition-all duration-500 flex flex-col h-full opacity-0 translate-y-12 data-reveal-delay-100" data-reveal="fade-up" data-ps="src/pages/industries/electronics.astro:dz28bh">
          <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center mb-8 group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300" data-ps="src/pages/industries/electronics.astro:dz28bg">
            <svg class="w-7 h-7 group-hover:rotate-180 transition-transform duration-700 ease-in-out" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
              <path d="M3 3v5h5"/>
              <path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/>
              <path d="M16 16h5v5"/>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-6" data-ps="src/pages/industries/electronics.astro:33uam3">Repair, reuse, and lifecycle continuity</h3>
          
          <div class="space-y-6 flex-grow" data-ps="src/pages/industries/electronics.astro:dz28bf">
            <div data-ps="src/pages/industries/electronics.astro:dz28be">
              <span class="text-blue-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/electronics.astro:6lp6te">TieBack</span>
              <p class="text-slate-700 leading-relaxed" data-ps="src/pages/industries/electronics.astro:mw4uh">A living record that can support repairability and reuse journeys — including status updates, care guidance, and continuity for second owners when products change hands.</p>
            </div>
            <div class="pt-6 border-t border-slate-100 mt-auto" data-ps="src/pages/industries/electronics.astro:dz28bd">
              <span class="text-slate-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/electronics.astro:6lp6tf">The Gap</span>
              <p class="text-slate-600 text-sm leading-relaxed" data-ps="src/pages/industries/electronics.astro:mw4ui">Lifecycle information disappears after first sale. Second-hand buyers lack clarity on service history, warranty status, and legitimacy.</p>
            </div>
          </div>
        </div>

        <!-- Pillar 4 -->
        <div class="group bg-white p-10 rounded-[2rem] border border-slate-200 hover:border-blue-200 hover:shadow-xl hover:shadow-blue-500/5 transition-all duration-500 flex flex-col h-full opacity-0 translate-y-12 data-reveal-delay-300" data-reveal="fade-up" data-ps="src/pages/industries/electronics.astro:dz28bc">
          <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center mb-8 group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300" data-ps="src/pages/industries/electronics.astro:dz28aq">
            <svg class="w-7 h-7 group-hover:scale-110 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect width="7" height="9" x="3" y="3" rx="1"/>
              <rect width="7" height="5" x="14" y="3" rx="1"/>
              <rect width="7" height="9" x="14" y="12" rx="1"/>
              <rect width="7" height="5" x="3" y="16" rx="1"/>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-6" data-ps="src/pages/industries/electronics.astro:33uam4">Operational control for global rollout</h3>
          
          <div class="space-y-6 flex-grow" data-ps="src/pages/industries/electronics.astro:dz28ap">
            <div data-ps="src/pages/industries/electronics.astro:dz28ao">
              <span class="text-blue-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/electronics.astro:6lp6tg">TieBack</span>
              <p class="text-slate-700 leading-relaxed" data-ps="src/pages/industries/electronics.astro:mw4uj">Governed workspaces, market-aware presentation, and rollout tooling that helps teams launch consistently across regions — and keep device information current without reissuing assets.</p>
            </div>
            <div class="pt-6 border-t border-slate-100 mt-auto" data-ps="src/pages/industries/electronics.astro:dz28an">
              <span class="text-slate-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/electronics.astro:6lp6th">The Gap</span>
              <p class="text-slate-600 text-sm leading-relaxed" data-ps="src/pages/industries/electronics.astro:mw4v5">Rollouts rely on one-off integrations and manual content updates. Consistency across markets becomes expensive, slow, and difficult to audit.</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Large Visual Block -->
  <section class="py-24 bg-white" data-ps="src/pages/industries/electronics.astro:injwvq">
     <div class="container mx-auto px-6" data-ps="src/pages/industries/electronics.astro:dz28am">
        <div class="relative h-[600px] rounded-[3rem] overflow-hidden group shadow-2xl bg-slate-900" data-ps="src/pages/industries/electronics.astro:dz28al">
           <img
            src="https://images.unsplash.com/photo-1689509973807-ab5a96012115?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w4MTQzNzh8MHwxfHNlYXJjaHwzfHxlbGVjdHJvbmljJTIwdG95c3xlbnwwfHx8fDE3NzMzNDI5Mjd8MA&ixlib=rb-4.1.0&q=80&w=1200&auto=format"
            sizes="100vw"
            alt="Smartphone repair and warranty" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" data-ps="src/pages/industries/electronics.astro:ghbcpd" crossorigin="anonymous" />
           <div class="absolute inset-0 bg-slate-900/40 group-hover:bg-slate-900/30 transition-colors" data-ps="src/pages/industries/electronics.astro:dz28ak"></div>
           <div class="absolute bottom-0 left-0 p-12 md:p-20 text-white max-w-2xl" data-ps="src/pages/industries/electronics.astro:dz28aj">
              <h2 class="text-4xl md:text-5xl font-bold mb-6" data-ps="src/pages/industries/electronics.astro:hs97tr">Identity that stays with the device.</h2>
              <p class="text-lg text-slate-300 leading-relaxed" data-ps="src/pages/industries/electronics.astro:mw4v6">From warranty activation to the secondary market, TieBack ensures the product's digital record remains its most valuable attribute.</p>
           </div>
        </div>
     </div>
  </section>

  <!-- Relevant Use Cases -->
  <section class="py-32 bg-slate-50 border-y border-slate-200" data-ps="src/pages/industries/electronics.astro:injwvp">
    <div class="container mx-auto px-6" data-ps="src/pages/industries/electronics.astro:dz28ai">
      <div class="max-w-6xl mx-auto" data-ps="src/pages/industries/electronics.astro:dz28ah">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6" data-ps="src/pages/industries/electronics.astro:44qwdd">
