---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/config/site';

const title = "Textiles, Apparel & Footwear — TieBack";
const description = "Product identity, compliance readiness, and resale continuity for textiles and apparel.";
---






<BaseLayout title={title} description={description}>
  <!-- 1. Industry Hero -->
  <section class="relative pt-32 pb-24 md:pt-52 md:pb-40 overflow-hidden bg-slate-950" data-ps="src/pages/industries/textiles.astro:cloe6q">
    <div class="absolute inset-0 opacity-40 transition-transform duration-1000 scale-105" data-reveal="zoom-out" data-ps="src/pages/industries/textiles.astro:hero-img-wrap">
       <img crossorigin="anonymous"
        src="https://images.unsplash.com/photo-1768102366381-c615ef9d12c9?auto=format&w=1200&q=80"
        srcset="https://images.unsplash.com/photo-1684259499086-93cb3e555803?auto=format&w=320&q=80 320w, https://images.unsplash.com/photo-1684259499086-93cb3e555803?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1684259499086-93cb3e555803?auto=format&w=640&q=80 640w, https://images.unsplash.com/photo-1684259499086-93cb3e555803?auto=format&w=768&q=80 768w, https://images.unsplash.com/photo-1684259499086-93cb3e555803?auto=format&w=1024&q=80 1024w, https://images.unsplash.com/photo-1684259499086-93cb3e555803?auto=format&w=1280&q=80 1280w, https://images.unsplash.com/photo-1684259499086-93cb3e555803?auto=format&w=1920&q=80 1920w"
        sizes="100vw"
        alt="High-end textile factory" class="w-full h-full object-cover" data-ps="src/pages/industries/textiles.astro:hero-img" />
       <div class="absolute inset-0 bg-gradient-to-b from-slate-950/80 via-slate-950/40 to-slate-950" data-ps="src/pages/industries/textiles.astro:hero-overlay"></div>
    </div>
</section></BaseLayout>


    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/industries/textiles.astro:6g628h">
      <div class="max-w-4xl mx-auto text-center opacity-0 translate-y-8 transition-all duration-1000" data-reveal="fade-up" data-ps="src/pages/industries/textiles.astro:6g627v">
        <div class="inline-flex items-center gap-2 py-1 px-3 mb-8 text-[11px] font-bold tracking-widest text-blue-400 uppercase bg-blue-500/10 backdrop-blur-md border border-blue-500/20 rounded-full" data-ps="src/pages/industries/textiles.astro:771h9b">
          <span class="w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse" data-ps="src/pages/industries/textiles.astro:9eb0t6"></span>
          Branchenfokus
        </div>
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight text-white mb-8 leading-[1.05]" data-ps="src/pages/industries/textiles.astro:jg65d">
        
          Textilien, Bekleidung <span class="text-blue-500" data-ps="src/pages/industries/textiles.astro:9eb0t5">und Schuhe</span>
        </h1>
        <p class="text-xl md:text-2xl text-slate-300 mb-12 leading-relaxed max-w-2xl mx-auto" data-ps="src/pages/industries/textiles.astro:8k945v">
          Nachhaltige Produktdaten für eine zirkuläre Zukunft. Verwalten Sie digitale Produktpässe, Transparenz und den Wiederverkauf mit einer dynamischen Identitätsschicht.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-5" data-ps="src/pages/industries/textiles.astro:6g627u">
          <a href="#request-access" class="w-full sm:w-auto px-10 py-4 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl transition-all duration-300 shadow-xl shadow-blue-500/20 hover:-translate-y-1" data-ps="src/pages/industries/textiles.astro:1gb7hr">
            Zugriff anfordern
          </a>
          
          <a href="/use-cases/compliance-readiness/" class="w-full sm:w-auto px-10 py-4 bg-white/5 backdrop-blur-md border border-white/10 text-white font-semibold rounded-xl hover:bg-white/10 transition-all duration-300" data-ps="src/pages/industries/textiles.astro:1gb7hq">
            Compliance-Bereitschaft
          </a>
        </div>
      </div>
    </div>
  



  <!-- 2. The Landscape -->
  <section class="py-32 bg-white relative overflow-hidden" data-ps="src/pages/industries/textiles.astro:cloe6r">
    <div class="container mx-auto px-6" data-ps="src/pages/industries/textiles.astro:6g627t">
      <div class="grid lg:grid-cols-2 gap-20 items-center" data-ps="src/pages/industries/textiles.astro:6g627s">
        <div class="relative opacity-0 -translate-x-12 transition-all duration-1000" data-reveal="fade-right" data-ps="src/pages/industries/textiles.astro:6g627r">
          <div class="absolute -top-12 -left-12 w-24 h-24 bg-blue-100/50 rounded-full blur-2xl" data-ps="src/pages/industries/textiles.astro:accent-3"></div>
          <h2 class="text-4xl md:text-5xl font-bold text-slate-900 leading-[1.15] relative" data-ps="src/pages/industries/textiles.astro:e4yr2w">
            Im Textilbereich geht der Trend zu <span class="italic font-serif text-blue-600" data-ps="src/pages/industries/textiles.astro:9eb0t4">dauerhaften</span> Aufzeichnungen.
          </h2>
          <div class="mt-12 space-y-8" data-ps="src/pages/industries/textiles.astro:landscape-text">
            <p class="text-lg text-slate-600 leading-relaxed" data-ps="src/pages/industries/textiles.astro:landscape-p1">
              Angetrieben durch Programme für digitale Produktpässe, Erwartungen an Materialtransparenz und das Wachstum des Wiederverkaufs benötigt die Branche eine dynamische digitale Identitätsschicht.
            </p>
            <p class="text-lg text-slate-600 leading-relaxed font-medium text-slate-900" data-ps="src/pages/industries/textiles.astro:landscape-p2">
              TieBack
              bietet die Infrastruktur, damit Produktinformationen strukturiert, aktualisierbar und über Märkte und den gesamten Produktlebenszyklus hinweg nutzbar bleiben.
            </p>
          </div>
        </div>
        <div class="relative group opacity-0 translate-x-12 transition-all duration-1000" data-reveal="fade-left" data-ps="src/pages/industries/textiles.astro:6g627q">
           <div class="absolute inset-0 bg-blue-600 rounded-[2.5rem] rotate-2 scale-95 opacity-10 group-hover:rotate-1 transition-transform duration-500" data-ps="src/pages/industries/textiles.astro:img-accent"></div>
           <img
            src="https://images.unsplash.com/photo-1534126511673-b6899657816a?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w4MTQzNzh8MHwxfHNlYXJjaHwxOXx8dGV4dGlsZSUyMGZhY3Rvcnl8ZW58MHx8fHwxNzczMzM5MDQ5fDA&ixlib=rb-4.1.0&q=80&w=1200&auto=format"
            sizes="(max-width: 768px) 100vw, 50vw"
            alt="Smart textile technology" class="relative z-10 w-full aspect-[4/3] object-cover rounded-[2.5rem] shadow-2xl" data-ps="src/pages/industries/textiles.astro:landscape-img" crossorigin="anonymous" />
        </div>
      </div>
    </div>
  </section>



  <!-- 3. Core Pillars (Modern Grid) -->
  <section class="py-32 bg-slate-50" data-ps="src/pages/industries/textiles.astro:cloe6s">
    <style>
      @keyframes draw {
        to { stroke-dashoffset: 0; }
      }
      .animate-draw path {
        stroke-dasharray: 100;
        stroke-dashoffset: 100;
      }
      .group:hover .animate-draw path {
        animation: draw 1.5s ease forwards;
      }
      @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-5px); }
      }
      .animate-float {
        animation: float 3s ease-in-out infinite;
      }
      @keyframes spin-slow {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
      }
      .animate-spin-slow {
        animation: spin-slow 8s linear infinite;
      }
    </style>
    <div class="container mx-auto px-6" data-ps="src/pages/industries/textiles.astro:6g627o">
      <div class="text-center max-w-3xl mx-auto mb-20" data-ps="src/pages/industries/textiles.astro:pillar-header">
        <h2 class="text-4xl font-bold text-slate-900 mb-6" data-ps="src/pages/industries/textiles.astro:pillar-title">Warum TieBack</h2>
        <p class="text-xl text-slate-600" data-ps="src/pages/industries/textiles.astro:pillar-desc">TieBack betreibt das lebende System hinter dem Pass – Identität, Vertrauenssignale und Lebenszyklus-Kontinuität –, damit Marken konform und vernetzt bleiben können.</p>
      </div>
</div></section>


      <div class="grid grid-cols-1 md:grid-cols-2 gap-8" data-ps="src/pages/industries/textiles.astro:6g627m">
        
        <!-- Pillar 1: Compliance (Document/Verify) -->
        <div class="group bg-white p-10 rounded-[2rem] border border-slate-200 hover:border-blue-200 hover:shadow-xl hover:shadow-blue-500/5 transition-all duration-500 flex flex-col h-full opacity-0 translate-y-12 data-reveal-delay-100" data-reveal="fade-up" data-ps="src/pages/industries/textiles.astro:pillar-1">
          <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center mb-8 group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300 relative" data-ps="src/pages/industries/textiles.astro:pillar-icon-1">
            <svg class="w-7 h-7 group-hover:scale-110 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/>
              <path d="m9 12 2 2 4-4"/>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-6" data-ps="src/pages/industries/textiles.astro:stdoaj">Stets aktuelle Compliance</h3>
          
          <div class="space-y-6 flex-grow" data-ps="src/pages/industries/textiles.astro:pillar-content-1">
            <div data-ps="src/pages/industries/textiles.astro:tieback-part-1">
              <span class="text-blue-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/textiles.astro:lbl-1">TieBack</span>
              <p class="text-slate-700 leading-relaxed" data-ps="src/pages/industries/textiles.astro:txt-1">Strukturierte Produktinformationen – Materialien, Zusammensetzung, Pflegehinweise und Recycling-Anleitungen – versioniert und aktualisierbar, ohne dass Identifikatoren neu vergeben werden müssen.</p>
            </div>
            <div class="pt-6 border-t border-slate-100 mt-auto" data-ps="src/pages/industries/textiles.astro:gap-part-1">
              <span class="text-slate-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/textiles.astro:lbl-gap-1">Die Lücke</span>
              <p class="text-slate-600 text-sm leading-relaxed" data-ps="src/pages/industries/textiles.astro:txt-gap-1">Compliance-Inhalte werden oft zu einer statischen Seite oder einem PDF-Snapshot. Aktualisierungen erfolgen manuell, sind uneinheitlich und schwer zu überprüfen.</p>
            </div>
          </div>
        </div>
</div>


        <!-- Pillar 2: Trust (Secure ID) -->
        <div class="group bg-white p-10 rounded-[2rem] border border-slate-200 hover:border-blue-200 hover:shadow-xl hover:shadow-blue-500/5 transition-all duration-500 flex flex-col h-full opacity-0 translate-y-12 data-reveal-delay-300" data-reveal="fade-up" data-ps="src/pages/industries/textiles.astro:pillar-2">
          <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center mb-8 group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300" data-ps="src/pages/industries/textiles.astro:pillar-icon-2">
            <svg class="w-7 h-7 group-hover:animate-pulse" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              <path d="m9 12 2 2 4-4"/>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-6" data-ps="src/pages/industries/textiles.astro:stdoai">Vertrauen ohne Reibungsverluste</h3>
          
          <div class="space-y-6 flex-grow" data-ps="src/pages/industries/textiles.astro:pillar-content-2">
            <div data-ps="src/pages/industries/textiles.astro:tieback-part-2">
              <span class="text-blue-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/textiles.astro:lbl-2">TieBack</span>
              <p class="text-slate-700 leading-relaxed" data-ps="src/pages/industries/textiles.astro:txt-2">Ein reibungsloser Scan-Prozess mit messbaren Vertrauenssignalen. Für risikoreiche Produktlinien bietet „TieBack“ eine höhere Sicherheit (NFC-Kopplung) ohne zusätzlichen Aufwand.</p>
            </div>
            <div class="pt-6 border-t border-slate-100 mt-auto" data-ps="src/pages/industries/textiles.astro:gap-part-2">
              <span class="text-slate-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/textiles.astro:lbl-gap-2">Die Lücke</span>
              <p class="text-slate-600 text-sm leading-relaxed" data-ps="src/pages/industries/textiles.astro:txt-gap-2">Die Verifizierung ist oft binär und anfällig. Sie erkennt selten verdächtige Wiederverwendung oder unterstützt stärkere Nachweise, ohne den Betrieb zu erschweren.</p>
            </div>
          </div>
        </div>



        <!-- Pillar 3: Resale (Refresh/Circular) -->
        <div class="group bg-white p-10 rounded-[2rem] border border-slate-200 hover:border-blue-200 hover:shadow-xl hover:shadow-blue-500/5 transition-all duration-500 flex flex-col h-full opacity-0 translate-y-12 data-reveal-delay-100" data-reveal="fade-up" data-ps="src/pages/industries/textiles.astro:pillar-3">
          <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center mb-8 group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300" data-ps="src/pages/industries/textiles.astro:pillar-icon-3">
            <svg class="w-7 h-7 group-hover:rotate-180 transition-transform duration-700 ease-in-out" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
              <path d="M3 3v5h5"/>
              <path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/>
              <path d="M16 16h5v5"/>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-6" data-ps="src/pages/industries/textiles.astro:stdoah">Weiterverkauf & Kreislaufwirtschaft</h3>
          
          <div class="space-y-6 flex-grow" data-ps="src/pages/industries/textiles.astro:pillar-content-3">
            <div data-ps="src/pages/industries/textiles.astro:tieback-part-3">
              <span class="text-blue-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/textiles.astro:lbl-3">TieBack</span>
              <p class="text-slate-700 leading-relaxed" data-ps="src/pages/industries/textiles.astro:txt-3">Workflows für Eigentumsansprüche und -übertragungen, die den Produktkontext über den Erstverkauf hinaus erhalten. Pflegehinweise bewahren und den Produktstatus über die Zeit hinweg aufrechterhalten.</p>
            </div>
            <div class="pt-6 border-t border-slate-100 mt-auto" data-ps="src/pages/industries/textiles.astro:gap-part-3">
              <span class="text-slate-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/textiles.astro:lbl-gap-3">Die Lücke</span>
              <p class="text-slate-600 text-sm leading-relaxed" data-ps="src/pages/industries/textiles.astro:txt-gap-3">Käufer im Wiederverkauf bleiben unsichtbar. Produktinformationen verlieren an Kontinuität, und Marken verpassen die Gelegenheit, den Kreislaufwert zu fördern.</p>
            </div>
          </div>
        </div>



        <!-- Pillar 4: Rollout (Supply Chain/Nodes) -->
        <div class="group bg-white p-10 rounded-[2rem] border border-slate-200 hover:border-blue-200 hover:shadow-xl hover:shadow-blue-500/5 transition-all duration-500 flex flex-col h-full opacity-0 translate-y-12 data-reveal-delay-300" data-reveal="fade-up" data-ps="src/pages/industries/textiles.astro:pillar-4">
          <div class="w-14 h-14 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center mb-8 group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300" data-ps="src/pages/industries/textiles.astro:pillar-icon-4">
            <svg class="w-7 h-7 group-hover:scale-110 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect width="7" height="9" x="3" y="3" rx="1"/>
              <rect width="7" height="5" x="14" y="3" rx="1"/>
              <rect width="7" height="9" x="14" y="12" rx="1"/>
              <rect width="7" height="5" x="3" y="16" rx="1"/>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-6" data-ps="src/pages/industries/textiles.astro:stdoag">Einführung in den gesamten Lieferketten</h3>
          
          <div class="space-y-6 flex-grow" data-ps="src/pages/industries/textiles.astro:pillar-content-4">
            <div data-ps="src/pages/industries/textiles.astro:tieback-part-4">
              <span class="text-blue-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/textiles.astro:lbl-4">TieBack</span>
              <p class="text-slate-700 leading-relaxed" data-ps="src/pages/industries/textiles.astro:txt-4">Kontrollierte Marken-Arbeitsbereiche und Wege für Lieferantenbeiträge, die eine regionenübergreifende Einführung ermöglichen, ohne das System Markt für Markt neu aufbauen zu müssen.</p>
            </div>
            <div class="pt-6 border-t border-slate-100 mt-auto" data-ps="src/pages/industries/textiles.astro:gap-part-4">
              <span class="text-slate-600 font-bold text-xs uppercase tracking-widest block mb-2" data-ps="src/pages/industries/textiles.astro:lbl-gap-4">Die Lücke</span>
              <p class="text-slate-600 text-sm leading-relaxed" data-ps="src/pages/industries/textiles.astro:txt-gap-4">Skalierung führt zu Inkonsistenzen zwischen Teams und Lieferanten, was Governance und Datenintegrität mit der Zeit erschwert.</p>
            </div>
          </div>
        </div>



      
    
  



  <!-- Large Visual Block -->
  <section class="py-24 bg-white" data-ps="src/pages/industries/textiles.astro:visual-feature">
     <div class="container mx-auto px-6" data-ps="src/pages/industries/textiles.astro:vf-container">
        <div class="relative h-[600px] rounded-[3rem] overflow-hidden group shadow-2xl bg-slate-900" data-ps="src/pages/industries/textiles.astro:vf-img-wrap">
           <img crossorigin="anonymous"
            src="https://images.unsplash.com/photo-1665815844395-06f64f44b5e3?auto=format&w=1200&q=80"
            srcset="https://images.unsplash.com/photo-1665815844395-06f64f44b5e3?auto=format&w=320&q=80 320w, https://images.unsplash.com/photo-1665815844395-06f64f44b5e3?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1665815844395-06f64f44b5e3?auto=format&w=640&q=80 640w, https://images.unsplash.com/photo-1665815844395-06f64f44b5e3?auto=format&w=768&q=80 768w, https://images.unsplash.com/photo-1665815844395-06f64f44b5e3?auto=format&w=1024&q=80 1024w, https://images.unsplash.com/photo-1665815844395-06f64f44b5e3?auto=format&w=1280&q=80 1280w, https://images.unsplash.com/photo-1665815844395-06f64f44b5e3?auto=format&w=1920&q=80 1920w"
            sizes="100vw"
            alt="Retail experience" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" data-ps="src/pages/industries/textiles.astro:vf-img" />
           <div class="absolute inset-0 bg-slate-900/40 group-hover:bg-slate-900/30 transition-colors" data-ps="src/pages/industries/textiles.astro:vf-overlay"></div>
           <div class="absolute bottom-0 left-0 p-12 md:p-20 text-white max-w-2xl" data-ps="src/pages/industries/textiles.astro:vf-content">
              <h2 class="text-4xl md:text-5xl font-bold mb-6" data-ps="src/pages/industries/textiles.astro:vf-title">Eine Identität, die dem Kleidungsstück erhalten bleibt.</h2>
              <p class="text-lg text-slate-300 leading-relaxed" data-ps="src/pages/industries/textiles.astro:vf-p">Von der Fabrikhalle bis zum Sekundärmarkt sorgt „TieBack“ dafür, dass die digitale Produktgeschichte das wertvollste Merkmal des Produkts bleibt.</p>
           </div>
        </div>
     </div>
  </section>



  <!-- Relevant Use Cases -->
  <section class="py-32 bg-slate-50 border-y border-slate-200" data-ps="src/pages/industries/textiles.astro:evidence-section">
    <div class="container mx-auto px-6" data-ps="src/pages/industries/textiles.astro:evidence-content">
      <div class="max-w-6xl mx-auto" data-ps="src/pages/industries/textiles.astro:evidence-grid-wrap">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6" data-ps="src/pages/industries/textiles.astro:evidence-h-wrap">
          <div data-ps="src/pages/industries/textiles.astro:ev-h-left">
            <h2 class="text-4xl font-bold text-slate-900 mb-4" data-ps="src/pages/industries/textiles.astro:evidence-h">Relevante Anwendungsfälle</h2>
            <p class="text-slate-600 text-lg" data-ps="src/pages/industries/textiles.astro:ev-h-p">Wie „TieBack“ spezifische Herausforderungen für Textilmarken löst.</p>
          </div>
          <a href="/use-cases/compliance-readiness/" class="text-blue-600 font-bold flex items-center gap-2 hover:gap-3 transition-all" data-ps="src/pages/industries/textiles.astro:ev-h-link">
          
            Alle Anwendungsfälle anzeigen<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
        <div class="grid md:grid-cols-3 gap-8" data-ps="src/pages/industries/textiles.astro:use-cases-grid">
           <a href="/use-cases/compliance-readiness/" class="group bg-white p-8 rounded-3xl border border-slate-200 hover:border-blue-300 hover:shadow-xl hover:shadow-blue-500/5 transition-all" data-ps="src/pages/industries/textiles.astro:uc-1">
             <div class="w-12 h-12 bg-blue-50 text-blue-600 rounded-xl flex items-center justify-center mb-6 group-hover:bg-blue-600 group-hover:text-white transition-colors" data-ps="src/pages/industries/textiles.astro:uc-icon-1">
