---,
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/config/site';
,

<BaseLayout
  title={`Why TieBack — Digital Identity for Physical Products | ${SITE.name}`}
  description="Authentication, lifecycle ownership, and connected product experiences — built on standards, designed for scale."
>
  <!-- Hero Section (Dark) -->
  <section class="relative bg-gray-900 text-white pt-32 pb-24 overflow-hidden" data-ps="src/pages/platform/why-tieback.astro:41jg11">
    <div class="absolute inset-0 z-0" data-ps="src/pages/platform/why-tieback.astro:nx1gmw">
      <div class="absolute inset-0 bg-gradient-to-br from-[#0080FF]/20 to-transparent opacity-50" data-ps="src/pages/platform/why-tieback.astro:nx1gmx"></div>
    </div>
    <div class="container mx-auto px-4 relative z-10 max-w-4xl text-center" data-ps="src/pages/platform/why-tieback.astro:nx1gmy">
      <h1 class="text-5xl md:text-6xl font-bold mb-6 tracking-tight text-white" data-ps="src/pages/platform/why-tieback.astro:kb1kkq">
        Digital identity for physical products.
      </h1>
      <p class="text-xl md:text-2xl text-gray-200 mb-8 leading-relaxed" data-ps="src/pages/platform/why-tieback.astro:f6mr3u">
        Give every physical product a living digital identity. TieBack is the scalable SaaS platform for GS1 Digital Link resolution, item-level authentication, and EU ESPR readiness.
      </p>
      <p class="text-lg text-gray-400 mb-10" data-ps="src/pages/platform/why-tieback.astro:f6mr3v">
        TieBack is a SaaS platform for product-level trust, with GS1 Digital Link–native resolution and optional NFC and tamper-resistant event records.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4" data-ps="src/pages/platform/why-tieback.astro:nx1gmz">
        <a href="/contact" class="px-8 py-4 bg-[#0080FF] text-white rounded-lg font-medium hover:bg-blue-600 transition-colors w-full sm:w-auto text-center" data-ps="src/pages/platform/why-tieback.astro:makntk">
          Request access
        </a>
        <a href="/#how-it-works" class="px-8 py-4 bg-white/10 text-white rounded-lg font-medium hover:bg-white/20 transition-colors w-full sm:w-auto text-center border border-white/20" data-ps="src/pages/platform/why-tieback.astro:makntl">
          See how it works
        </a>
      </div>
      <p class="mt-8 text-sm text-gray-400" data-ps="src/pages/platform/why-tieback.astro:f6mr3w">
        We're onboarding brands now for EU ESPR readiness and production rollout.
      </p>
    </div>
  </section>

  <!-- Credibility Strip (Light) -->
  <section class="py-16 bg-white border-b border-gray-100 text-gray-900" data-ps="src/pages/platform/why-tieback.astro:41jg10">
    <div class="container mx-auto px-4 max-w-6xl" data-ps="src/pages/platform/why-tieback.astro:nx1gnl">
      <h2 class="text-2xl font-bold text-center mb-10 text-gray-900" data-ps="src/pages/platform/why-tieback.astro:5mmnch">Designed for real-world rollout</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center" data-ps="src/pages/platform/why-tieback.astro:nx1gnm">
        <div class="p-6 rounded-2xl bg-gray-50 border border-gray-100 shadow-sm" data-ps="src/pages/platform/why-tieback.astro:nx1gnn">
          <h3 class="font-bold text-lg mb-2 text-gray-900" data-ps="src/pages/platform/why-tieback.astro:91s9vw">GS1 Digital Link</h3>
          <p class="text-gray-600" data-ps="src/pages/platform/why-tieback.astro:f6mr3x">Native identifiers and support included</p>
        </div>
        <div class="p-6 rounded-2xl bg-gray-50 border border-gray-100 shadow-sm" data-ps="src/pages/platform/why-tieback.astro:nx1gno">
          <h3 class="font-bold text-lg mb-2 text-gray-900" data-ps="src/pages/platform/why-tieback.astro:91s9vv">Lifecycle Ownership</h3>
          <p class="text-gray-600" data-ps="src/pages/platform/why-tieback.astro:f6mr4j">Item-level identity tracking</p>
        </div>
        <div class="p-6 rounded-2xl bg-gray-50 border border-gray-100 shadow-sm" data-ps="src/pages/platform/why-tieback.astro:nx1gnp">
          <h3 class="font-bold text-lg mb-2 text-gray-900" data-ps="src/pages/platform/why-tieback.astro:91s9v9">AI-led Trust Signals</h3>
          <p class="text-gray-600" data-ps="src/pages/platform/why-tieback.astro:f6mr4k">Insights from every scan</p>
        </div>
        <div class="p-6 rounded-2xl bg-gray-50 border border-gray-100 shadow-sm" data-ps="src/pages/platform/why-tieback.astro:nx1gnq">
          <h3 class="font-bold text-lg mb-2 text-gray-900" data-ps="src/pages/platform/why-tieback.astro:91s9v8">Tamper-resistant</h3>
          <p class="text-gray-600" data-ps="src/pages/platform/why-tieback.astro:f6mr4l">Optional lifecycle proof</p>
        </div>
        <div class="p-6 rounded-2xl bg-gray-50 border border-gray-100 shadow-sm md:col-span-2" data-ps="src/pages/platform/why-tieback.astro:nx1gnr">
          <h3 class="font-bold text-lg mb-2 text-gray-900" data-ps="src/pages/platform/why-tieback.astro:91s9v7">Secure Workspaces</h3>
          <p class="text-gray-600" data-ps="src/pages/platform/why-tieback.astro:f6mr4m">Audited brand workspaces for complete control</p>
        </div>
      </div>
    </div>
  </section>

  <!-- The Inevitability (Light) -->
  <section class="py-24 bg-gray-50 text-gray-900" data-ps="src/pages/platform/why-tieback.astro:41jg0z">
    <div class="container mx-auto px-4 max-w-6xl" data-ps="src/pages/platform/why-tieback.astro:nx1gns">
      <div class="grid lg:grid-cols-2 gap-16 items-center" data-ps="src/pages/platform/why-tieback.astro:hk4he6">
        <div data-ps="src/pages/platform/why-tieback.astro:hk4he5">
          <h2 class="text-4xl font-bold mb-8 text-gray-900 leading-tight" data-ps="src/pages/platform/why-tieback.astro:5mmnci">Physical products are becoming digital endpoints.</h2>
          
          <div class="prose prose-lg max-w-none text-gray-600" data-ps="src/pages/platform/why-tieback.astro:nx1gnt">
            <p class="text-xl mb-6 text-gray-700" data-ps="src/pages/platform/why-tieback.astro:f6mr4n">Regulations, customer expectations, and supply-chain complexity are converging. Every brand will need a persistent, verifiable way to identify products, publish lifecycle information, and keep it current over time.</p>
            
            <p class="mb-8" data-ps="src/pages/platform/why-tieback.astro:f6mr4o">Digital Product Passport programmes are accelerating this shift.</p>
            
            <div class="bg-white p-6 rounded-2xl border border-gray-200 shadow-sm mb-8" data-ps="src/pages/platform/why-tieback.astro:nx1gnu">
              <p class="text-xl font-bold text-gray-900 mb-0" data-ps="src/pages/platform/why-tieback.astro:f6mr4p">This is no longer a future problem. It's an operational one.</p>
            </div>

            <p class="mb-4 text-gray-900 font-bold text-lg" data-ps="src/pages/platform/why-tieback.astro:f6mr4q">Most organisations face the same choice:</p>
            <ul class="space-y-4 mb-10 text-gray-700 list-none pl-0">
              <li class="flex items-start" data-ps="src/pages/platform/why-tieback.astro:6dljse">
                <svg class="w-6 h-6 text-[#0080FF] mr-3 shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                <span data-ps="src/pages/platform/why-tieback.astro:iah7qm">Build and maintain a complex system that will never be their core business</span>
              </li>
              <li class="flex items-start" data-ps="src/pages/platform/why-tieback.astro:6dljsf">
                <svg class="w-6 h-6 text-[#0080FF] mr-3 shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                <span data-ps="src/pages/platform/why-tieback.astro:iah7ql">Or adopt a platform designed specifically for this new reality</span>
              </li>
            </ul>

            <div class="p-6 bg-blue-50 rounded-xl text-blue-900 text-center border border-blue-100 shadow-sm" data-ps="src/pages/platform/why-tieback.astro:nx1gog">
              <p class="text-xl font-bold mb-0" data-ps="src/pages/platform/why-tieback.astro:f6mr4r">TieBack exists for the second path.</p>
            </div>
          </div>
        </div>
        
        <div class="relative group" data-ps="src/pages/platform/why-tieback.astro:img-box-1">
          <div class="absolute -inset-4 bg-gradient-to-r from-blue-500 to-cyan-500 rounded-3xl blur opacity-20 group-hover:opacity-30 transition-opacity" data-ps="src/pages/platform/why-tieback.astro:hk4he4"></div>
          <img
            src="https://images.unsplash.com/photo-1760874610754-18d6928ad387?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w4MTQzNzh8MHwxfHNlYXJjaHwxM3x8bmZjJTIwdGFncyUyMG9uJTIwbHV4dXJ5JTIwcHJvZHVjdHN8ZW58MHx8fHwxNzczNjk0NzY5fDA&ixlib=rb-4.1.0&q=80&w=1200&auto=format"
            sizes="(max-width: 1024px) 100vw, 50vw"
            alt="White nsx model car on display stand" 
            class="relative rounded-2xl shadow-2xl w-full h-[500px] object-cover" data-ps="src/pages/platform/why-tieback.astro:nlqlxn" crossorigin="anonymous" />
        </div>
      </div>
    </div>
  </section>

  <!-- Reframing (Dark) -->
  <section class="py-24 bg-gray-950 text-white relative overflow-hidden" data-ps="src/pages/platform/why-tieback.astro:41jg0y">
    <div class="absolute inset-0 z-0" data-ps="src/pages/platform/why-tieback.astro:nx1goh">
      <img 
        crossorigin="anonymous"
        src="https://images.unsplash.com/photo-1639503547276-90230c4a4198?auto=format&w=1920&q=80" 
        class="w-full h-full object-cover opacity-20"
        alt="Digital security background" data-ps="src/pages/platform/why-tieback.astro:nlqlxo" />
      <div class="absolute inset-0 bg-gradient-to-t from-gray-950 via-gray-950/80 to-transparent" data-ps="src/pages/platform/why-tieback.astro:hk4he3"></div>
    </div>
    <div class="container mx-auto px-4 max-w-6xl relative z-10" data-ps="src/pages/platform/why-tieback.astro:nx1goi">
      <div class="grid lg:grid-cols-5 gap-12 items-center" data-ps="src/pages/platform/why-tieback.astro:hk4he2">
        <div class="lg:col-span-3" data-ps="src/pages/platform/why-tieback.astro:hk4he1">
          <div class="mb-6 inline-block px-4 py-1.5 rounded-full bg-[#0080FF]/20 text-blue-300 font-semibold text-sm border border-[#0080FF]/30 tracking-wide uppercase" data-ps="src/pages/platform/why-tieback.astro:nx1goj">
            Beyond compliance
          </div>
          <h2 class="text-4xl md:text-5xl font-bold mb-4 text-white" data-ps="src/pages/platform/why-tieback.astro:5mmncj">This isn't just compliance.</h2>
          <h3 class="text-3xl md:text-4xl font-semibold mb-10 text-gray-300" data-ps="src/pages/platform/why-tieback.astro:91s9v6">It's a new channel.</h3>
          
          <p class="text-xl text-gray-300 mb-10 leading-relaxed" data-ps="src/pages/platform/why-tieback.astro:f6mr4s">
            A product passport doesn't have to be a static page or a regulatory formality. When designed properly, it becomes:
          </p>

          <div class="grid gap-6 mb-12" data-ps="src/pages/platform/why-tieback.astro:nx1gok">
            <div class="bg-white/5 p-6 rounded-xl border border-white/10 flex items-start backdrop-blur-md shadow-2xl hover:border-blue-500/50 transition-colors" data-ps="src/pages/platform/why-tieback.astro:nx1gol">
              <div class="w-12 h-12 rounded-full bg-[#0080FF]/20 flex items-center justify-center mr-5 shrink-0 border border-[#0080FF]/30" data-ps="src/pages/platform/why-tieback.astro:nx1gom">
                <svg class="w-6 h-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              </div>
              <p class="text-lg text-white font-medium mt-2" data-ps="src/pages/platform/why-tieback.astro:f6mr5e">A single source of truth for compliance and operations</p>
            </div>
            <div class="bg-white/5 p-6 rounded-xl border border-white/10 flex items-start backdrop-blur-md shadow-2xl hover:border-blue-500/50 transition-colors" data-ps="src/pages/platform/why-tieback.astro:nx1gon">
              <div class="w-12 h-12 rounded-full bg-[#0080FF]/20 flex items-center justify-center mr-5 shrink-0 border border-[#0080FF]/30" data-ps="src/pages/platform/why-tieback.astro:nx1goo">
                <svg class="w-6 h-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
              </div>
              <p class="text-lg text-white font-medium mt-2" data-ps="src/pages/platform/why-tieback.astro:f6mr5f">A live interface for customers, owners, and partners</p>
            </div>
            <div class="bg-white/5 p-6 rounded-xl border border-white/10 flex items-start backdrop-blur-md shadow-2xl hover:border-blue-500/50 transition-colors" data-ps="src/pages/platform/why-tieback.astro:nx1gop">
              <div class="w-12 h-12 rounded-full bg-[#0080FF]/20 flex items-center justify-center mr-5 shrink-0 border border-[#0080FF]/30" data-ps="src/pages/platform/why-tieback.astro:hk4he9">
                <svg class="w-6 h-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
              </div>
              <p class="text-lg text-white font-medium mt-2" data-ps="src/pages/platform/why-tieback.astro:f6mr5g">A way to update product information without changing the product itself</p>
            </div>
          </div>
        </div>

        <div class="lg:col-span-2 space-y-8" data-ps="src/pages/platform/why-tieback.astro:side-graphics">
          <div class="bg-white/5 border border-white/10 p-8 rounded-3xl backdrop-blur-md" data-ps="src/pages/platform/why-tieback.astro:hk4he8">
            <p class="text-2xl font-semibold text-white mb-6 leading-tight" data-ps="src/pages/platform/why-tieback.astro:f6mr5h">
              TieBack treats every physical product as a digital endpoint — resolvable, updateable, and controlled by the brand.
            </p>
            <div class="h-1 w-20 bg-blue-500 rounded-full" data-ps="src/pages/platform/why-tieback.astro:hk4he0"></div>
          </div>
          
          <img
            src="https://images.unsplash.com/photo-1632251657417-585ab7d16043?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w4MTQzNzh8MHwxfHNlYXJjaHwxOXx8bmZjJTIwdGFncyUyMG9uJTIwbHV4dXJ5JTIwcHJvZHVjdHN8ZW58MHx8fHwxNzczNjk0NzY5fDA&ixlib=rb-4.1.0&q=80&w=1200&auto=format"
            sizes="(max-width: 1024px) 100vw, 33vw"
            alt="Secure data blocks"
            class="rounded-3xl shadow-2xl border border-white/10 w-full h-64 object-cover" data-ps="src/pages/platform/why-tieback.astro:nlqlxp" crossorigin="anonymous" />
        </div>
      </div>
    </div>
  </section>

  <!-- Why Structured Product Identity Matters (Light) -->
  <section class="py-24 bg-white text-gray-900" data-ps="src/pages/platform/why-tieback.astro:41jg0x">
    <div class="container mx-auto px-4 max-w-5xl" data-ps="src/pages/platform/why-tieback.astro:hk4he7">
      <h2 class="text-4xl font-bold mb-16 text-center text-gray-900" data-ps="src/pages/platform/why-tieback.astro:5mmnck">Why Structured Product Identity Matters</h2>
      
      <div class="grid md:grid-cols-2 gap-12" data-ps="src/pages/platform/why-tieback.astro:hk4he6">
        <div class="bg-gray-50 p-8 rounded-2xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow" data-ps="src/pages/platform/why-tieback.astro:hk4he5">
          <div class="w-14 h-14 bg-red-100 text-red-700 rounded-xl flex items-center justify-center mb-6 border border-red-200" data-ps="src/pages/platform/why-tieback.astro:hk4he4">
            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
          </div>
          <h3 class="text-2xl font-bold mb-4 text-gray-900" data-ps="src/pages/platform/why-tieback.astro:91s9v5">Counterfeit trade is not marginal</h3>
          <p class="text-gray-600 mb-6 leading-relaxed" data-ps="src/pages/platform/why-tieback.astro:f6mr5i">
            According to the OECD and the European Union Intellectual Property Office (EUIPO), trade in counterfeit and pirated goods represents approximately 3.3% of global trade.
          </p>
          <div class="bg-white p-4 rounded-lg border border-gray-100" data-ps="src/pages/platform/why-tieback.astro:hk4he3">
            <p class="text-gray-900 font-bold m-0" data-ps="src/pages/platform/why-tieback.astro:f6mr5j">
              Structured digital identity helps brands move from reactive verification to measurable traceability.
            </p>
          </div>
        </div>

        <div class="bg-gray-50 p-8 rounded-2xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow" data-ps="src/pages/platform/why-tieback.astro:hk4he2">
          <div class="w-14 h-14 bg-blue-100 text-blue-700 rounded-xl flex items-center justify-center mb-6 border border-blue-200" data-ps="src/pages/platform/why-tieback.astro:hk4he1">
            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"></path></svg>
          </div>
          <h3 class="text-2xl font-bold mb-4 text-gray-900" data-ps="src/pages/platform/why-tieback.astro:91s9v4">Regulation is formalising transparency</h3>
          <p class="text-gray-600 mb-6 leading-relaxed" data-ps="src/pages/platform/why-tieback.astro:f6mr5k">
            The EU Ecodesign for Sustainable Products Regulation (ESPR) introduces a framework for Digital Product Passports across product categories.
          </p>
          <div class="bg-white p-4 rounded-lg border border-gray-100" data-ps="src/pages/platform/why-tieback.astro:hk4he0">
            <p class="text-gray-900 font-bold m-0" data-ps="src/pages/platform/why-tieback.astro:f6mr5l">
              Digital Product Passport makes product information persistent, updateable, and inspectable over time.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
---


<baselayout title="<astro-expr" id="0">
  `}
  description="Authentifizierung, Lebenszyklusverwaltung und vernetzte Produkterlebnisse – auf Standards basierend und für Skalierbarkeit konzipiert."
>
  <!-- Hero Section (Dark) -->
  <section class="relative bg-gray-900 text-white pt-32 pb-24 overflow-hidden" data-ps="src/pages/platform/why-tieback.astro:41jg11">
    <div class="absolute inset-0 z-0" data-ps="src/pages/platform/why-tieback.astro:nx1gmw">
      <div class="absolute inset-0 bg-gradient-to-br from-[#0080FF]/20 to-transparent opacity-50" data-ps="src/pages/platform/why-tieback.astro:nx1gmx"></div>
    </div>
    <div class="container mx-auto px-4 relative z-10 max-w-4xl text-center" data-ps="src/pages/platform/why-tieback.astro:nx1gmy">
      <h1 class="text-5xl md:text-6xl font-bold mb-6 tracking-tight text-white" data-ps="src/pages/platform/why-tieback.astro:kb1kkq">
        Digitale Identität für physische Produkte.
      </h1>
      <p class="text-xl md:text-2xl text-gray-200 mb-8 leading-relaxed" data-ps="src/pages/platform/why-tieback.astro:f6mr3u">
        Verleihen Sie jedem physischen Produkt eine lebendige digitale Identität. TieBack ist die skalierbare SaaS-Plattform für die Auflösung von „GS1“ Digital Link, die Authentifizierung auf Artikelebene und die Vorbereitung auf die EU-Verordnung „ESPR“.
      </p>
      <p class="text-lg text-gray-400 mb-10" data-ps="src/pages/platform/why-tieback.astro:f6mr3v">
        TieBack
        ist eine SaaS-Plattform für Vertrauen auf Produktebene mit nativer Auflösung von „GS1
        Digital Link“ sowie optionalen NFC- und manipulationssicheren Ereignisaufzeichnungen.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4" data-ps="src/pages/platform/why-tieback.astro:nx1gmz">
        <a href="/contact" class="px-8 py-4 bg-[#0080FF] text-white rounded-lg font-medium hover:bg-blue-600 transition-colors w-full sm:w-auto text-center" data-ps="src/pages/platform/why-tieback.astro:makntk">
          Zugang beantragen
        </a>
        
        <a href="/#how-it-works" class="px-8 py-4 bg-white/10 text-white rounded-lg font-medium hover:bg-white/20 transition-colors w-full sm:w-auto text-center border border-white/20" data-ps="src/pages/platform/why-tieback.astro:makntl">
          So funktioniert es
        </a>
      </div>
      <p class="mt-8 text-sm text-gray-400" data-ps="src/pages/platform/why-tieback.astro:f6mr3w">
        Wir nehmen derzeit Marken für die EU-ESPR-Bereitschaft und die Produktionsbereitstellung auf.
      </p>
    </div>
  </section></baselayout>

  <!-- Credibility Strip (Light) -->
  <section class="py-16 bg-white border-b border-gray-100 text-gray-900" data-ps="src/pages/platform/why-tieback.astro:41jg10">
    <div class="container mx-auto px-4 max-w-6xl" data-ps="src/pages/platform/why-tieback.astro:nx1gnl">
      <h2 class="text-2xl font-bold text-center mb-10 text-gray-900" data-ps="src/pages/platform/why-tieback.astro:5mmnch">Entwickelt für den Einsatz in der Praxis</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center" data-ps="src/pages/platform/why-tieback.astro:nx1gnm">
