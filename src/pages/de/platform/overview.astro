            <script>
              function initSkuCarousel() {
                const carousel = document.getElementById('macbook-sku-carousel');
                if (!carousel) return;
                
                const slides = carousel.querySelectorAll('.sku-carousel-slide');
                const dots = carousel.querySelectorAll('.sku-carousel-dot');
                const prevBtn = carousel.querySelector('.sku-carousel-prev');
                const nextBtn = carousel.querySelector('.sku-carousel-next');
                let activeSlide = 0;
                const totalSlides = slides.length;
                let autoPlayInterval;

                function goToSlide(index) {
                  slides.forEach((slide, i) => {
                    if (i === index) {
                      slide.classList.remove('opacity-0', 'z-0');
                      slide.classList.add('opacity-100', 'z-10');
                    } else {
                      slide.classList.remove('opacity-100', 'z-10');
                      slide.classList.add('opacity-0', 'z-0');
                    }
