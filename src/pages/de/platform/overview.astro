            <script is:inline>
              function initLifecycleCarousel() {
                const carousel = document.getElementById('macbook-lifecycle-carousel');
                if (!carousel) return;
                
                const slides = carousel.querySelectorAll('.carousel-item');
                const dots = carousel.querySelectorAll('.lifecycle-dot');
                const prevBtn = document.getElementById('lifecycle-prev');
                const nextBtn = document.getElementById('lifecycle-next');
                let activeSlide = 0;
                const totalSlides = slides.length;
                let autoPlayInterval;

                function goToSlide(index) {
                  slides.forEach((slide, i) => {
                    if (i === index) {
                      slide.classList.remove('opacity-0', 'z-0');
                      slide.classList.add('opacity-100', 'z-10');
                    } else {
                      slide.classList.remove('opacity-100', 'z-10');
                      slide.classList.add('opacity-0', 'z-0');
                    }
                  });
                  
                  dots.forEach((dot, i) => {
                    if (i === index) {
                      dot.className = 'lifecycle-dot w-5 h-1.5 rounded-full transition-all duration-300 bg-blue-600 ring-4 ring-blue-600/20';
                    } else {
                      dot.className = 'lifecycle-dot w-1.5 h-1.5 rounded-full transition-all duration-300 bg-slate-300 hover:bg-slate-400';
                    }
                  });
                  
                  activeSlide = index;
                }

                function nextSlide() {
                  goToSlide((activeSlide + 1) % totalSlides);
                }

                function prevSlide() {
                  goToSlide((activeSlide - 1 + totalSlides) % totalSlides);
                }

                function startAutoPlay() {
                  stopAutoPlay();
                  autoPlayInterval = setInterval(nextSlide, 3500);
                }

                function stopAutoPlay() {
                  if (autoPlayInterval) clearInterval(autoPlayInterval);
                }

                if (prevBtn) prevBtn.addEventListener('click', prevSlide);
                if (nextBtn) nextBtn.addEventListener('click', nextSlide);
                
                dots.forEach((dot, i) => {
                  dot.addEventListener('click', () => goToSlide(i));
                });

                carousel.addEventListener('mouseenter', stopAutoPlay);
                carousel.addEventListener('mouseleave', startAutoPlay);

                startAutoPlay();
              }

              initLifecycleCarousel();
              document.addEventListener('astro:page-load', initLifecycleCarousel);
            </script>
          
        
      
    



