---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = "Compliance Readiness — TieBack";
const description = "Prepare early without over-enforcing. TieBack gives compliance, legal, and product teams a structured way to model DPP requirements, run readiness checks, and maintain audit-ready evidence.";
---






<baselayout title="{title}" description="{description}">
  <!-- 1. Use Case Hero -->
  <section class="relative pt-32 pb-24 md:pt-52 md:pb-40 overflow-hidden bg-slate-900" data-ps="src/pages/use-cases/compliance-readiness.astro:hero">
    <!-- Hero Background Image -->
    <div class="absolute inset-0 z-0" data-ps="src/pages/use-cases/compliance-readiness.astro:hero-bg-img-wrap">
      <img crossorigin="anonymous"
        src="https://images.unsplash.com/photo-1634637343552-39a806b0e462?auto=format&w=1200&q=80"
        srcset="https://images.unsplash.com/photo-1634637343552-39a806b0e462?auto=format&w=320&q=80 320w, https://images.unsplash.com/photo-1634637343552-39a806b0e462?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1634637343552-39a806b0e462?auto=format&w=640&q=80 640w, https://images.unsplash.com/photo-1634637343552-39a806b0e462?auto=format&w=768&q=80 768w, https://images.unsplash.com/photo-1634637343552-39a806b0e462?auto=format&w=1024&q=80 1024w, https://images.unsplash.com/photo-1634637343552-39a806b0e462?auto=format&w=1280&q=80 1280w, https://images.unsplash.com/photo-1634637343552-39a806b0e462?auto=format&w=1920&q=80 1920w"
        sizes="100vw"
        alt="Compliance Readiness Architectural Background" class="w-full h-full object-cover opacity-30"
        loading="eager" fetchpriority="high" data-ps="src/pages/use-cases/compliance-readiness.astro:kwsdk0" />
      <div class="absolute inset-0 bg-gradient-to-b from-slate-950/80 via-slate-950/50 to-slate-950/80" data-ps="src/pages/use-cases/compliance-readiness.astro:hero-overlay"></div>
    </div>
</section></baselayout>


    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/use-cases/compliance-readiness.astro:hero-container">
      <div class="max-w-4xl mx-auto text-center" data-ps="src/pages/use-cases/compliance-readiness.astro:hero-content">
        <div class="inline-flex items-center gap-2 py-1 px-3 mb-8 text-[11px] font-bold tracking-widest text-blue-400 uppercase bg-white/5 backdrop-blur-md border border-white/10 rounded-full" data-ps="src/pages/use-cases/compliance-readiness.astro:eyebrow">
          <span class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-pulse" data-ps="src/pages/use-cases/compliance-readiness.astro:pulse"></span>
          Fall 04
        </div>
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight text-white mb-8 leading-[1.05]" data-ps="src/pages/use-cases/compliance-readiness.astro:title">
        
          Compliance<span class="text-blue-500" data-ps="src/pages/use-cases/compliance-readiness.astro:title-blue">-Bereitschaft</span>
        </h1>
        <p class="text-xl md:text-2xl text-slate-300 mb-12 leading-relaxed max-w-2xl mx-auto" data-ps="src/pages/use-cases/compliance-readiness.astro:subtext">
          Bereiten Sie sich frühzeitig vor, ohne zu strenge Maßnahmen zu ergreifen. „TieBack“ bietet Compliance-, Rechts- und Produktteams eine strukturierte Methode, um die Anforderungen des Digital Product Passport zu modellieren, Bereitschaftsprüfungen durchzuführen und auditfähige Nachweise zu pflegen, während sich die Vorschriften weiterentwickeln.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-5" data-ps="src/pages/use-cases/compliance-readiness.astro:buttons">
          <a href="/request-access" class="w-full sm:w-auto px-10 py-4 bg-blue-600 hover:bg-blue-500 text-white font-semibold rounded-xl transition-all duration-300 shadow-2xl shadow-blue-900/40 hover:-translate-y-1" data-ps="src/pages/use-cases/compliance-readiness.astro:btn-primary">
            Zugriff anfordern
          </a>
          
          <a href="/platform/why-tieback/" class="w-full sm:w-auto px-10 py-4 bg-white/5 backdrop-blur-md border border-white/10 text-white font-semibold rounded-xl hover:bg-white/10 transition-all duration-300" data-ps="src/pages/use-cases/compliance-readiness.astro:btn-secondary">
            Plattformübersicht
          </a>
        </div>
      </div>
    </div>
  



  <!-- 2. The Compliance Reality -->
  <section class="py-32 bg-slate-50 border-y border-slate-200/60 relative overflow-hidden" data-ps="src/pages/use-cases/compliance-readiness.astro:reality">
    <div class="container mx-auto px-6" data-ps="src/pages/use-cases/compliance-readiness.astro:reality-container">
      <div class="grid lg:grid-cols-2 gap-20 items-center" data-ps="src/pages/use-cases/compliance-readiness.astro:reality-grid">
        <div class="relative" data-ps="src/pages/use-cases/compliance-readiness.astro:reality-left">
          <div class="absolute -top-12 -left-12 w-24 h-24 bg-blue-100/50 rounded-full blur-2xl" data-ps="src/pages/use-cases/compliance-readiness.astro:accent-3"></div>
          <h2 class="text-4xl md:text-5xl font-bold text-slate-900 leading-[1.15] relative" data-ps="src/pages/use-cases/compliance-readiness.astro:reality-heading">
          
            Entwickelt für Programmverantwortliche, die <span class="italic font-serif text-blue-700" data-ps="src/pages/use-cases/compliance-readiness.astro:reality-blue">einen ruhigen Überblick</span>
          benötigen <span class="italic font-serif text-blue-700" data-ps="src/pages/use-cases/compliance-readiness.astro:reality-blue">– über Märkte, Kategorien und Veränderungen hinweg.</span>
          </h2>
          <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-1 gap-6" data-ps="src/pages/use-cases/compliance-readiness.astro:reality-list">
             <div class="flex gap-4 items-center group bg-white/50 backdrop-blur-sm p-4 rounded-xl border border-slate-200 transition-all hover:border-blue-200 hover:shadow-lg hover:shadow-blue-50" data-ps="src/pages/use-cases/compliance-readiness.astro:reality-item-1">
                <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center shrink-0 text-blue-700 font-bold" data-ps="src/pages/use-cases/compliance-readiness.astro:reality-icon-1">01</div>
                <div data-ps="src/pages/use-cases/compliance-readiness.astro:reality-text-1">
                  <h4 class="font-bold text-slate-900" data-ps="src/pages/use-cases/compliance-readiness.astro:reality-h-1">Frühzeitige Vorbereitung vor Mandatsbeginn</h4>
                </div>
             </div>
             <div class="flex gap-4 items-center group bg-white/50 backdrop-blur-sm p-4 rounded-xl border border-slate-200 transition-all hover:border-blue-200 hover:shadow-lg hover:shadow-blue-50" data-ps="src/pages/use-cases/compliance-readiness.astro:reality-item-2">
                <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center shrink-0 text-blue-700 font-bold" data-ps="src/pages/use-cases/compliance-readiness.astro:reality-icon-2">02</div>
                <div data-ps="src/pages/use-cases/compliance-readiness.astro:reality-text-2">
                  <h4 class="font-bold text-slate-900" data-ps="src/pages/use-cases/compliance-readiness.astro:reality-h-2">Automatische Nachweisfähigkeit und Überprüfbarkeit</h4>
                </div>
             </div>
             <div class="flex gap-4 items-center group bg-white/50 backdrop-blur-sm p-4 rounded-xl border border-slate-200 transition-all hover:border-blue-200 hover:shadow-lg hover:shadow-blue-50" data-ps="src/pages/use-cases/compliance-readiness.astro:reality-item-3">
                <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center shrink-0 text-blue-700 font-bold" data-ps="src/pages/use-cases/compliance-readiness.astro:reality-icon-3">03</div>
                <div data-ps="src/pages/use-cases/compliance-readiness.astro:reality-text-3">
                  <h4 class="font-bold text-slate-900" data-ps="src/pages/use-cases/compliance-readiness.astro:reality-h-3">Reduzierter Verwaltungsaufwand</h4>
                </div>
             </div>
             <div class="flex gap-4 items-center group bg-white/50 backdrop-blur-sm p-4 rounded-xl border border-slate-200 transition-all hover:border-blue-200 hover:shadow-lg hover:shadow-blue-50" data-ps="src/pages/use-cases/compliance-readiness.astro:reality-item-4">
                <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center shrink-0 text-blue-700 font-bold" data-ps="src/pages/use-cases/compliance-readiness.astro:reality-icon-4">04</div>
                <div data-ps="src/pages/use-cases/compliance-readiness.astro:reality-text-4">
                  <h4 class="font-bold text-slate-900" data-ps="src/pages/use-cases/compliance-readiness.astro:reality-h-4">Anpassung an sich weiterentwickelnde Vorschriften</h4>
                </div>
             </div>
          </div>
        </div>
        <div class="relative" data-ps="src/pages/use-cases/compliance-readiness.astro:reality-right">
          <div class="bg-white p-8 md:p-12 rounded-[2rem] border border-slate-200 shadow-2xl shadow-slate-200/50" data-ps="src/pages/use-cases/compliance-readiness.astro:reality-box">
            <h3 class="text-xs uppercase tracking-widest text-blue-700 font-bold mb-4" data-ps="src/pages/use-cases/compliance-readiness.astro:reality-eyebrow">Die Realität der Compliance</h3>
            <p class="text-xl text-slate-800 leading-relaxed mb-8 font-medium" data-ps="src/pages/use-cases/compliance-readiness.astro:reality-quote">
              Programme für digitale Produktpässe sorgen für Beständigkeit. Produktinformationen müssen über einen längeren Zeitraum strukturiert, aktuell und überprüfbar bleiben – und die Beweislast liegt bei der Organisation.
            </p>
            <div class="h-px bg-slate-100 mb-8" data-ps="src/pages/use-cases/compliance-readiness.astro:reality-divider"></div>
            <div class="grid gap-4" data-ps="src/pages/use-cases/compliance-readiness.astro:reality-bullets">
              <div class="flex items-start gap-4" data-ps="src/pages/use-cases/compliance-readiness.astro:reality-bullet-1">
                <span class="w-2 h-2 rounded-full bg-blue-600 mt-2 shrink-0" data-ps="src/pages/use-cases/compliance-readiness.astro:bullet-dot-1"></span>
                <p class="text-slate-600 font-medium" data-ps="src/pages/use-cases/compliance-readiness.astro:bullet-text-1">Die Anforderungen entwickeln sich Kategorie für Kategorie</p>
              </div>
              <div class="flex items-start gap-4" data-ps="src/pages/use-cases/compliance-readiness.astro:reality-bullet-2">
                <span class="w-2 h-2 rounded-full bg-blue-600 mt-2 shrink-0" data-ps="src/pages/use-cases/compliance-readiness.astro:bullet-dot-2"></span>
                <p class="text-slate-600 font-medium" data-ps="src/pages/use-cases/compliance-readiness.astro:bullet-text-2">Nachweise werden erwartet, sie sind nicht optional</p>
              </div>
              <div class="flex items-start gap-4" data-ps="src/pages/use-cases/compliance-readiness.astro:reality-bullet-3">
                <span class="w-2 h-2 rounded-full bg-blue-600 mt-2 shrink-0" data-ps="src/pages/use-cases/compliance-readiness.astro:bullet-dot-3"></span>
                <p class="text-slate-600 font-medium" data-ps="src/pages/use-cases/compliance-readiness.astro:bullet-text-3">Kontinuität: Passes müssen über einen längeren Zeitraum korrekt bleiben</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>



  <!-- 3. Capabilities Grid -->
  <section class="py-32 bg-white" data-ps="src/pages/use-cases/compliance-readiness.astro:capabilities">
    <div class="container mx-auto px-6" data-ps="src/pages/use-cases/compliance-readiness.astro:capabilities-container">
      <div class="max-w-3xl mb-20" data-ps="src/pages/use-cases/compliance-readiness.astro:capabilities-header">
        <span class="text-blue-700 font-bold uppercase tracking-wider text-xs block mb-4" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-label">Vorbereitungsphase</span>
        <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-title">Baseline-Modus.</h2>
        <p class="text-slate-600 text-xl leading-relaxed" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-subtext">Die Passport-Strukturen sind verfügbar, die Felder sind sichtbar, und die Teams können Datenquellen abgleichen, ohne den Betrieb zu stören.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-grid">
        <!-- Card 1 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-card-1">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-card-deco-1"></div>
          <div class="w-14 h-14 bg-blue-700 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-icon-1">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-h-1">Frühe Vorbereitung</h3>
          <p class="text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-p-1">Abstimmung der internen Zuständigkeiten und Lieferantenbeiträge ohne vorzeitige operative Belastung.</p>
          <ul class="space-y-4 text-slate-700 font-medium" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-list-1">
            <li class="flex items-start gap-3" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-li-1-1"><svg class="w-5 h-5 text-blue-700 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Basisstrukturen auf SKU-Ebene</li>
            <li class="flex items-start gap-3" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-li-1-2"><svg class="w-5 h-5 text-blue-700 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Empfohlene vs. erforderliche Felder</li>
            <li class="flex items-start gap-3" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-li-1-3"><svg class="w-5 h-5 text-blue-700 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Versionshistorie vom ersten Tag an</li>
          </ul>
        </div>
</div></div></section>


        <!-- Card 2 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-card-2">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-card-deco-2"></div>
          <div class="w-14 h-14 bg-blue-700 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-icon-2">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-h-2">Governance und Nachweisführung</h3>
          <p class="text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-p-2">Die Bereitschaft wird messbar, wenn das System automatisch Nachweise erstellt.</p>
          <ul class="space-y-4 text-slate-700 font-medium" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-list-2">
            <li class="flex items-start gap-3" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-li-2-1"><svg class="w-5 h-5 text-blue-700 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Versionsgeführte Passhistorie</li>
            <li class="flex items-start gap-3" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-li-2-2"><svg class="w-5 h-5 text-blue-700 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Rückverfolgbarkeit auf Benutzer-/Rollenebene</li>
            <li class="flex items-start gap-3" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-li-2-3"><svg class="w-5 h-5 text-blue-700 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Exportierbare Audit-Snapshots</li>
          </ul>
        </div>



        <!-- Card 3 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-card-3">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-card-deco-3"></div>
          <div class="w-14 h-14 bg-blue-700 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-icon-3">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-h-3">Erfahrung als Prüfer</h3>
          <p class="text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-p-3">Spezielle Compliance-Rollen, damit Prüfer den Verlauf und die Bereitschaft sicher überprüfen können.</p>
          <ul class="space-y-4 text-slate-700 font-medium" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-list-3">
            <li class="flex items-start gap-3" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-li-3-1"><svg class="w-5 h-5 text-blue-700 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Lesezugriff mit eingeschränkter Zugriffsberechtigung</li>
            <li class="flex items-start gap-3" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-li-3-2"><svg class="w-5 h-5 text-blue-700 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Validierung und Sicherheitsüberprüfungen</li>
            <li class="flex items-start gap-3" data-ps="src/pages/use-cases/compliance-readiness.astro:cap-li-3-3"><svg class="w-5 h-5 text-blue-700 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Verifizierte Lebenszyklusereignisse</li>
          </ul>
        </div>
      
    
  



  <!-- Visual Separator Section -->
  <section class="py-24 bg-slate-950 text-white relative overflow-hidden" data-ps="src/pages/use-cases/compliance-readiness.astro:stability">
    <div class="absolute inset-0 opacity-40" data-ps="src/pages/use-cases/compliance-readiness.astro:stability-bg">
      <img crossorigin="anonymous"
        src="https://images.unsplash.com/photo-1451187580459-43490279c0fa?auto=format&w=1200&q=80"
        srcset="https://images.unsplash.com/photo-1451187580459-43490279c0fa?auto=format&w=320&q=80 320w, https://images.unsplash.com/photo-1451187580459-43490279c0fa?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1451187580459-43490279c0fa?auto=format&w=640&q=80 640w, https://images.unsplash.com/photo-1451187580459-43490279c0fa?auto=format&w=768&q=80 768w, https://images.unsplash.com/photo-1451187580459-43490279c0fa?auto=format&w=1024&q=80 1024w, https://images.unsplash.com/photo-1451187580459-43490279c0fa?auto=format&w=1280&q=80 1280w, https://images.unsplash.com/photo-1451187580459-43490279c0fa?auto=format&w=1920&q=80 1920w"
        sizes="100vw"
        alt="Stability and Growth" class="w-full h-full object-cover" data-ps="src/pages/use-cases/compliance-readiness.astro:stability-img" />
      <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/80 to-transparent" data-ps="src/pages/use-cases/compliance-readiness.astro:stability-overlay"></div>
    </div>
    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/use-cases/compliance-readiness.astro:stability-container">
      <div class="max-w-5xl mx-auto" data-ps="src/pages/use-cases/compliance-readiness.astro:stability-content">
