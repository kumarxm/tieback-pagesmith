---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/config/site';

const title = "Authentication & Anti-Counterfeit — TieBack";
const description = "Verifiable product identity without consumer friction. Structured authentication for brands facing counterfeiting, diversion, or grey markets.";
---

<BaseLayout title={title} description={description}>
  <!-- 1. Use Case Hero (Cloned from Compliance) -->
  <section class="relative pt-32 pb-24 md:pt-52 md:pb-40 overflow-hidden bg-white" data-ps="src/pages/use-cases/authentication.astro:hero">
    <!-- Subtle Background Accents -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-7xl pointer-events-none" data-ps="src/pages/use-cases/authentication.astro:bg-accents">
      <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-blue-50/50 blur-[120px]" data-ps="src/pages/use-cases/authentication.astro:accent-1"></div>
      <div class="absolute bottom-[10%] right-[-5%] w-[30%] h-[30%] rounded-full bg-slate-50 blur-[100px]" data-ps="src/pages/use-cases/authentication.astro:accent-2"></div>
    </div>

    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/use-cases/authentication.astro:hero-container">
      <div class="max-w-4xl mx-auto text-center" data-ps="src/pages/use-cases/authentication.astro:hero-content">
        <div class="inline-flex items-center gap-2 py-1 px-3 mb-8 text-[11px] font-bold tracking-widest text-blue-600 uppercase bg-blue-50/80 backdrop-blur-sm border border-blue-100 rounded-full" data-ps="src/pages/use-cases/authentication.astro:eyebrow">
          <span class="w-1.5 h-1.5 rounded-full bg-blue-600 animate-pulse" data-ps="src/pages/use-cases/authentication.astro:pulse"></span>
          Use Case 07
        </div>
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight text-slate-900 mb-8 leading-[1.05]" data-ps="src/pages/use-cases/authentication.astro:title">
          Authentication & <span class="text-blue-600" data-ps="src/pages/use-cases/authentication.astro:title-blue">Anti-Counterfeit</span>
        </h1>
        <p class="text-xl md:text-2xl text-slate-600 mb-12 leading-relaxed max-w-2xl mx-auto" data-ps="src/pages/use-cases/authentication.astro:subtext">
          Verifiable product identity without consumer friction. Structured authentication for brands facing counterfeiting, diversion, or grey markets.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-5" data-ps="src/pages/use-cases/authentication.astro:buttons">
          <a href="#request-access" class="w-full sm:w-auto px-10 py-4 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl transition-all duration-300 shadow-xl shadow-blue-200 hover:-translate-y-1" data-ps="src/pages/use-cases/authentication.astro:btn-primary">
            Request Access
          </a>
          <a href="/platform/why-tieback/" class="w-full sm:w-auto px-10 py-4 bg-white border border-slate-200 text-slate-700 font-semibold rounded-xl hover:bg-slate-50 transition-all duration-300 hover:border-slate-300" data-ps="src/pages/use-cases/authentication.astro:btn-secondary">
            Platform Overview
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. The Challenge (Cloned from Compliance) -->
  <section class="py-32 bg-slate-50 border-y border-slate-200/60 relative overflow-hidden" data-ps="src/pages/use-cases/authentication.astro:challenge">
    <div class="container mx-auto px-6" data-ps="src/pages/use-cases/authentication.astro:challenge-container">
      <div class="grid lg:grid-cols-2 gap-20 items-center" data-ps="src/pages/use-cases/authentication.astro:challenge-grid">
        <div class="relative" data-ps="src/pages/use-cases/authentication.astro:challenge-left">
          <div class="absolute -top-12 -left-12 w-24 h-24 bg-blue-100/50 rounded-full blur-2xl" data-ps="src/pages/use-cases/authentication.astro:accent-3"></div>
          <h2 class="text-4xl md:text-5xl font-bold text-slate-900 leading-[1.15] relative" data-ps="src/pages/use-cases/authentication.astro:challenge-heading">
            Built for brands facing <span class="italic font-serif text-blue-600" data-ps="src/pages/use-cases/authentication.astro:challenge-blue">counterfeiting, diversion, or grey markets</span>.
          </h2>
          <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-1 gap-8" data-ps="src/pages/use-cases/authentication.astro:challenge-list">
             <div class="flex gap-6 group bg-white/50 backdrop-blur-sm p-6 rounded-2xl border border-slate-200 transition-all hover:border-blue-200 hover:shadow-lg hover:shadow-blue-50" data-ps="src/pages/use-cases/authentication.astro:challenge-item-1">
                <div class="w-12 h-12 rounded-xl bg-blue-600 flex items-center justify-center shrink-0 shadow-lg shadow-blue-100" data-ps="src/pages/use-cases/authentication.astro:challenge-icon-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-alert"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
                </div>
                <div data-ps="src/pages/use-cases/authentication.astro:challenge-text-1">
                  <h4 class="font-bold text-slate-900 mb-1" data-ps="src/pages/use-cases/authentication.astro:challenge-h-1">Authenticity Matters</h4>
                  <p class="text-slate-600 text-sm" data-ps="src/pages/use-cases/authentication.astro:challenge-p-1">For luxury, premium apparel, and electronics, identity must be verifiable, not assumed.</p>
                </div>
             </div>
             <div class="flex gap-6 group bg-white/50 backdrop-blur-sm p-6 rounded-2xl border border-slate-200 transition-all hover:border-blue-200 hover:shadow-lg hover:shadow-blue-50" data-ps="src/pages/use-cases/authentication.astro:challenge-item-2">
                <div class="w-12 h-12 rounded-xl bg-blue-600 flex items-center justify-center shrink-0 shadow-lg shadow-blue-100" data-ps="src/pages/use-cases/authentication.astro:challenge-icon-2">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-alert-octagon"><polygon points="7.86 2 16.14 2 22 7.86 22 16.14 16.14 22 7.86 22 2 16.14 2 7.86 7.86 2"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                </div>
                <div data-ps="src/pages/use-cases/authentication.astro:challenge-text-2">
                  <h4 class="font-bold text-slate-900 mb-1" data-ps="src/pages/use-cases/authentication.astro:challenge-h-2">Systemic Risks</h4>
                  <p class="text-slate-600 text-sm" data-ps="src/pages/use-cases/authentication.astro:challenge-p-2">Counterfeiting creates revenue leakage, brand dilution, and safety exposure.</p>
                </div>
             </div>
          </div>
        </div>
        <div class="relative" data-ps="src/pages/use-cases/authentication.astro:challenge-right">
          <div class="bg-white p-8 md:p-12 rounded-[2rem] border border-slate-200 shadow-2xl shadow-slate-200/50" data-ps="src/pages/use-cases/authentication.astro:challenge-box">
            <p class="text-2xl text-slate-800 leading-relaxed mb-8 font-medium" data-ps="src/pages/use-cases/authentication.astro:challenge-quote">
              Traditional approaches rely on static codes and non-verifiable markers. Authentication becomes reactive rather than systematic.
            </p>
            <div class="h-px bg-slate-100 mb-8" data-ps="src/pages/use-cases/authentication.astro:challenge-divider"></div>
            <div class="grid gap-6" data-ps="src/pages/use-cases/authentication.astro:challenge-bullets">
              <div class="flex items-start gap-4" data-ps="src/pages/use-cases/authentication.astro:challenge-bullet-1">
                <span class="w-2 h-2 rounded-full bg-blue-600 mt-2.5 shrink-0" data-ps="src/pages/use-cases/authentication.astro:bullet-dot-1"></span>
                <p class="text-slate-600 text-lg" data-ps="src/pages/use-cases/authentication.astro:bullet-text-1">Fragmented portals and serial numbers without validation create customer mistrust.</p>
              </div>
              <div class="flex items-start gap-4" data-ps="src/pages/use-cases/authentication.astro:challenge-bullet-2">
                <span class="w-2 h-2 rounded-full bg-blue-600 mt-2.5 shrink-0" data-ps="src/pages/use-cases/authentication.astro:bullet-dot-2"></span>
                <p class="text-slate-600 text-lg" data-ps="src/pages/use-cases/authentication.astro:bullet-text-2">TieBack supports structured authentication without introducing complexity for consumers.</p>
              </div>
            </div>
          </div>
          <!-- Decorative element -->
          <div class="absolute -bottom-6 -right-6 w-32 h-32 border-b-2 border-r-2 border-blue-100 rounded-br-3xl pointer-events-none" data-ps="src/pages/use-cases/authentication.astro:challenge-deco"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Capabilities Grid (Cloned from Compliance) -->
  <section class="py-32 bg-white" data-ps="src/pages/use-cases/authentication.astro:capabilities">
    <div class="container mx-auto px-6" data-ps="src/pages/use-cases/authentication.astro:capabilities-container">
      <div class="max-w-3xl mb-20" data-ps="src/pages/use-cases/authentication.astro:capabilities-header">
        <span class="text-blue-600 font-bold uppercase tracking-wider text-xs block mb-4" data-ps="src/pages/use-cases/authentication.astro:cap-label">Capabilities</span>
        <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6" data-ps="src/pages/use-cases/authentication.astro:cap-title">Structured verification.</h2>
        <p class="text-slate-600 text-xl leading-relaxed" data-ps="src/pages/use-cases/authentication.astro:cap-subtext">TieBack enables unit-level passports where each item carries a unique, persistent digital identity verifiable through the resolver.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-ps="src/pages/use-cases/authentication.astro:cap-grid">
        <!-- Card 1 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/authentication.astro:cap-card-1">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/authentication.astro:cap-card-deco-1"></div>
          <div class="w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/authentication.astro:cap-icon-1">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/use-cases/authentication.astro:cap-h-1">Item-Level Identity</h3>
          <p class="text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/use-cases/authentication.astro:cap-p-1">Persistent identity that remains verifiable through the resolver—not through visual inspection alone.</p>
          <ul class="space-y-4 text-slate-700 font-medium" data-ps="src/pages/use-cases/authentication.astro:cap-list-1">
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/authentication.astro:cap-li-1-1"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Unique persistent IDs</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/authentication.astro:cap-li-1-2"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Structured lifecycle status</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/authentication.astro:cap-li-1-3"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Full ownership history</li>
          </ul>
        </div>

        <!-- Card 2 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/authentication.astro:cap-card-2">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/authentication.astro:cap-card-deco-2"></div>
          <div class="w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/authentication.astro:cap-icon-2">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/use-cases/authentication.astro:cap-h-2">High-Assurance Mode</h3>
          <p class="text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/use-cases/authentication.astro:cap-p-2">Enhanced assurance for high-risk categories through tamper-resistant anchored records.</p>
          <ul class="space-y-4 text-slate-700 font-medium" data-ps="src/pages/use-cases/authentication.astro:cap-list-2">
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/authentication.astro:cap-li-2-1"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Tamper-resistant records</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/authentication.astro:cap-li-2-2"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> No consumer apps required</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/authentication.astro:cap-li-2-3"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Simple Scan. View. Confirm.</li>
          </ul>
        </div>

        <!-- Card 3 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/authentication.astro:cap-card-3">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/authentication.astro:cap-card-deco-3"></div>
          <div class="w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/authentication.astro:cap-icon-3">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/use-cases/authentication.astro:cap-h-3">Trust Signals</h3>
          <p class="text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/use-cases/authentication.astro:cap-p-3">Real-world signals surfaced operationally to support brand protection workflows without friction.</p>
          <ul class="space-y-4 text-slate-700 font-medium" data-ps="src/pages/use-cases/authentication.astro:cap-list-3">
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/authentication.astro:cap-li-3-1"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Geofence anomaly detection</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/authentication.astro:cap-li-3-2"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Abnormal frequency alerts</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/authentication.astro:cap-li-3-3"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Zero-consumer friction</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Visual Separator Section (Cloned from Compliance) -->
  <section class="py-24 bg-slate-950 text-white relative overflow-hidden" data-ps="src/pages/use-cases/authentication.astro:evidence">
    <div class="absolute inset-0 opacity-30" data-ps="src/pages/use-cases/authentication.astro:evidence-bg">
      <img crossorigin="anonymous"
        src="https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&w=1200&q=80"
        srcset="https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&w=320&q=80 320w, https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&w=640&q=80 640w, https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&w=768&q=80 768w, https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&w=1024&q=80 1024w, https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&w=1280&q=80 1280w, https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&w=1920&q=80 1920w"
        sizes="100vw"
        alt="Cybersecurity data lines" class="w-full h-full object-cover" data-ps="src/pages/use-cases/authentication.astro:evidence-img" />
      <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/80 to-transparent" data-ps="src/pages/use-cases/authentication.astro:evidence-overlay"></div>
    </div>
    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/use-cases/authentication.astro:evidence-container">
      <div class="max-w-5xl mx-auto" data-ps="src/pages/use-cases/authentication.astro:evidence-content">
        <h2 class="text-3xl md:text-5xl font-bold mb-16 text-center" data-ps="src/pages/use-cases/authentication.astro:evidence-title">Measurable protection.</h2>
        <div class="grid lg:grid-cols-2 gap-16 items-center" data-ps="src/pages/use-cases/authentication.astro:evidence-grid">
           <div class="bg-white/5 backdrop-blur-xl p-10 rounded-[2.5rem] border border-white/10 shadow-2xl" data-ps="src/pages/use-cases/authentication.astro:evidence-box">
             <div class="flex items-center gap-4 mb-8" data-ps="src/pages/use-cases/authentication.astro:evidence-label-wrap">
               <div class="w-10 h-10 rounded-xl bg-blue-500/20 flex items-center justify-center" data-ps="src/pages/use-cases/authentication.astro:evidence-icon-box">
                 <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#60a5fa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-fingerprint"><path d="M2 12C2 6.477 6.477 2 12 2s10 4.477 10 10"/><path d="M5 12c0-3.866 3.134-7 7-7s7 3.134 7 7"/><path d="M8 12c0-2.209 1.791-4 4-4s4 1.791 4 4"/><path d="M12 12v9"/><path d="M9 16.5c1.5 1 3 1 4.5 0"/><path d="M12 18h.01"/></svg>
               </div>
               <h4 class="text-blue-400 font-bold uppercase tracking-widest text-xs" data-ps="src/pages/use-cases/authentication.astro:evidence-label">Identity Layer</h4>
             </div>
             <ul class="space-y-6" data-ps="src/pages/use-cases/authentication.astro:evidence-list">
               <li class="flex items-center gap-4 group" data-ps="src/pages/use-cases/authentication.astro:evidence-li-1">
                 <div class="w-2 h-2 rounded-full bg-blue-500 shadow-[0_0_10px_#3b82f6]" data-ps="src/pages/use-cases/authentication.astro:evidence-dot-1"></div>
                 <span class="text-lg font-medium text-slate-200" data-ps="src/pages/use-cases/authentication.astro:evidence-txt-1">Verifiable Product Identity</span>
               </li>
               <li class="flex items-center gap-4 group" data-ps="src/pages/use-cases/authentication.astro:evidence-li-2">
                 <div class="w-2 h-2 rounded-full bg-blue-500 shadow-[0_0_10px_#3b82f6]" data-ps="src/pages/use-cases/authentication.astro:evidence-dot-2"></div>
                 <span class="text-lg font-medium text-slate-200" data-ps="src/pages/use-cases/authentication.astro:evidence-txt-2">Resale Trust Protocols</span>
               </li>
               <li class="flex items-center gap-4 group" data-ps="src/pages/use-cases/authentication.astro:evidence-li-3">
                 <div class="w-2 h-2 rounded-full bg-blue-500 shadow-[0_0_10px_#3b82f6]" data-ps="src/pages/use-cases/authentication.astro:evidence-dot-3"></div>
                 <span class="text-lg font-medium text-slate-200" data-ps="src/pages/use-cases/authentication.astro:evidence-txt-3">Anomaly Escalation Logic</span>
               </li>
             </ul>
           </div>
           <div class="flex flex-col justify-center" data-ps="src/pages/use-cases/authentication.astro:evidence-text">
             <h3 class="text-2xl font-bold mb-6" data-ps="src/pages/use-cases/authentication.astro:evidence-h3">Beyond Authenticity</h3>
             <p class="text-slate-400 text-lg leading-relaxed mb-8" data-ps="src/pages/use-cases/authentication.astro:evidence-p">
               The same identity layer used for compliance becomes the basis for authenticity. Authentication supports warranty validation, resale confidence, and customs checks without parallel systems.
             </p>
             <div class="flex items-center gap-6" data-ps="src/pages/use-cases/authentication.astro:evidence-stats">
                <div data-ps="src/pages/use-cases/authentication.astro:stat-1">
                  <div class="text-3xl font-bold text-blue-400" data-ps="src/pages/use-cases/authentication.astro:stat-val-1">Zero</div>
                  <div class="text-xs uppercase tracking-widest text-slate-400 font-bold" data-ps="src/pages/use-cases/authentication.astro:stat-lbl-1">Consumer Friction</div>
                </div>
                <div class="w-px h-10 bg-white/10" data-ps="src/pages/use-cases/authentication.astro:stat-sep"></div>
                <div data-ps="src/pages/use-cases/authentication.astro:stat-2">
                  <div class="text-3xl font-bold text-blue-400" data-ps="src/pages/use-cases/authentication.astro:stat-val-2">Simple</div>
                  <div class="text-xs uppercase tracking-widest text-slate-400 font-bold" data-ps="src/pages/use-cases/authentication.astro:stat-lbl-2">Verification</div>
                </div>
             </div>
           </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Final CTA (Cloned from Compliance) -->
  <section id="request-access" class="py-32 bg-white relative overflow-hidden" data-ps="src/pages/use-cases/authentication.astro:cta">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_left,_var(--tw-gradient-stops))] from-blue-50/50 via-transparent to-transparent pointer-events-none" data-ps="src/pages/use-cases/authentication.astro:cta-grad"></div>
    <div class="container mx-auto px-6 relative z-10 text-center" data-ps="src/pages/use-cases/authentication.astro:cta-container">
      <div class="max-w-4xl mx-auto" data-ps="src/pages/use-cases/authentication.astro:cta-content">
        <h2 class="text-5xl md:text-6xl font-bold text-slate-900 mb-8 tracking-tight" data-ps="src/pages/use-cases/authentication.astro:cta-h">Identity that <span class="text-blue-600" data-ps="src/pages/use-cases/authentication.astro:cta-blue">proves itself.</span></h2>
        <p class="text-xl text-slate-600 mb-12 max-w-2xl mx-auto leading-relaxed" data-ps="src/pages/use-cases/authentication.astro:cta-p">
          Authenticity without complexity. Verification without friction. Join the brands securing their product integrity with TieBack.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-6" data-ps="src/pages/use-cases/authentication.astro:cta-buttons">
          <button class="w-full sm:w-auto px-12 py-5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-2xl transition-all duration-300 shadow-2xl shadow-blue-200 hover:-translate-y-1" data-ps="src/pages/use-cases/authentication.astro:cta-primary">
            Request Early Access
          </button>
          <a href="/platform/security/" class="group text-slate-900 font-bold flex items-center gap-3 transition-colors hover:text-blue-600" data-ps="src/pages/use-cases/authentication.astro:cta-secondary">
            Platform Security <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
,---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/config/site';

const title = "Authentication & Anti-Counterfeit — TieBack";
const description = "Verifiable product identity without consumer friction. Structured authentication for brands facing counterfeiting, diversion, or grey markets.";
---
,<BaseLayout title={title} description={description}>
  <!-- 1. Use Case Hero (Cloned from Compliance) -->
  <section class="relative pt-32 pb-24 md:pt-52 md:pb-40 overflow-hidden bg-white" data-ps="src/pages/use-cases/authentication.astro:hero">
    <!-- Subtle Background Accents -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-7xl pointer-events-none" data-ps="src/pages/use-cases/authentication.astro:bg-accents">
      <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-blue-50/50 blur-[120px]" data-ps="src/pages/use-cases/authentication.astro:accent-1"></div>
      <div class="absolute bottom-[10%] right-[-5%] w-[30%] h-[30%] rounded-full bg-slate-50 blur-[100px]" data-ps="src/pages/use-cases/authentication.astro:accent-2"></div>
    </div>

    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/use-cases/authentication.astro:hero-container">
      <div class="max-w-4xl mx-auto text-center" data-ps="src/pages/use-cases/authentication.astro:hero-content">
        <div class="inline-flex items-center gap-2 py-1 px-3 mb-8 text-[11px] font-bold tracking-widest text-blue-600 uppercase bg-blue-50/80 backdrop-blur-sm border border-blue-100 rounded-full" data-ps="src/pages/use-cases/authentication.astro:eyebrow">
          <span class="w-1.5 h-1.5 rounded-full bg-blue-600 animate-pulse" data-ps="src/pages/use-cases/authentication.astro:pulse"></span>
          Use Case 07
        </div>
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight text-slate-900 mb-8 leading-[1.05]" data-ps="src/pages/use-cases/authentication.astro:title">
          Authentication & <span class="text-blue-600" data-ps="src/pages/use-cases/authentication.astro:title-blue">Anti-Counterfeit</span>
        </h1>
        <p class="text-xl md:text-2xl text-slate-600 mb-12 leading-relaxed max-w-2xl mx-auto" data-ps="src/pages/use-cases/authentication.astro:subtext">
          Verifiable product identity without consumer friction. Structured authentication for brands facing counterfeiting, diversion, or grey markets.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-5" data-ps="src/pages/use-cases/authentication.astro:buttons">
          <a href="#request-access" class="w-full sm:w-auto px-10 py-4 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl transition-all duration-300 shadow-xl shadow-blue-200 hover:-translate-y-1" data-ps="src/pages/use-cases/authentication.astro:btn-primary">
            Request Access
          </a>
          <a href="/platform/why-tieback/" class="w-full sm:w-auto px-10 py-4 bg-white border border-slate-200 text-slate-700 font-semibold rounded-xl hover:bg-slate-50 transition-all duration-300 hover:border-slate-300" data-ps="src/pages/use-cases/authentication.astro:btn-secondary">
            Platform Overview
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. The Challenge (Cloned from Compliance) -->
  <section class="py-32 bg-slate-50 border-y border-slate-200/60 relative overflow-hidden" data-ps="src/pages/use-cases/authentication.astro:challenge">
    <div class="container mx-auto px-6" data-ps="src/pages/use-cases/authentication.astro:challenge-container">
      <div class="grid lg:grid-cols-2 gap-20 items-center" data-ps="src/pages/use-cases/authentication.astro:challenge-grid">
        <div class="relative" data-ps="src/pages/use-cases/authentication.astro:challenge-left">
          <div class="absolute -top-12 -left-12 w-24 h-24 bg-blue-100/50 rounded-full blur-2xl" data-ps="src/pages/use-cases/authentication.astro:accent-3"></div>
          <h2 class="text-4xl md:text-5xl font-bold text-slate-900 leading-[1.15] relative" data-ps="src/pages/use-cases/authentication.astro:challenge-heading">
            Built for brands facing <span class="italic font-serif text-blue-600" data-ps="src/pages/use-cases/authentication.astro:challenge-blue">counterfeiting, diversion, or grey markets</span>.
          </h2>
          <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-1 gap-8" data-ps="src/pages/use-cases/authentication.astro:challenge-list">
             <div class="flex gap-6 group bg-white/50 backdrop-blur-sm p-6 rounded-2xl border border-slate-200 transition-all hover:border-blue-200 hover:shadow-lg hover:shadow-blue-50" data-ps="src/pages/use-cases/authentication.astro:challenge-item-1">
                <div class="w-12 h-12 rounded-xl bg-blue-600 flex items-center justify-center shrink-0 shadow-lg shadow-blue-100" data-ps="src/pages/use-cases/authentication.astro:challenge-icon-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-alert"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
                </div>
                <div data-ps="src/pages/use-cases/authentication.astro:challenge-text-1">
                  <h4 class="font-bold text-slate-900 mb-1" data-ps="src/pages/use-cases/authentication.astro:challenge-h-1">Authenticity Matters</h4>
                  <p class="text-slate-600 text-sm" data-ps="src/pages/use-cases/authentication.astro:challenge-p-1">For luxury, premium apparel, and electronics, identity must be verifiable, not assumed.</p>
                </div>
             </div>
             <div class="flex gap-6 group bg-white/50 backdrop-blur-sm p-6 rounded-2xl border border-slate-200 transition-all hover:border-blue-200 hover:shadow-lg hover:shadow-blue-50" data-ps="src/pages/use-cases/authentication.astro:challenge-item-2">
                <div class="w-12 h-12 rounded-xl bg-blue-600 flex items-center justify-center shrink-0 shadow-lg shadow-blue-100" data-ps="src/pages/use-cases/authentication.astro:challenge-icon-2">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-alert-octagon"><polygon points="7.86 2 16.14 2 22 7.86 22 16.14 16.14 22 7.86 22 2 16.14 2 7.86 7.86 2"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                </div>
                <div data-ps="src/pages/use-cases/authentication.astro:challenge-text-2">
                  <h4 class="font-bold text-slate-900 mb-1" data-ps="src/pages/use-cases/authentication.astro:challenge-h-2">Systemic Risks</h4>
                  <p class="text-slate-600 text-sm" data-ps="src/pages/use-cases/authentication.astro:challenge-p-2">Counterfeiting creates revenue leakage, brand dilution, and safety exposure.</p>
                </div>
             </div>
          </div>
        </div>
        <div class="relative" data-ps="src/pages/use-cases/authentication.astro:challenge-right">
          <div class="bg-white p-8 md:p-12 rounded-[2rem] border border-slate-200 shadow-2xl shadow-slate-200/50" data-ps="src/pages/use-cases/authentication.astro:challenge-box">
            <p class="text-2xl text-slate-800 leading-relaxed mb-8 font-medium" data-ps="src/pages/use-cases/authentication.astro:challenge-quote">
              Traditional approaches rely on static codes and non-verifiable markers. Authentication becomes reactive rather than systematic.
            </p>
            <div class="h-px bg-slate-100 mb-8" data-ps="src/pages/use-cases/authentication.astro:challenge-divider"></div>
            <div class="grid gap-6" data-ps="src/pages/use-cases/authentication.astro:challenge-bullets">
              <div class="flex items-start gap-4" data-ps="src/pages/use-cases/authentication.astro:challenge-bullet-1">
                <span class="w-2 h-2 rounded-full bg-blue-600 mt-2.5 shrink-0" data-ps="src/pages/use-cases/authentication.astro:bullet-dot-1"></span>
                <p class="text-slate-600 text-lg" data-ps="src/pages/use-cases/authentication.astro:bullet-text-1">Fragmented portals and serial numbers without validation create customer mistrust.</p>
              </div>
              <div class="flex items-start gap-4" data-ps="src/pages/use-cases/authentication.astro:challenge-bullet-2">
                <span class="w-2 h-2 rounded-full bg-blue-600 mt-2.5 shrink-0" data-ps="src/pages/use-cases/authentication.astro:bullet-dot-2"></span>
                <p class="text-slate-600 text-lg" data-ps="src/pages/use-cases/authentication.astro:bullet-text-2">TieBack supports structured authentication without introducing complexity for consumers.</p>
              </div>
            </div>
          </div>
          <!-- Decorative element -->
          <div class="absolute -bottom-6 -right-6 w-32 h-32 border-b-2 border-r-2 border-blue-100 rounded-br-3xl pointer-events-none" data-ps="src/pages/use-cases/authentication.astro:challenge-deco"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Capabilities Grid (Cloned from Compliance) -->
  <section class="py-32 bg-white" data-ps="src/pages/use-cases/authentication.astro:capabilities">
    <div class="container mx-auto px-6" data-ps="src/pages/use-cases/authentication.astro:capabilities-container">
      <div class="max-w-3xl mb-20" data-ps="src/pages/use-cases/authentication.astro:capabilities-header">
        <span class="text-blue-600 font-bold uppercase tracking-wider text-xs block mb-4" data-ps="src/pages/use-cases/authentication.astro:cap-label">Capabilities</span>
        <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6" data-ps="src/pages/use-cases/authentication.astro:cap-title">Structured verification.</h2>
        <p class="text-slate-600 text-xl leading-relaxed" data-ps="src/pages/use-cases/authentication.astro:cap-subtext">TieBack enables unit-level passports where each item carries a unique, persistent digital identity verifiable through the resolver.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-ps="src/pages/use-cases/authentication.astro:cap-grid">
        <!-- Card 1 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/authentication.astro:cap-card-1">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/authentication.astro:cap-card-deco-1"></div>
          <div class="w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/authentication.astro:cap-icon-1">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/use-cases/authentication.astro:cap-h-1">Item-Level Identity</h3>
          <p class="text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/use-cases/authentication.astro:cap-p-1">Persistent identity that remains verifiable through the resolver—not through visual inspection alone.</p>
          <ul class="space-y-4 text-slate-700 font-medium" data-ps="src/pages/use-cases/authentication.astro:cap-list-1">
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/authentication.astro:cap-li-1-1"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Unique persistent IDs</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/authentication.astro:cap-li-1-2"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Structured lifecycle status</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/authentication.astro:cap-li-1-3"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Full ownership history</li>
          </ul>
        </div>

        <!-- Card 2 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/authentication.astro:cap-card-2">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/authentication.astro:cap-card-deco-2"></div>
          <div class="w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/authentication.astro:cap-icon-2">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/use-cases/authentication.astro:cap-h-2">High-Assurance Mode</h3>
          <p class="text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/use-cases/authentication.astro:cap-p-2">Enhanced assurance for high-risk categories through tamper-resistant anchored records.</p>
          <ul class="space-y-4 text-slate-700 font-medium" data-ps="src/pages/use-cases/authentication.astro:cap-list-2">
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/authentication.astro:cap-li-2-1"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Tamper-resistant records</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/authentication.astro:cap-li-2-2"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> No consumer apps required</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/authentication.astro:cap-li-2-3"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Simple Scan. View. Confirm.</li>
          </ul>
        </div>

        <!-- Card 3 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/authentication.astro:cap-card-3">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/authentication.astro:cap-card-deco-3"></div>
          <div class="w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/authentication.astro:cap-icon-3">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/use-cases/authentication.astro:cap-h-3">Trust Signals</h3>
          <p class="text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/use-cases/authentication.astro:cap-p-3">Real-world signals surfaced operationally to support brand protection workflows without friction.</p>
          <ul class="space-y-4 text-slate-700 font-medium" data-ps="src/pages/use-cases/authentication.astro:cap-list-3">
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/authentication.astro:cap-li-3-1"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Geofence anomaly detection</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/authentication.astro:cap-li-3-2"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Abnormal frequency alerts</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/authentication.astro:cap-li-3-3"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Zero-consumer friction</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Visual Separator Section (Cloned from Compliance) -->
  <section class="py-24 bg-slate-950 text-white relative overflow-hidden" data-ps="src/pages/use-cases/authentication.astro:evidence">
    <div class="absolute inset-0 opacity-30" data-ps="src/pages/use-cases/authentication.astro:evidence-bg">
      <img crossorigin="anonymous"
        src="https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&w=1200&q=80"
        srcset="https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&w=320&q=80 320w, https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&w=640&q=80 640w, https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&w=768&q=80 768w, https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&w=1024&q=80 1024w, https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&w=1280&q=80 1280w, https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&w=1920&q=80 1920w"
        sizes="100vw"
        alt="Cybersecurity data lines" class="w-full h-full object-cover" data-ps="src/pages/use-cases/authentication.astro:evidence-img" />
      <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/80 to-transparent" data-ps="src/pages/use-cases/authentication.astro:evidence-overlay"></div>
    </div>
    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/use-cases/authentication.astro:evidence-container">
      <div class="max-w-5xl mx-auto" data-ps="src/pages/use-cases/authentication.astro:evidence-content">
        <h2 class="text-3xl md:text-5xl font-bold mb-16 text-center" data-ps="src/pages/use-cases/authentication.astro:evidence-title">Measurable protection.</h2>
        <div class="grid lg:grid-cols-2 gap-16 items-center" data-ps="src/pages/use-cases/authentication.astro:evidence-grid">
           <div class="bg-white/5 backdrop-blur-xl p-10 rounded-[2.5rem] border border-white/10 shadow-2xl" data-ps="src/pages/use-cases/authentication.astro:evidence-box">
             <div class="flex items-center gap-4 mb-8" data-ps="src/pages/use-cases/authentication.astro:evidence-label-wrap">
               <div class="w-10 h-10 rounded-xl bg-blue-500/20 flex items-center justify-center" data-ps="src/pages/use-cases/authentication.astro:evidence-icon-box">
                 <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#60a5fa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-fingerprint"><path d="M2 12C2 6.477 6.477 2 12 2s10 4.477 10 10"/><path d="M5 12c0-3.866 3.134-7 7-7s7 3.134 7 7"/><path d="M8 12c0-2.209 1.791-4 4-4s4 1.791 4 4"/><path d="M12 12v9"/><path d="M9 16.5c1.5 1 3 1 4.5 0"/><path d="M12 18h.01"/></svg>
               </div>
               <h4 class="text-blue-400 font-bold uppercase tracking-widest text-xs" data-ps="src/pages/use-cases/authentication.astro:evidence-label">Identity Layer</h4>
             </div>
             <ul class="space-y-6" data-ps="src/pages/use-cases/authentication.astro:evidence-list">
               <li class="flex items-center gap-4 group" data-ps="src/pages/use-cases/authentication.astro:evidence-li-1">
                 <div class="w-2 h-2 rounded-full bg-blue-500 shadow-[0_0_10px_#3b82f6]" data-ps="src/pages/use-cases/authentication.astro:evidence-dot-1"></div>
                 <span class="text-lg font-medium text-slate-200" data-ps="src/pages/use-cases/authentication.astro:evidence-txt-1">Verifiable Product Identity</span>
               </li>
               <li class="flex items-center gap-4 group" data-ps="src/pages/use-cases/authentication.astro:evidence-li-2">
                 <div class="w-2 h-2 rounded-full bg-blue-500 shadow-[0_0_10px_#3b82f6]" data-ps="src/pages/use-cases/authentication.astro:evidence-dot-2"></div>
                 <span class="text-lg font-medium text-slate-200" data-ps="src/pages/use-cases/authentication.astro:evidence-txt-2">Resale Trust Protocols</span>
               </li>
               <li class="flex items-center gap-4 group" data-ps="src/pages/use-cases/authentication.astro:evidence-li-3">
                 <div class="w-2 h-2 rounded-full bg-blue-500 shadow-[0_0_10px_#3b82f6]" data-ps="src/pages/use-cases/authentication.astro:evidence-dot-3"></div>
                 <span class="text-lg font-medium text-slate-200" data-ps="src/pages/use-cases/authentication.astro:evidence-txt-3">Anomaly Escalation Logic</span>
               </li>
             </ul>
           </div>
           <div class="flex flex-col justify-center" data-ps="src/pages/use-cases/authentication.astro:evidence-text">
             <h3 class="text-2xl font-bold mb-6" data-ps="src/pages/use-cases/authentication.astro:evidence-h3">Beyond Authenticity</h3>
             <p class="text-slate-400 text-lg leading-relaxed mb-8" data-ps="src/pages/use-cases/authentication.astro:evidence-p">
               The same identity layer used for compliance becomes the basis for authenticity. Authentication supports warranty validation, resale confidence, and customs checks without parallel systems.
             </p>
             <div class="flex items-center gap-6" data-ps="src/pages/use-cases/authentication.astro:evidence-stats">
                <div data-ps="src/pages/use-cases/authentication.astro:stat-1">
                  <div class="text-3xl font-bold text-blue-400" data-ps="src/pages/use-cases/authentication.astro:stat-val-1">Zero</div>
                  <div class="text-xs uppercase tracking-widest text-slate-400 font-bold" data-ps="src/pages/use-cases/authentication.astro:stat-lbl-1">Consumer Friction</div>
                </div>
                <div class="w-px h-10 bg-white/10" data-ps="src/pages/use-cases/authentication.astro:stat-sep"></div>
                <div data-ps="src/pages/use-cases/authentication.astro:stat-2">
                  <div class="text-3xl font-bold text-blue-400" data-ps="src/pages/use-cases/authentication.astro:stat-val-2">Simple</div>
                  <div class="text-xs uppercase tracking-widest text-slate-400 font-bold" data-ps="src/pages/use-cases/authentication.astro:stat-lbl-2">Verification</div>
                </div>
             </div>
           </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Final CTA (Cloned from Compliance) -->
  <section id="request-access" class="py-32 bg-white relative overflow-hidden" data-ps="src/pages/use-cases/authentication.astro:cta">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_left,_var(--tw-gradient-stops))] from-blue-50/50 via-transparent to-transparent pointer-events-none" data-ps="src/pages/use-cases/authentication.astro:cta-grad"></div>
    <div class="container mx-auto px-6 relative z-10 text-center" data-ps="src/pages/use-cases/authentication.astro:cta-container">
      <div class="max-w-4xl mx-auto" data-ps="src/pages/use-cases/authentication.astro:cta-content">
        <h2 class="text-5xl md:text-6xl font-bold text-slate-900 mb-8 tracking-tight" data-ps="src/pages/use-cases/authentication.astro:cta-h">Identity that <span class="text-blue-600" data-ps="src/pages/use-cases/authentication.astro:cta-blue">proves itself.</span></h2>
        <p class="text-xl text-slate-600 mb-12 max-w-2xl mx-auto leading-relaxed" data-ps="src/pages/use-cases/authentication.astro:cta-p">
          Authenticity without complexity. Verification without friction. Join the brands securing their product integrity with TieBack.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-6" data-ps="src/pages/use-cases/authentication.astro:cta-buttons">
          <button class="w-full sm:w-auto px-12 py-5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-2xl transition-all duration-300 shadow-2xl shadow-blue-200 hover:-translate-y-1" data-ps="src/pages/use-cases/authentication.astro:cta-primary">
            Request Early Access
          </button>
          <a href="/platform/security/" class="group text-slate-900 font-bold flex items-center gap-3 transition-colors hover:text-blue-600" data-ps="src/pages/use-cases/authentication.astro:cta-secondary">
            Platform Security <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from &#x27;@/layouts/BaseLayout.astro&#x27;;
import { SITE } from &#x27;@/config/site&#x27;;

const title = &quot;Authentifizierung &amp; Fälschungsschutz — TieBack&quot;;
const description = &quot;Überprüfbare Produktidentität ohne Reibungsverluste für den Verbraucher. Strukturierte Authentifizierung für Marken, die mit Fälschungen, Umleitungen oder Graumärkten konfrontiert sind.&quot;;
---

<BaseLayout title=<astro-expr id="1">
  description={description}
  &gt;
  <!-- 1. Use Case Hero (Cloned from Compliance) -->
  <section class="relative pt-32 pb-24 md:pt-52 md:pb-40 overflow-hidden bg-white" data-ps="src/pages/use-cases/authentication.astro:hero">
    <!-- Subtle Background Accents -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-7xl pointer-events-none" data-ps="src/pages/use-cases/authentication.astro:bg-accents">
      <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-blue-50/50 blur-[120px]" data-ps="src/pages/use-cases/authentication.astro:accent-1"></div>
      <div class="absolute bottom-[10%] right-[-5%] w-[30%] h-[30%] rounded-full bg-slate-50 blur-[100px]" data-ps="src/pages/use-cases/authentication.astro:accent-2"></div>
    </div>

    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/use-cases/authentication.astro:hero-container">
      <div class="max-w-4xl mx-auto text-center" data-ps="src/pages/use-cases/authentication.astro:hero-content">
        <div class="inline-flex items-center gap-2 py-1 px-3 mb-8 text-[11px] font-bold tracking-widest text-blue-600 uppercase bg-blue-50/80 backdrop-blur-sm border border-blue-100 rounded-full" data-ps="src/pages/use-cases/authentication.astro:eyebrow">
          <span class="w-1.5 h-1.5 rounded-full bg-blue-600 animate-pulse" data-ps="src/pages/use-cases/authentication.astro:pulse"></span>
          Anwendungsfall 07
        </div>
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight text-slate-900 mb-8 leading-[1.05]" data-ps="src/pages/use-cases/authentication.astro:title">
        
          Authentifizierung &amp; <span class="text-blue-600" data-ps="src/pages/use-cases/authentication.astro:title-blue">Fälschungsschutz</span>
        </h1>
        <p class="text-xl md:text-2xl text-slate-600 mb-12 leading-relaxed max-w-2xl mx-auto" data-ps="src/pages/use-cases/authentication.astro:subtext">
          Überprüfbare Produktidentität ohne Reibungsverluste für den Verbraucher. Strukturierte Authentifizierung für Marken, die mit Fälschungen, Umleitungen oder Graumärkten konfrontiert sind.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-5" data-ps="src/pages/use-cases/authentication.astro:buttons">
          <a href="#request-access" class="w-full sm:w-auto px-10 py-4 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl transition-all duration-300 shadow-xl shadow-blue-200 hover:-translate-y-1" data-ps="src/pages/use-cases/authentication.astro:btn-primary">
            Zugriff anfordern
          </a>
          
          <a href="/platform/why-tieback/" class="w-full sm:w-auto px-10 py-4 bg-white border border-slate-200 text-slate-700 font-semibold rounded-xl hover:bg-slate-50 transition-all duration-300 hover:border-slate-300" data-ps="src/pages/use-cases/authentication.astro:btn-secondary">
            Plattformübersicht
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. The Challenge (Cloned from Compliance) -->
  <section class="py-32 bg-slate-50 border-y border-slate-200/60 relative overflow-hidden" data-ps="src/pages/use-cases/authentication.astro:challenge">
    <div class="container mx-auto px-6" data-ps="src/pages/use-cases/authentication.astro:challenge-container">
      <div class="grid lg:grid-cols-2 gap-20 items-center" data-ps="src/pages/use-cases/authentication.astro:challenge-grid">
        <div class="relative" data-ps="src/pages/use-cases/authentication.astro:challenge-left">
          <div class="absolute -top-12 -left-12 w-24 h-24 bg-blue-100/50 rounded-full blur-2xl" data-ps="src/pages/use-cases/authentication.astro:accent-3"></div>
          <h2 class="text-4xl md:text-5xl font-bold text-slate-900 leading-[1.15] relative" data-ps="src/pages/use-cases/authentication.astro:challenge-heading">
            Entwickelt für Marken, die mit <span class="italic font-serif text-blue-600" data-ps="src/pages/use-cases/authentication.astro:challenge-blue">Fälschungen, Umleitungen oder Graumärkten</span> konfrontiert sind.
          </h2>
          <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-1 gap-8" data-ps="src/pages/use-cases/authentication.astro:challenge-list">
             <div class="flex gap-6 group bg-white/50 backdrop-blur-sm p-6 rounded-2xl border border-slate-200 transition-all hover:border-blue-200 hover:shadow-lg hover:shadow-blue-50" data-ps="src/pages/use-cases/authentication.astro:challenge-item-1">
                <div class="w-12 h-12 rounded-xl bg-blue-600 flex items-center justify-center shrink-0 shadow-lg shadow-blue-100" data-ps="src/pages/use-cases/authentication.astro:challenge-icon-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-alert"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
                </div>
                <div data-ps="src/pages/use-cases/authentication.astro:challenge-text-1">
                  <h4 class="font-bold text-slate-900 mb-1" data-ps="src/pages/use-cases/authentication.astro:challenge-h-1">Echtheit ist entscheidend</h4>
                  <p class="text-slate-600 text-sm" data-ps="src/pages/use-cases/authentication.astro:challenge-p-1">Bei Luxusgütern, Premium-Bekleidung und Elektronik muss die Identität nachprüfbar sein, nicht nur angenommen werden.</p>
                </div>
             </div>
             <div class="flex gap-6 group bg-white/50 backdrop-blur-sm p-6 rounded-2xl border border-slate-200 transition-all hover:border-blue-200 hover:shadow-lg hover:shadow-blue-50" data-ps="src/pages/use-cases/authentication.astro:challenge-item-2">
                <div class="w-12 h-12 rounded-xl bg-blue-600 flex items-center justify-center shrink-0 shadow-lg shadow-blue-100" data-ps="src/pages/use-cases/authentication.astro:challenge-icon-2">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-alert-octagon"><polygon points="7.86 2 16.14 2 22 7.86 22 16.14 16.14 22 7.86 22 2 16.14 2 7.86 7.86 2"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                </div>
                <div data-ps="src/pages/use-cases/authentication.astro:challenge-text-2">
                  <h4 class="font-bold text-slate-900 mb-1" data-ps="src/pages/use-cases/authentication.astro:challenge-h-2">Systemische Risiken</h4>
                  <p class="text-slate-600 text-sm" data-ps="src/pages/use-cases/authentication.astro:challenge-p-2">Fälschungen führen zu Umsatzverlusten, Markenverwässerung und Sicherheitsrisiken.</p>
                </div>
             </div>
          </div>
        </div>
        <div class="relative" data-ps="src/pages/use-cases/authentication.astro:challenge-right">
          <div class="bg-white p-8 md:p-12 rounded-[2rem] border border-slate-200 shadow-2xl shadow-slate-200/50" data-ps="src/pages/use-cases/authentication.astro:challenge-box">
            <p class="text-2xl text-slate-800 leading-relaxed mb-8 font-medium" data-ps="src/pages/use-cases/authentication.astro:challenge-quote">
              Herkömmliche Ansätze stützen sich auf statische Codes und nicht überprüfbare Kennzeichnungen. Die Authentifizierung erfolgt eher reaktiv als systematisch.
            </p>
            <div class="h-px bg-slate-100 mb-8" data-ps="src/pages/use-cases/authentication.astro:challenge-divider"></div>
            <div class="grid gap-6" data-ps="src/pages/use-cases/authentication.astro:challenge-bullets">
              <div class="flex items-start gap-4" data-ps="src/pages/use-cases/authentication.astro:challenge-bullet-1">
                <span class="w-2 h-2 rounded-full bg-blue-600 mt-2.5 shrink-0" data-ps="src/pages/use-cases/authentication.astro:bullet-dot-1"></span>
                <p class="text-slate-600 text-lg" data-ps="src/pages/use-cases/authentication.astro:bullet-text-1">Fragmentierte Portale und Seriennummern ohne Validierung führen zu Misstrauen bei den Kunden.</p>
              </div>
              <div class="flex items-start gap-4" data-ps="src/pages/use-cases/authentication.astro:challenge-bullet-2">
                <span class="w-2 h-2 rounded-full bg-blue-600 mt-2.5 shrink-0" data-ps="src/pages/use-cases/authentication.astro:bullet-dot-2"></span>
                <p class="text-slate-600 text-lg" data-ps="src/pages/use-cases/authentication.astro:bullet-text-2">TieBack unterstützt eine strukturierte Authentifizierung, ohne den Verbrauchern zusätzliche Komplexität zu verursachen.</p>
              </div>
            </div>
          </div>
          <!-- Decorative element -->
          <div class="absolute -bottom-6 -right-6 w-32 h-32 border-b-2 border-r-2 border-blue-100 rounded-br-3xl pointer-events-none" data-ps="src/pages/use-cases/authentication.astro:challenge-deco"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Capabilities Grid (Cloned from Compliance) -->
  <section class="py-32 bg-white" data-ps="src/pages/use-cases/authentication.astro:capabilities">
    <div class="container mx-auto px-6" data-ps="src/pages/use-cases/authentication.astro:capabilities-container">
      <div class="max-w-3xl mb-20" data-ps="src/pages/use-cases/authentication.astro:capabilities-header">
        <span class="text-blue-600 font-bold uppercase tracking-wider text-xs block mb-4" data-ps="src/pages/use-cases/authentication.astro:cap-label">Funktionen</span>
        <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6" data-ps="src/pages/use-cases/authentication.astro:cap-title">Strukturierte Verifizierung.</h2>
        <p class="text-slate-600 text-xl leading-relaxed" data-ps="src/pages/use-cases/authentication.astro:cap-subtext">TieBack ermöglicht Passports auf Artikelebene, bei denen jeder Artikel eine eindeutige, dauerhafte digitale Identität trägt, die über den Resolver verifiziert werden kann.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-ps="src/pages/use-cases/authentication.astro:cap-grid">
        <!-- Card 1 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/authentication.astro:cap-card-1">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/authentication.astro:cap-card-deco-1"></div>
          <div class="w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/authentication.astro:cap-icon-1">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/use-cases/authentication.astro:cap-h-1">Identität auf Artikelebene</h3>
          <p class="text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/use-cases/authentication.astro:cap-p-1">Dauerhafte Identität, die über den Resolver verifizierbar bleibt – nicht nur durch visuelle Inspektion.</p>
          <ul class="space-y-4 text-slate-700 font-medium" data-ps="src/pages/use-cases/authentication.astro:cap-list-1">
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/authentication.astro:cap-li-1-1"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Eindeutige, dauerhafte IDs</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/authentication.astro:cap-li-1-2"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Strukturierter Lebenszyklusstatus</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/authentication.astro:cap-li-1-3"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Vollständige Eigentumsgeschichte</li>
          </ul>
        </div>

        <!-- Card 2 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/authentication.astro:cap-card-2">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/authentication.astro:cap-card-deco-2"></div>
          <div class="w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/authentication.astro:cap-icon-2">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/use-cases/authentication.astro:cap-h-2">Hochsicherheitsmodus</h3>
          <p class="text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/use-cases/authentication.astro:cap-p-2">Erhöhte Sicherheit für risikoreiche Kategorien durch manipulationssichere, verankerte Datensätze.</p>
          <ul class="space-y-4 text-slate-700 font-medium" data-ps="src/pages/use-cases/authentication.astro:cap-list-2">
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/authentication.astro:cap-li-2-1"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Manipulationssichere Datensätze</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/authentication.astro:cap-li-2-2"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Keine Verbraucher-Apps erforderlich</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/authentication.astro:cap-li-2-3"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Einfach scannen. Anzeigen. Bestätigen.</li>
          </ul>
        </div>

        <!-- Card 3 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/authentication.astro:cap-card-3">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/authentication.astro:cap-card-deco-3"></div>
          <div class="w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/authentication.astro:cap-icon-3">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/use-cases/authentication.astro:cap-h-3">Vertrauenssignale</h3>
          <p class="text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/use-cases/authentication.astro:cap-p-3">Signale aus der realen Welt werden operativ sichtbar gemacht, um Workflows zum Markenschutz reibungslos zu unterstützen.</p>
          <ul class="space-y-4 text-slate-700 font-medium" data-ps="src/pages/use-cases/authentication.astro:cap-list-3">
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/authentication.astro:cap-li-3-1"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Erkennung von Geofence-Anomalien</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/authentication.astro:cap-li-3-2"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Warnmeldungen bei ungewöhnlicher Häufigkeit</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/authentication.astro:cap-li-3-3"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Keine Beeinträchtigung für den Verbraucher</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Visual Separator Section (Cloned from Compliance) -->
  <section class="py-24 bg-slate-950 text-white relative overflow-hidden" data-ps="src/pages/use-cases/authentication.astro:evidence">
    <div class="absolute inset-0 opacity-30" data-ps="src/pages/use-cases/authentication.astro:evidence-bg">
      <img crossorigin="anonymous"
        src="https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&w=1200&q=80"
        srcset="https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&w=320&q=80 320w, https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&w=640&q=80 640w, https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&w=768&q=80 768w, https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&w=1024&q=80 1024w, https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&w=1280&q=80 1280w, https://images.unsplash.com/photo-1550751827-4bd374c3f58b?auto=format&w=1920&q=80 1920w"
        sizes="100vw"
        alt="Cybersecurity data lines" class="w-full h-full object-cover" data-ps="src/pages/use-cases/authentication.astro:evidence-img" />
      <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/80 to-transparent" data-ps="src/pages/use-cases/authentication.astro:evidence-overlay"></div>
    </div>
    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/use-cases/authentication.astro:evidence-container">
      <div class="max-w-5xl mx-auto" data-ps="src/pages/use-cases/authentication.astro:evidence-content">
        <h2 class="text-3xl md:text-5xl font-bold mb-16 text-center" data-ps="src/pages/use-cases/authentication.astro:evidence-title">Messbarer Schutz.</h2>
        <div class="grid lg:grid-cols-2 gap-16 items-center" data-ps="src/pages/use-cases/authentication.astro:evidence-grid">
           <div class="bg-white/5 backdrop-blur-xl p-10 rounded-[2.5rem] border border-white/10 shadow-2xl" data-ps="src/pages/use-cases/authentication.astro:evidence-box">
             <div class="flex items-center gap-4 mb-8" data-ps="src/pages/use-cases/authentication.astro:evidence-label-wrap">
               <div class="w-10 h-10 rounded-xl bg-blue-500/20 flex items-center justify-center" data-ps="src/pages/use-cases/authentication.astro:evidence-icon-box">
                 <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#60a5fa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-fingerprint"><path d="M2 12C2 6.477 6.477 2 12 2s10 4.477 10 10"/><path d="M5 12c0-3.866 3.134-7 7-7s7 3.134 7 7"/><path d="M8 12c0-2.209 1.791-4 4-4s4 1.791 4 4"/><path d="M12 12v9"/><path d="M9 16.5c1.5 1 3 1 4.5 0"/><path d="M12 18h.01"/></svg>
               </div>
               <h4 class="text-blue-400 font-bold uppercase tracking-widest text-xs" data-ps="src/pages/use-cases/authentication.astro:evidence-label">Identitätsschicht</h4>
             </div>
             <ul class="space-y-6" data-ps="src/pages/use-cases/authentication.astro:evidence-list">
               <li class="flex items-center gap-4 group" data-ps="src/pages/use-cases/authentication.astro:evidence-li-1">
                 <div class="w-2 h-2 rounded-full bg-blue-500 shadow-[0_0_10px_#3b82f6]" data-ps="src/pages/use-cases/authentication.astro:evidence-dot-1"></div>
                 <span class="text-lg font-medium text-slate-200" data-ps="src/pages/use-cases/authentication.astro:evidence-txt-1">Überprüfbare Produktidentität</span>
               </li>
               <li class="flex items-center gap-4 group" data-ps="src/pages/use-cases/authentication.astro:evidence-li-2">
                 <div class="w-2 h-2 rounded-full bg-blue-500 shadow-[0_0_10px_#3b82f6]" data-ps="src/pages/use-cases/authentication.astro:evidence-dot-2"></div>
                 <span class="text-lg font-medium text-slate-200" data-ps="src/pages/use-cases/authentication.astro:evidence-txt-2">Protokolle für vertrauenswürdigen Wiederverkauf</span>
               </li>
               <li class="flex items-center gap-4 group" data-ps="src/pages/use-cases/authentication.astro:evidence-li-3">
                 <div class="w-2 h-2 rounded-full bg-blue-500 shadow-[0_0_10px_#3b82f6]" data-ps="src/pages/use-cases/authentication.astro:evidence-dot-3"></div>
                 <span class="text-lg font-medium text-slate-200" data-ps="src/pages/use-cases/authentication.astro:evidence-txt-3">Logik zur Eskalation von Anomalien</span>
               </li>
             </ul>
           </div>
           <div class="flex flex-col justify-center" data-ps="src/pages/use-cases/authentication.astro:evidence-text">
             <h3 class="text-2xl font-bold mb-6" data-ps="src/pages/use-cases/authentication.astro:evidence-h3">Mehr als nur Authentizität</h3>
             <p class="text-slate-400 text-lg leading-relaxed mb-8" data-ps="src/pages/use-cases/authentication.astro:evidence-p">
               Die gleiche Identitätsschicht, die für die Compliance genutzt wird, bildet die Grundlage für die Authentizität. Die Authentifizierung unterstützt die Garantieüberprüfung, das Vertrauen beim Wiederverkauf und Zollkontrollen ohne parallele Systeme.
             </p>
             <div class="flex items-center gap-6" data-ps="src/pages/use-cases/authentication.astro:evidence-stats">
                <div data-ps="src/pages/use-cases/authentication.astro:stat-1">
                  <div class="text-3xl font-bold text-blue-400" data-ps="src/pages/use-cases/authentication.astro:stat-val-1">Null</div>
                  <div class="text-xs uppercase tracking-widest text-slate-400 font-bold" data-ps="src/pages/use-cases/authentication.astro:stat-lbl-1">Reibungsverluste</div>
                </div>
                <div class="w-px h-10 bg-white/10" data-ps="src/pages/use-cases/authentication.astro:stat-sep"></div>
                <div data-ps="src/pages/use-cases/authentication.astro:stat-2">
                  <div class="text-3xl font-bold text-blue-400" data-ps="src/pages/use-cases/authentication.astro:stat-val-2">Einfache</div>
                  <div class="text-xs uppercase tracking-widest text-slate-400 font-bold" data-ps="src/pages/use-cases/authentication.astro:stat-lbl-2">Verifizierung</div>
                </div>
             </div>
           </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Final CTA (Cloned from Compliance) -->
  <section id="request-access" class="py-32 bg-white relative overflow-hidden" data-ps="src/pages/use-cases/authentication.astro:cta">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_left,_var(--tw-gradient-stops))] from-blue-50/50 via-transparent to-transparent pointer-events-none" data-ps="src/pages/use-cases/authentication.astro:cta-grad"></div>
    <div class="container mx-auto px-6 relative z-10 text-center" data-ps="src/pages/use-cases/authentication.astro:cta-container">
      <div class="max-w-4xl mx-auto" data-ps="src/pages/use-cases/authentication.astro:cta-content">
        <h2 class="text-5xl md:text-6xl font-bold text-slate-900 mb-8 tracking-tight" data-ps="src/pages/use-cases/authentication.astro:cta-h">Identität, die <span class="text-blue-600" data-ps="src/pages/use-cases/authentication.astro:cta-blue">sich selbst beweist.</span></h2>
        <p class="text-xl text-slate-600 mb-12 max-w-2xl mx-auto leading-relaxed" data-ps="src/pages/use-cases/authentication.astro:cta-p">
          Authentizität ohne Komplexität. Verifizierung ohne Reibungsverluste. Schließen Sie sich den Marken an, die ihre Produktintegrität mit „TieBack“ sichern.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-6" data-ps="src/pages/use-cases/authentication.astro:cta-buttons">
          <button class="w-full sm:w-auto px-12 py-5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-2xl transition-all duration-300 shadow-2xl shadow-blue-200 hover:-translate-y-1" data-ps="src/pages/use-cases/authentication.astro:cta-primary">
            Frühzugang beantragen
          </button>
          <a href="/platform/security/" class="group text-slate-900 font-bold flex items-center gap-3 transition-colors hover:text-blue-600" data-ps="src/pages/use-cases/authentication.astro:cta-secondary">
          
            Plattform-Sicherheit<svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
,---
import BaseLayout aus &#x27;@/layouts/BaseLayout.astro&#x27;;
import { SITE } aus &#x27;@/config/site&#x27;;

const title = &quot;Authentifizierung &amp; Fälschungsschutz — TieBack&quot;;
const description = &quot;Überprüfbare Produktidentität ohne Reibungsverluste für den Verbraucher. Strukturierte Authentifizierung für Marken, die mit Fälschungen, Umleitungen oder Graumärkten konfrontiert sind.&quot;;
---
,<BaseLayout title=<astro-expr id="4">
  description={description}
  &gt;
  <!-- 1. Use Case Hero (Cloned from Compliance) -->
  <section class="relative pt-32 pb-24 md:pt-52 md:pb-40 overflow-hidden bg-white" data-ps="src/pages/use-cases/authentication.astro:hero">
    <!-- Subtle Background Accents -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-7xl pointer-events-none" data-ps="src/pages/use-cases/authentication.astro:bg-accents">
      <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-blue-50/50 blur-[120px]" data-ps="src/pages/use-cases/authentication.astro:accent-1"></div>
      <div class="absolute bottom-[10%] right-[-5%] w-[30%] h-[30%] rounded-full bg-slate-50 blur-[100px]" data-ps="src/pages/use-cases/authentication.astro:accent-2"></div>
    </div>

    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/use-cases/authentication.astro:hero-container">
      <div class="max-w-4xl mx-auto text-center" data-ps="src/pages/use-cases/authentication.astro:hero-content">
        <div class="inline-flex items-center gap-2 py-1 px-3 mb-8 text-[11px] font-bold tracking-widest text-blue-600 uppercase bg-blue-50/80 backdrop-blur-sm border border-blue-100 rounded-full" data-ps="src/pages/use-cases/authentication.astro:eyebrow">
          <span class="w-1.5 h-1.5 rounded-full bg-blue-600 animate-pulse" data-ps="src/pages/use-cases/authentication.astro:pulse"></span>
          Anwendungsfall 07
        </div>
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight text-slate-900 mb-8 leading-[1.05]" data-ps="src/pages/use-cases/authentication.astro:title">
        
          Authentifizierung &amp; <span class="text-blue-600" data-ps="src/pages/use-cases/authentication.astro:title-blue">Fälschungsschutz</span>
        </h1>
        <p class="text-xl md:text-2xl text-slate-600 mb-12 leading-relaxed max-w-2xl mx-auto" data-ps="src/pages/use-cases/authentication.astro:subtext">
          Überprüfbare Produktidentität ohne Reibungsverluste für den Verbraucher. Strukturierte Authentifizierung für Marken, die mit Fälschungen, Umleitungen oder Graumärkten konfrontiert sind.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-5" data-ps="src/pages/use-cases/authentication.astro:buttons">
          <a href="#request-access" class="w-full sm:w-auto px-10 py-4 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl transition-all duration-300 shadow-xl shadow-blue-200 hover:-translate-y-1" data-ps="src/pages/use-cases/authentication.astro:btn-primary">
            Zugang anfordern
          </a>
          
          <a href="/platform/why-tieback/" class="w-full sm:w-auto px-10 py-4 bg-white border border-slate-200 text-slate-700 font-semibold rounded-xl hover:bg-slate-50 transition-all duration-300 hover:border-slate-300" data-ps="src/pages/use-cases/authentication.astro:btn-secondary">
            Plattformübersicht
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. The Challenge (Cloned from Compliance) -->
  <section class="py-32 bg-slate-50 border-y border-slate-200/60 relative overflow-hidden" data-ps="src/pages/use-cases/authentication.astro:challenge">
    <div class="container mx-auto px-6" data-ps="src/pages/use-cases/authentication.astro:challenge-container">
      <div class="grid lg:grid-cols-2 gap-20 items-center" data-ps="src/pages/use-cases/authentication.astro:challenge-grid">
        <div class="relative" data-ps="src/pages/use-cases/authentication.astro:challenge-left">
          <div class="absolute -top-12 -left-12 w-24 h-24 bg-blue-100/50 rounded-full blur-2xl" data-ps="src/pages/use-cases/authentication.astro:accent-3"></div>
          <h2 class="text-4xl md:text-5xl font-bold text-slate-900 leading-[1.15] relative" data-ps="src/pages/use-cases/authentication.astro:challenge-heading">
            Entwickelt für Marken, die mit <span class="italic font-serif text-blue-600" data-ps="src/pages/use-cases/authentication.astro:challenge-blue">Fälschungen, Umleitungen oder Graumärkten</span> konfrontiert sind.
          </h2>
          <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-1 gap-8" data-ps="src/pages/use-cases/authentication.astro:challenge-list">
             <div class="flex gap-6 group bg-white/50 backdrop-blur-sm p-6 rounded-2xl border border-slate-200 transition-all hover:border-blue-200 hover:shadow-lg hover:shadow-blue-50" data-ps="src/pages/use-cases/authentication.astro:challenge-item-1">
                <div class="w-12 h-12 rounded-xl bg-blue-600 flex items-center justify-center shrink-0 shadow-lg shadow-blue-100" data-ps="src/pages/use-cases/authentication.astro:challenge-icon-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-alert"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
                </div>
                <div data-ps="src/pages/use-cases/authentication.astro:challenge-text-1">
                  <h4 class="font-bold text-slate-900 mb-1" data-ps="src/pages/use-cases/authentication.astro:challenge-h-1">Echtheit ist entscheidend</h4>
                  <p class="text-slate-600 text-sm" data-ps="src/pages/use-cases/authentication.astro:challenge-p-1">Bei Luxusgütern, Premium-Bekleidung und Elektronik muss die Identität nachprüfbar sein, nicht nur angenommen werden.</p>
                </div>
             </div>
             <div class="flex gap-6 group bg-white/50 backdrop-blur-sm p-6 rounded-2xl border border-slate-200 transition-all hover:border-blue-200 hover:shadow-lg hover:shadow-blue-50" data-ps="src/pages/use-cases/authentication.astro:challenge-item-2">
                <div class="w-12 h-12 rounded-xl bg-blue-600 flex items-center justify-center shrink-0 shadow-lg shadow-blue-100" data-ps="src/pages/use-cases/authentication.astro:challenge-icon-2">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-alert-octagon"><polygon points="7.86 2 16.14 2 22 7.86 22 16.14 16.14 22 7.86 22 2 16.14 2 7.86 7.86 2"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                </div>
                <div data-ps="src/pages/use-cases/authentication.astro:challenge-text-2">
                  <h4 class="font-bold text-slate-900 mb-1" data-ps="src/pages/use-cases/authentication.astro:challenge-h-2">Systemische Risiken</h4>
                  <p class="text-slate-600 text-sm" data-ps="src/pages/use-cases/authentication.astro:challenge-p-2">Fälschungen führen zu Umsatzverlusten, Markenverwässerung und Sicherheitsrisiken.</p>
                </div>
             </div>
          </div>
        </div>
        <div class="relative" data-ps="src/pages/use-cases/authentication.astro:challenge-right">
          <div class="bg-white p-8 md:p-12 rounded-[2rem] border border-slate-200 shadow-2xl shadow-slate-200/50" data-ps="src/pages/use-cases/authentication.astro:challenge-box">
            <p class="text-2xl text-slate-800 leading-relaxed mb-8 font-medium" data-ps="src/pages/use-cases/authentication.astro:challenge-quote">
              Herkömmliche Ansätze stützen sich auf statische Codes und nicht überprüfbare Kennzeichnungen. Die Authentifizierung erfolgt eher reaktiv als systematisch.
            </p>
            <div class="h-px bg-slate-100 mb-8" data-ps="src/pages/use-cases/authentication.astro:challenge-divider"></div>
            <div class="grid gap-6" data-ps="src/pages/use-cases/authentication.astro:challenge-bullets">
              <div class="flex items-start gap-4" data-ps="src/pages/use-cases/authentication.astro:challenge-bullet-1">
                <span class="w-2 h-2 rounded-full bg-blue-600 mt-2.5 shrink-0" data-ps="src/pages/use-cases/authentication.astro:bullet-dot-1"></span>
                <p class="text-slate-600 text-lg" data-ps="src/pages/use-cases/authentication.astro:bullet-text-1">Fragmentierte Portale und Seriennummern ohne Validierung führen zu Misstrauen bei den Kunden.</p>
              </div>
              <div class="flex items-start gap-4" data-ps="src/pages/use-cases/authentication.astro:challenge-bullet-2">
                <span class="w-2 h-2 rounded-full bg-blue-600 mt-2.5 shrink-0" data-ps="src/pages/use-cases/authentication.astro:bullet-dot-2"></span>
                <p class="text-slate-600 text-lg" data-ps="src/pages/use-cases/authentication.astro:bullet-text-2">TieBack unterstützt eine strukturierte Authentifizierung, ohne den Verbrauchern zusätzliche Komplexität zu verursachen.</p>
              </div>
            </div>
          </div>
          <!-- Decorative element -->
          <div class="absolute -bottom-6 -right-6 w-32 h-32 border-b-2 border-r-2 border-blue-100 rounded-br-3xl pointer-events-none" data-ps="src/pages/use-cases/authentication.astro:challenge-deco"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Capabilities Grid (Cloned from Compliance) -->
  <section class="py-32 bg-white" data-ps="src/pages/use-cases/authentication.astro:capabilities">
    <div class="container mx-auto px-6" data-ps="src/pages/use-cases/authentication.astro:capabilities-container">
      <div class="max-w-3xl mb-20" data-ps="src/pages/use-cases/authentication.astro:capabilities-header">
        <span class="text-blue-600 font-bold uppercase tracking-wider text-xs block mb-4" data-ps="src/pages/use-cases/authentication.astro:cap-label">Funktionen</span>
        <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6" data-ps="src/pages/use-cases/authentication.astro:cap-title">Strukturierte Verifizierung.</h2>
        <p class="text-slate-600 text-xl leading-relaxed" data-ps="src/pages/use-cases/authentication.astro:cap-subtext">TieBack ermöglicht Passports auf Artikelebene, bei denen jeder Artikel eine eindeutige, dauerhafte digitale Identität trägt, die über den Resolver verifiziert werden kann.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-ps="src/pages/use-cases/authentication.astro:cap-grid">
        <!-- Card 1 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/authentication.astro:cap-card-1">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/authentication.astro:cap-card-deco-1"></div>
          <div class="w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/authentication.astro:cap-icon-1">
