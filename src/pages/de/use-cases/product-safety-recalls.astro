---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/config/site';

const title = "Product Safety & Recalls — TieBack";
const description = "TieBack structures safety communication with precision — targeted passport updates, time-bound messaging, and ownership-aware notification.";
---






<baselayout title="{title}" description="{description}">
  <!-- 1. Use Case Hero (Enhanced with Depth) -->
  <section class="relative pt-32 pb-24 md:pt-52 md:pb-40 overflow-hidden bg-white" data-ps="src/pages/use-cases/product-safety-recalls.astro:cloe6q">
    <!-- Subtle Background Accents -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-7xl pointer-events-none" data-ps="src/pages/use-cases/product-safety-recalls.astro:bg-accents">
      <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-blue-50/50 blur-[120px]" data-ps="src/pages/use-cases/product-safety-recalls.astro:accent-1"></div>
      <div class="absolute bottom-[10%] right-[-5%] w-[30%] h-[30%] rounded-full bg-slate-50 blur-[100px]" data-ps="src/pages/use-cases/product-safety-recalls.astro:accent-2"></div>
    </div>
</section></baselayout>


    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/use-cases/product-safety-recalls.astro:6g628h">
      <div class="max-w-4xl mx-auto text-center" data-ps="src/pages/use-cases/product-safety-recalls.astro:6g627v">
        <div class="inline-flex items-center gap-2 py-1 px-3 mb-8 text-[11px] font-bold tracking-widest text-blue-600 uppercase bg-blue-50/80 backdrop-blur-sm border border-blue-100 rounded-full" data-ps="src/pages/use-cases/product-safety-recalls.astro:771h9b">
          <span class="w-1.5 h-1.5 rounded-full bg-blue-600 animate-pulse" data-ps="src/pages/use-cases/product-safety-recalls.astro:9eb0t6"></span>
          Fall 06
        </div>
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight text-slate-900 mb-8 leading-[1.05]" data-ps="src/pages/use-cases/product-safety-recalls.astro:jg65d">
        
          Produktsicherheit <span class="text-blue-600" data-ps="src/pages/use-cases/product-safety-recalls.astro:9eb0t5">& Rückrufe</span>
        </h1>
        <p class="text-xl md:text-2xl text-slate-600 mb-12 leading-relaxed max-w-2xl mx-auto" data-ps="src/pages/use-cases/product-safety-recalls.astro:8k945v">
          Risiken präzise kommunizieren. „TieBack“ gestaltet die Schnittstelle zwischen Produkt und Besitzer für entscheidende Momente.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-5" data-ps="src/pages/use-cases/product-safety-recalls.astro:6g627u">
          <a href="#request-access" class="w-full sm:w-auto px-10 py-4 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl transition-all duration-300 shadow-xl shadow-blue-200 hover:-translate-y-1" data-ps="src/pages/use-cases/product-safety-recalls.astro:1gb7hr">
            Zugang beantragen
          </a>
          
          <a href="/platform/why-tieback/" class="w-full sm:w-auto px-10 py-4 bg-white border border-slate-200 text-slate-700 font-semibold rounded-xl hover:bg-slate-50 transition-all duration-300 hover:border-slate-300" data-ps="src/pages/use-cases/product-safety-recalls.astro:1gb7hq">
            Plattformübersicht
          </a>
        </div>
      </div>
    </div>
  



  <!-- 2. The Challenge (Impactful Layout) -->
  <section class="py-32 bg-slate-50 border-y border-slate-200/60 relative overflow-hidden" data-ps="src/pages/use-cases/product-safety-recalls.astro:cloe6r">
    <div class="container mx-auto px-6" data-ps="src/pages/use-cases/product-safety-recalls.astro:6g627t">
      <div class="grid lg:grid-cols-2 gap-20 items-center" data-ps="src/pages/use-cases/product-safety-recalls.astro:6g627s">
        <div class="relative" data-ps="src/pages/use-cases/product-safety-recalls.astro:6g627r">
          <div class="absolute -top-12 -left-12 w-24 h-24 bg-blue-100/50 rounded-full blur-2xl" data-ps="src/pages/use-cases/product-safety-recalls.astro:accent-3"></div>
          <h2 class="text-4xl md:text-5xl font-bold text-slate-900 leading-[1.15] relative" data-ps="src/pages/use-cases/product-safety-recalls.astro:e4yr2w">
            Rückrufprozesse, die sich durch <span class="italic font-serif text-blue-600" data-ps="src/pages/use-cases/product-safety-recalls.astro:9eb0t4">Präzision</span> und nicht durch Umfang auszeichnen.
          </h2>
          <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-1 gap-8" data-ps="src/pages/use-cases/product-safety-recalls.astro:list-wrapper">
             <div class="flex gap-6 group bg-white/50 backdrop-blur-sm p-6 rounded-2xl border border-slate-200 transition-all hover:border-blue-200 hover:shadow-lg hover:shadow-blue-50" data-ps="src/pages/use-cases/product-safety-recalls.astro:list-item-1">
                <div class="w-12 h-12 rounded-xl bg-blue-600 flex items-center justify-center shrink-0 shadow-lg shadow-blue-100" data-ps="src/pages/use-cases/product-safety-recalls.astro:icon-box-1">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-alert-triangle"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3ZM12 9v4"/><path d="M12 17h.01"/></svg>
                </div>
                <div data-ps="src/pages/use-cases/product-safety-recalls.astro:8ygl37">
                  <h4 class="font-bold text-slate-900 mb-1" data-ps="src/pages/use-cases/product-safety-recalls.astro:list-h-1">Unmittelbare Auswirkungen</h4>
                  <p class="text-slate-600 text-sm" data-ps="src/pages/use-cases/product-safety-recalls.astro:list-p-1">Wenn Sicherheitsprobleme auftreten, bestimmt die Reaktion das Vertrauen in die Marke und die Verantwortlichkeit.</p>
                </div>
             </div>
             <div class="flex gap-6 group bg-white/50 backdrop-blur-sm p-6 rounded-2xl border border-slate-200 transition-all hover:border-blue-200 hover:shadow-lg hover:shadow-blue-50" data-ps="src/pages/use-cases/product-safety-recalls.astro:list-item-2">
                <div class="w-12 h-12 rounded-xl bg-blue-600 flex items-center justify-center shrink-0 shadow-lg shadow-blue-100" data-ps="src/pages/use-cases/product-safety-recalls.astro:icon-box-2">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-crosshair"><circle cx="12" cy="12" r="10"/><line x1="22" y1="12" x2="18" y2="12"/><line x1="6" y1="12" x2="2" y2="12"/><line x1="12" y1="6" x2="12" y2="2"/><line x1="12" y1="22" x2="12" y2="18"/></svg>
                </div>
                <div data-ps="src/pages/use-cases/product-safety-recalls.astro:8ygl38">
                  <h4 class="font-bold text-slate-900 mb-1" data-ps="src/pages/use-cases/product-safety-recalls.astro:list-h-2">Gezielte Reaktion</h4>
                  <p class="text-slate-600 text-sm" data-ps="src/pages/use-cases/product-safety-recalls.astro:list-p-2">Identifizieren Sie betroffene Einheiten präzise, um unnötige Beunruhigung zu minimieren.</p>
                </div>
             </div>
          </div>
        </div>
        <div class="relative" data-ps="src/pages/use-cases/product-safety-recalls.astro:6g627q">
          <div class="bg-white p-8 md:p-12 rounded-[2rem] border border-slate-200 shadow-2xl shadow-slate-200/50" data-ps="src/pages/use-cases/product-safety-recalls.astro:6g627p">
            <p class="text-2xl text-slate-800 leading-relaxed mb-8 font-medium" data-ps="src/pages/use-cases/product-safety-recalls.astro:8k945u">
              Geschwindigkeit ist wichtig. Klarheit ist noch wichtiger.
            </p>
            <div class="h-px bg-slate-100 mb-8" data-ps="src/pages/use-cases/product-safety-recalls.astro:divider"></div>
            <div class="grid gap-6" data-ps="src/pages/use-cases/product-safety-recalls.astro:grid-info">
              <div class="flex items-start gap-4" data-ps="src/pages/use-cases/product-safety-recalls.astro:ddzuom">
                <span class="w-2 h-2 rounded-full bg-blue-600 mt-2.5 shrink-0" data-ps="src/pages/use-cases/product-safety-recalls.astro:771h98"></span>
                <p class="text-slate-600 text-lg" data-ps="src/pages/use-cases/product-safety-recalls.astro:771h98_p">Unternehmen müssen klar kommunizieren und gleichzeitig Prüfungsnachweise für behördliche Überprüfungen aufbewahren.</p>
              </div>
              <div class="flex items-start gap-4" data-ps="src/pages/use-cases/product-safety-recalls.astro:ddzuol">
                <span class="w-2 h-2 rounded-full bg-blue-600 mt-2.5 shrink-0" data-ps="src/pages/use-cases/product-safety-recalls.astro:771h97"></span>
                <p class="text-slate-600 text-lg" data-ps="src/pages/use-cases/product-safety-recalls.astro:771h97_p">TieBack ersetzt pauschale, ungenaue Benachrichtigungen durch gezielte, verantwortungsbewusste Kommunikation.</p>
              </div>
            </div>
          </div>
          <!-- Decorative element -->
          <div class="absolute -bottom-6 -right-6 w-32 h-32 border-b-2 border-r-2 border-blue-100 rounded-br-3xl pointer-events-none" data-ps="src/pages/use-cases/product-safety-recalls.astro:deco-corner"></div>
        </div>
      </div>
    </div>
  </section>



  <!-- 3. The Solution / Capabilities (3-Column Card Grid) -->
  <section class="py-32 bg-white" data-ps="src/pages/use-cases/product-safety-recalls.astro:cloe6s">
    <div class="container mx-auto px-6" data-ps="src/pages/use-cases/product-safety-recalls.astro:6g627o">
      <div class="max-w-3xl mb-20" data-ps="src/pages/use-cases/product-safety-recalls.astro:6g627n">
        <span class="text-blue-600 font-bold uppercase tracking-wider text-xs block mb-4" data-ps="src/pages/use-cases/product-safety-recalls.astro:label">Funktionen</span>
        <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6" data-ps="src/pages/use-cases/product-safety-recalls.astro:e4yr2a">Kontrolle, wenn es darauf ankommt.</h2>
        <p class="text-slate-600 text-xl leading-relaxed" data-ps="src/pages/use-cases/product-safety-recalls.astro:8k945t">Sicherheitsmaßnahmen werden strukturiert statt improvisiert, sodass Marken Ereignisse mit gelassener Effizienz bewältigen können.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-ps="src/pages/use-cases/product-safety-recalls.astro:6g627m">
        <!-- Card 1 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/product-safety-recalls.astro:6g6270">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/product-safety-recalls.astro:card-deco-1"></div>
          <div class="w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/product-safety-recalls.astro:6g626z">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/use-cases/product-safety-recalls.astro:stdoaj">Gezielte Aktualisierungen</h3>
          <p class="text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/use-cases/product-safety-recalls.astro:8k9457">Sicherheitshinweise werden direkt auf SKU-, Varianten- oder Chargenebene in die betroffenen Passdaten eingebettet. Nicht betroffene Produkte bleiben unverändert.</p>
          <ul class="space-y-4 text-slate-700 font-medium" data-ps="src/pages/use-cases/product-safety-recalls.astro:card-list-1">
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/product-safety-recalls.astro:ddzuok"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Präzision auf Chargenebene</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/product-safety-recalls.astro:ddzuoj"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Keine kategorieweiten Warnmeldungen</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/product-safety-recalls.astro:ddzunx"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Eigentümerbezogene Warnmeldungen</li>
          </ul>
        </div>
</div></div></section>


        <!-- Card 2 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/product-safety-recalls.astro:6g626y">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/product-safety-recalls.astro:card-deco-2"></div>
          <div class="w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/product-safety-recalls.astro:6g626x">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/use-cases/product-safety-recalls.astro:stdoai">Zeitgesteuerte Nachrichten</h3>
          <p class="text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/use-cases/product-safety-recalls.astro:8k9456">Kontrollierte Aktivierung und Auflösung. Nachrichten werden zu festgelegten Terminen aktiviert und geschlossen, sobald sie erledigt sind, um veraltete Benachrichtigungen zu vermeiden.</p>
          <ul class="space-y-4 text-slate-700 font-medium" data-ps="src/pages/use-cases/product-safety-recalls.astro:card-list-2">
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/product-safety-recalls.astro:ddzunv"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Geplante Aktivierung</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/product-safety-recalls.astro:ddzunu"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Dynamische Untersuchungsprotokolle</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/product-safety-recalls.astro:ddzunt"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Verifizierter Abschlussstatus</li>
          </ul>
        </div>



        <!-- Card 3 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/product-safety-recalls.astro:6g626w">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/product-safety-recalls.astro:card-deco-3"></div>
          <div class="w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/product-safety-recalls.astro:6g626v">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/use-cases/product-safety-recalls.astro:stdoah">Versionsverfolgbare Aufzeichnung</h3>
          <p class="text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/use-cases/product-safety-recalls.astro:8k9455">Nachverfolgbare Historie. Jeder Sicherheitshinweis ist mit einem Zeitstempel versehen, versioniert und zuordenbar, was eine nahtlose behördliche Überprüfung ermöglicht.</p>
          <ul class="space-y-4 text-slate-700 font-medium" data-ps="src/pages/use-cases/product-safety-recalls.astro:card-list-3">
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/product-safety-recalls.astro:ddzunr"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Auditfähige Zeitstempel</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/product-safety-recalls.astro:ddzunq"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Nachweis gegenüber Aufsichtsbehörden</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/product-safety-recalls.astro:ddzunp"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Eindeutiger Nachweis der Erledigung</li>
          </ul>
        </div>
      
    
  



  <!-- Visual Separator Section: The Evidence Model -->
  <section class="py-24 bg-slate-950 text-white relative overflow-hidden" data-ps="src/pages/use-cases/product-safety-recalls.astro:evidence-section">
    <div class="absolute inset-0 opacity-30" data-ps="src/pages/use-cases/product-safety-recalls.astro:img-container">
      <img crossorigin="anonymous"
        src="https://images.unsplash.com/photo-1581092160562-40aa08e78837?auto=format&w=1200&q=80"
        srcset="https://images.unsplash.com/photo-1581092160562-40aa08e78837?auto=format&w=320&q=80 320w, https://images.unsplash.com/photo-1581092160562-40aa08e78837?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1581092160562-40aa08e78837?auto=format&w=640&q=80 640w, https://images.unsplash.com/photo-1581092160562-40aa08e78837?auto=format&w=768&q=80 768w, https://images.unsplash.com/photo-1581092160562-40aa08e78837?auto=format&w=1024&q=80 1024w, https://images.unsplash.com/photo-1581092160562-40aa08e78837?auto=format&w=1280&q=80 1280w, https://images.unsplash.com/photo-1581092160562-40aa08e78837?auto=format&w=1920&q=80 1920w"
        sizes="100vw"
        alt="Industrial safety and quality control" class="w-full h-full object-cover" data-ps="src/pages/use-cases/product-safety-recalls.astro:kwsdk2" />
      <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/80 to-transparent" data-ps="src/pages/use-cases/product-safety-recalls.astro:8ygl33"></div>
    </div>
    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/use-cases/product-safety-recalls.astro:evidence-content">
      <div class="max-w-5xl mx-auto" data-ps="src/pages/use-cases/product-safety-recalls.astro:evidence-grid-wrap">
        <h2 class="text-3xl md:text-5xl font-bold mb-16 text-center" data-ps="src/pages/use-cases/product-safety-recalls.astro:evidence-h">Auf Lösung ausgerichtet.</h2>
        <div class="grid lg:grid-cols-2 gap-16 items-center" data-ps="src/pages/use-cases/product-safety-recalls.astro:evidence-grid">
           <div class="bg-white/5 backdrop-blur-xl p-10 rounded-[2.5rem] border border-white/10 shadow-2xl" data-ps="src/pages/use-cases/product-safety-recalls.astro:evidence-box-1">
             <div class="flex items-center gap-4 mb-8" data-ps="src/pages/use-cases/product-safety-recalls.astro:8ygl34">
               <div class="w-10 h-10 rounded-xl bg-blue-500/20 flex items-center justify-center" data-ps="src/pages/use-cases/product-safety-recalls.astro:8ygl35">
                 <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#60a5fa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-alert"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
               </div>
