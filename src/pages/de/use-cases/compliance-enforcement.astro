---
import BaseLayout from '@/layouts/BaseLayout.astro';

const title = "Compliance Enforcement — TieBack";
const description = "When mandates activate, compliance becomes operational. TieBack enforces required fields automatically and supports go/no-go decisions before products are placed on the EU market.";
---






<baselayout title="{title}" description="{description}">
  <!-- 1. Use Case Hero -->
  <section class="relative pt-32 pb-24 md:pt-52 md:pb-40 overflow-hidden bg-slate-950" data-ps="src/pages/use-cases/compliance-enforcement.astro:hero">
    <!-- Hero Background Image -->
    <div class="absolute inset-0 z-0 overflow-hidden" data-ps="src/pages/use-cases/compliance-enforcement.astro:hero-bg">
      <img crossorigin="anonymous"
        src="https://images.unsplash.com/photo-1614064641938-3bbee52942c7?auto=format&w=1200&q=80"
        srcset="https://images.unsplash.com/photo-1614064641938-3bbee52942c7?auto=format&w=320&q=80 320w, https://images.unsplash.com/photo-1614064641938-3bbee52942c7?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1614064641938-3bbee52942c7?auto=format&w=640&q=80 640w, https://images.unsplash.com/photo-1614064641938-3bbee52942c7?auto=format&w=768&q=80 768w, https://images.unsplash.com/photo-1614064641938-3bbee52942c7?auto=format&w=1024&q=80 1024w, https://images.unsplash.com/photo-1614064641938-3bbee52942c7?auto=format&w=1280&q=80 1280w, https://images.unsplash.com/photo-1614064641938-3bbee52942c7?auto=format&w=1920&q=80 1920w"
        sizes="100vw"
        alt="Cybersecurity and data compliance shield" 
        class="w-full h-full object-cover opacity-30 scale-105" 
        loading="eager" fetchpriority="high" data-ps="src/pages/use-cases/compliance-enforcement.astro:hero-img" />
      <div class="absolute inset-0 bg-gradient-to-b from-slate-950/80 via-slate-950/60 to-slate-950" data-ps="src/pages/use-cases/compliance-enforcement.astro:hero-overlay"></div>
    </div>
</section></baselayout>


    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/use-cases/compliance-enforcement.astro:hero-container">
      <div class="max-w-4xl mx-auto text-center" data-ps="src/pages/use-cases/compliance-enforcement.astro:hero-content">
        <div class="inline-flex items-center gap-2 py-1 px-3 mb-8 text-[11px] font-bold tracking-widest text-blue-400 uppercase bg-blue-500/10 backdrop-blur-md border border-blue-500/20 rounded-full" data-ps="src/pages/use-cases/compliance-enforcement.astro:eyebrow">
          <span class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-pulse" data-ps="src/pages/use-cases/compliance-enforcement.astro:pulse"></span>
          Fall 05
        </div>
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight text-white mb-8 leading-[1.05]" data-ps="src/pages/use-cases/compliance-enforcement.astro:title">
        
          <span class="text-blue-500" data-ps="src/pages/use-cases/compliance-enforcement.astro:title-blue">Durchsetzung</span>
        der Compliance
        </h1>
        <p class="text-xl md:text-2xl text-slate-300 mb-12 leading-relaxed max-w-2xl mx-auto" data-ps="src/pages/use-cases/compliance-enforcement.astro:subtext">
          Sobald Vorschriften in Kraft treten, wird Compliance zur operativen Aufgabe. „TieBack“ sorgt automatisch für die Einhaltung der Pflichtfelder, macht Hindernisse deutlich sichtbar und unterstützt Go/No-Go-Entscheidungen, bevor Produkte auf den EU-Markt gebracht werden.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-5" data-ps="src/pages/use-cases/compliance-enforcement.astro:buttons">
          <a href="/request-access" class="w-full sm:w-auto px-10 py-4 bg-blue-600 hover:bg-blue-500 text-white font-semibold rounded-xl transition-all duration-300 shadow-xl shadow-blue-900/40 hover:-translate-y-1" data-ps="src/pages/use-cases/compliance-enforcement.astro:btn-primary">
            Zugriff anfordern
          </a>
          
          <a href="/platform/why-tieback/" class="w-full sm:w-auto px-10 py-4 bg-slate-900/50 backdrop-blur-sm border border-slate-800 text-white font-semibold rounded-xl hover:bg-slate-800 transition-all duration-300 hover:border-slate-700" data-ps="src/pages/use-cases/compliance-enforcement.astro:btn-secondary">
            Plattformübersicht
          </a>
        </div>
      </div>
    </div>
  



  <!-- 2. The Enforcement Moment -->
  <section class="py-32 bg-slate-50 border-y border-slate-200/60 relative overflow-hidden" data-ps="src/pages/use-cases/compliance-enforcement.astro:moment">
    <div class="container mx-auto px-6" data-ps="src/pages/use-cases/compliance-enforcement.astro:moment-container">
      <div class="grid lg:grid-cols-2 gap-20 items-center" data-ps="src/pages/use-cases/compliance-enforcement.astro:moment-grid">
        <div class="relative" data-ps="src/pages/use-cases/compliance-enforcement.astro:moment-left">
          <div class="absolute -top-12 -left-12 w-24 h-24 bg-blue-100/50 rounded-full blur-2xl" data-ps="src/pages/use-cases/compliance-enforcement.astro:accent-3"></div>
          <h2 class="text-4xl md:text-5xl font-bold text-slate-900 leading-[1.15] relative" data-ps="src/pages/use-cases/compliance-enforcement.astro:moment-heading">
          
            Entwickelt für den Moment, in dem die Durchsetzung zählt – <span class="italic font-serif text-blue-700" data-ps="src/pages/use-cases/compliance-enforcement.astro:moment-blue">Validierung, Zugriffskontrolle und Rückverfolgbarkeit.</span>
          </h2>
          <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-1 gap-6" data-ps="src/pages/use-cases/compliance-enforcement.astro:moment-list">
             <div class="flex gap-4 items-center group bg-white/50 backdrop-blur-sm p-4 rounded-xl border border-slate-200 transition-all hover:border-blue-200 hover:shadow-lg hover:shadow-blue-50" data-ps="src/pages/use-cases/compliance-enforcement.astro:moment-item-1">
                <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center shrink-0 text-blue-700 font-bold" data-ps="src/pages/use-cases/compliance-enforcement.astro:moment-icon-1">01</div>
                <div data-ps="src/pages/use-cases/compliance-enforcement.astro:moment-text-1">
                  <h4 class="font-bold text-slate-900" data-ps="src/pages/use-cases/compliance-enforcement.astro:moment-h-1">Durchsetzung nach Produktgruppe</h4>
                </div>
             </div>
             <div class="flex gap-4 items-center group bg-white/50 backdrop-blur-sm p-4 rounded-xl border border-slate-200 transition-all hover:border-blue-200 hover:shadow-lg hover:shadow-blue-50" data-ps="src/pages/use-cases/compliance-enforcement.astro:moment-item-2">
                <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center shrink-0 text-blue-700 font-bold" data-ps="src/pages/use-cases/compliance-enforcement.astro:moment-icon-2">02</div>
                <div data-ps="src/pages/use-cases/compliance-enforcement.astro:moment-text-2">
                  <h4 class="font-bold text-slate-900" data-ps="src/pages/use-cases/compliance-enforcement.astro:moment-h-2">Deterministische Validierungsregeln</h4>
                </div>
             </div>
             <div class="flex gap-4 items-center group bg-white/50 backdrop-blur-sm p-4 rounded-xl border border-slate-200 transition-all hover:border-blue-200 hover:shadow-lg hover:shadow-blue-50" data-ps="src/pages/use-cases/compliance-enforcement.astro:moment-item-3">
                <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center shrink-0 text-blue-700 font-bold" data-ps="src/pages/use-cases/compliance-enforcement.astro:moment-icon-3">03</div>
                <div data-ps="src/pages/use-cases/compliance-enforcement.astro:moment-text-3">
                  <h4 class="font-bold text-slate-900" data-ps="src/pages/use-cases/compliance-enforcement.astro:moment-h-3">Klare Zuständigkeit für die Behebung</h4>
                </div>
             </div>
             <div class="flex gap-4 items-center group bg-white/50 backdrop-blur-sm p-4 rounded-xl border border-slate-200 transition-all hover:border-blue-200 hover:shadow-lg hover:shadow-blue-50" data-ps="src/pages/use-cases/compliance-enforcement.astro:moment-item-4">
                <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center shrink-0 text-blue-700 font-bold" data-ps="src/pages/use-cases/compliance-enforcement.astro:moment-icon-4">04</div>
                <div data-ps="src/pages/use-cases/compliance-enforcement.astro:moment-text-4">
                  <h4 class="font-bold text-slate-900" data-ps="src/pages/use-cases/compliance-enforcement.astro:moment-h-4">Nachverfolgbare Aufzeichnungen über die Durchsetzung</h4>
                </div>
             </div>
          </div>
        </div>
        <div class="relative" data-ps="src/pages/use-cases/compliance-enforcement.astro:moment-right">
          <div class="bg-white p-8 md:p-12 rounded-[2rem] border border-slate-200 shadow-2xl shadow-slate-200/50" data-ps="src/pages/use-cases/compliance-enforcement.astro:moment-box">
            <h3 class="text-xs uppercase tracking-widest text-blue-700 font-bold mb-4" data-ps="src/pages/use-cases/compliance-enforcement.astro:reality-eyebrow">Die Herausforderung</h3>
            <p class="text-xl text-slate-800 leading-relaxed mb-8 font-medium" data-ps="src/pages/use-cases/compliance-enforcement.astro:moment-quote">
              DPP
              Die Durchsetzung erfolgt je nach Produktgruppe und Markt. Das Risiko liegt nicht im Konzept der Compliance – es ist der Übergang von „Vorbereitung“ zu „muss jetzt korrekt sein“.
            </p>
            <div class="h-px bg-slate-100 mb-8" data-ps="src/pages/use-cases/compliance-enforcement.astro:moment-divider"></div>
            <div class="grid gap-4" data-ps="src/pages/use-cases/compliance-enforcement.astro:moment-bullets">
              <div class="flex items-start gap-4" data-ps="src/pages/use-cases/compliance-enforcement.astro:moment-bullet-1">
                <span class="w-2 h-2 rounded-full bg-blue-600 mt-2 shrink-0" data-ps="src/pages/use-cases/compliance-enforcement.astro:bullet-dot-1"></span>
                <p class="text-slate-600 font-medium" data-ps="src/pages/use-cases/compliance-enforcement.astro:bullet-text-1">Validierungsregeln müssen klar und deterministisch sein</p>
              </div>
              <div class="flex items-start gap-4" data-ps="src/pages/use-cases/compliance-enforcement.astro:moment-bullet-2">
                <span class="w-2 h-2 rounded-full bg-blue-600 mt-2 shrink-0" data-ps="src/pages/use-cases/compliance-enforcement.astro:bullet-dot-2"></span>
                <p class="text-slate-600 font-medium" data-ps="src/pages/use-cases/compliance-enforcement.astro:bullet-text-2">Hindernisse müssen den Korrekturteams klar aufgezeigt werden</p>
              </div>
              <div class="flex items-start gap-4" data-ps="src/pages/use-cases/compliance-enforcement.astro:moment-bullet-3">
                <span class="w-2 h-2 rounded-full bg-blue-600 mt-2 shrink-0" data-ps="src/pages/use-cases/compliance-enforcement.astro:bullet-dot-3"></span>
                <p class="text-slate-600 font-medium" data-ps="src/pages/use-cases/compliance-enforcement.astro:bullet-text-3">Die Bereitschaft muss ein Go/No-Go-Signal für die Markteinführung sein</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>



  <!-- 3. Capabilities Grid -->
  <section class="py-32 bg-white" data-ps="src/pages/use-cases/compliance-enforcement.astro:capabilities">
    <div class="container mx-auto px-6" data-ps="src/pages/use-cases/compliance-enforcement.astro:capabilities-container">
      <div class="max-w-3xl mb-20" data-ps="src/pages/use-cases/compliance-enforcement.astro:capabilities-header">
        <span class="text-blue-700 font-bold uppercase tracking-wider text-xs block mb-4" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-label">Operative Phase</span>
        <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-title">Durchsetzungsmodus.</h2>
        <p class="text-slate-600 text-xl leading-relaxed" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-subtext">TieBack Validiert Pflichtfelder automatisch und macht die Konformität sichtbar, wodurch sichergestellt wird, dass nur konforme Produkte auf den Markt gelangen.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-grid">
        <!-- Card 1 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-card-1">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-card-deco-1"></div>
          <div class="w-14 h-14 bg-blue-700 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-icon-1">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-h-1">Aktivierung & Logik</h3>
          <p class="text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-p-1">Passen Sie die Durchsetzung an bestimmte Produktkategorien und die Markteinführung an, ohne zu starke Einschränkungen vorzunehmen.</p>
          <ul class="space-y-4 text-slate-700 font-medium" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-list-1">
            <li class="flex items-start gap-3" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-li-1-1"><svg class="w-5 h-5 text-blue-700 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Kategorienbasierte Aktivierung</li>
            <li class="flex items-start gap-3" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-li-1-2"><svg class="w-5 h-5 text-blue-700 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Marktorientierte Durchsetzungslogik</li>
            <li class="flex items-start gap-3" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-li-1-3"><svg class="w-5 h-5 text-blue-700 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Konsistentes Verhalten des Resolvers</li>
          </ul>
        </div>
</div></div></section>


        <!-- Card 2 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-card-2">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-card-deco-2"></div>
          <div class="w-14 h-14 bg-blue-700 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-icon-2">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-h-2">Validierungs-Gating</h3>
          <p class="text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-p-2">Machen Sie die Betriebsbereitschaft zu einem deterministischen Signal für Startentscheidungen und die Vollständigkeit der Daten.</p>
          <ul class="space-y-4 text-slate-700 font-medium" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-list-2">
            <li class="flex items-start gap-3" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-li-2-1"><svg class="w-5 h-5 text-blue-700 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Validierung von Pflichtfeldern</li>
            <li class="flex items-start gap-3" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-li-2-2"><svg class="w-5 h-5 text-blue-700 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Fehlende Daten werden als Blocker gekennzeichnet</li>
            <li class="flex items-start gap-3" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-li-2-3"><svg class="w-5 h-5 text-blue-700 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Eindeutige Bereitschaftsstatus (Go/No-Go)</li>
          </ul>
        </div>



        <!-- Card 3 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-card-3">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-card-deco-3"></div>
          <div class="w-14 h-14 bg-blue-700 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-icon-3">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-h-3">Behebungszyklus</h3>
          <p class="text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-p-3">Beheben Sie Hindernisse schnell mit eindeutigen Diagnosen und vollständiger Zuordnung der Verantwortlichkeiten.</p>
          <ul class="space-y-4 text-slate-700 font-medium" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-list-3">
            <li class="flex items-start gap-3" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-li-3-1"><svg class="w-5 h-5 text-blue-700 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Diagnoseansichten „Was fehlt?“</li>
            <li class="flex items-start gap-3" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-li-3-2"><svg class="w-5 h-5 text-blue-700 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Versionsverfolgter Behebungsverlauf</li>
            <li class="flex items-start gap-3" data-ps="src/pages/use-cases/compliance-enforcement.astro:cap-li-3-3"><svg class="w-5 h-5 text-blue-700 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Verantwortlichkeit und Zuordnung von Änderungen</li>
          </ul>
        </div>
      
    
  



  <!-- Visual Separator Section -->
  <section class="py-24 bg-slate-950 text-white relative overflow-hidden" data-ps="src/pages/use-cases/compliance-enforcement.astro:evidence">
    <div class="absolute inset-0 opacity-40" data-ps="src/pages/use-cases/compliance-enforcement.astro:evidence-bg">
      <img crossorigin="anonymous"
        src="https://images.unsplash.com/photo-1695649383193-b55adef4e60e?auto=format&w=1200&q=80"
        srcset="https://images.unsplash.com/photo-1695649383193-b55adef4e60e?auto=format&w=320&q=80 320w, https://images.unsplash.com/photo-1695649383193-b55adef4e60e?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1695649383193-b55adef4e60e?auto=format&w=640&q=80 640w, https://images.unsplash.com/photo-1695649383193-b55adef4e60e?auto=format&w=768&q=80 768w, https://images.unsplash.com/photo-1695649383193-b55adef4e60e?auto=format&w=1024&q=80 1024w, https://images.unsplash.com/photo-1695649383193-b55adef4e60e?auto=format&w=1280&q=80 1280w, https://images.unsplash.com/photo-1695649383193-b55adef4e60e?auto=format&w=1920&q=80 1920w"
        sizes="100vw"
        alt="Legal and compliance documentation" class="w-full h-full object-cover" data-ps="src/pages/use-cases/compliance-enforcement.astro:evidence-img" />
      <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/80 to-transparent" data-ps="src/pages/use-cases/compliance-enforcement.astro:evidence-overlay"></div>
    </div>
    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/use-cases/compliance-enforcement.astro:evidence-container">
      <div class="max-w-5xl mx-auto" data-ps="src/pages/use-cases/compliance-enforcement.astro:evidence-content">
        <h2 class="text-3xl md:text-5xl font-bold mb-16 text-center" data-ps="src/pages/use-cases/compliance-enforcement.astro:evidence-title">Die Durchsetzung muss nachweisbar sein.</h2>
        <div class="grid lg:grid-cols-2 gap-16 items-center" data-ps="src/pages/use-cases/compliance-enforcement.astro:evidence-grid">
           <div class="bg-white/5 backdrop-blur-xl p-10 rounded-[2.5rem] border border-white/10 shadow-2xl" data-ps="src/pages/use-cases/compliance-enforcement.astro:evidence-box">
             <div class="flex items-center gap-4 mb-8" data-ps="src/pages/use-cases/compliance-enforcement.astro:evidence-label-wrap">
