---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/config/site';

const title = "Upstream Suppliers & Manufacturers — TieBack";
const description = "TieBack supports structured contribution of product data for suppliers whose materials and components enter EU supply chains.";
---

<BaseLayout title={title} description={description}>
  <!-- 1. Use Case Hero (Enhanced with Depth) -->
  <section class="relative pt-32 pb-24 md:pt-52 md:pb-40 overflow-hidden bg-white" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:ocb6x9">
    <!-- Subtle Background Accents -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-7xl pointer-events-none" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fio">
      <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-blue-50/50 blur-[120px]" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fja"></div>
      <div class="absolute bottom-[10%] right-[-5%] w-[30%] h-[30%] rounded-full bg-slate-50 blur-[100px]" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fjb"></div>
    </div>

    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fjc">
      <div class="max-w-4xl mx-auto text-center" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fjd">
        <div class="inline-flex items-center gap-2 py-1 px-3 mb-8 text-[11px] font-bold tracking-widest text-blue-600 uppercase bg-blue-50/80 backdrop-blur-sm border border-blue-100 rounded-full" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fje">
          <span class="w-1.5 h-1.5 rounded-full bg-blue-600 animate-pulse" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:zfotub"></span>
          Case 02
        </div>
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight text-slate-900 mb-8 leading-[1.05]" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:sfu22p">
          Suppliers & <span class="text-blue-600" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:sn01xa">Upstream Manufacturers</span>
        </h1>
        <p class="text-xl md:text-2xl text-slate-600 mb-12 leading-relaxed max-w-2xl mx-auto" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:clk1sf">
          Supplying materials or components into the EU market
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-5" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fjf">
          <a href="#request-access" class="w-full sm:w-auto px-10 py-4 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-xl transition-all duration-300 shadow-xl shadow-blue-200 hover:-translate-y-1" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:s3u3dq">
            Request Access
          </a>
          <a href="/platform/why-tieback/" class="w-full sm:w-auto px-10 py-4 bg-white border border-slate-200 text-slate-700 font-semibold rounded-xl hover:bg-slate-50 transition-all duration-300 hover:border-slate-300" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:s3u3dp">
            Platform Overview
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. The Challenge (Impactful Layout) -->
  <section class="py-32 bg-slate-50 border-y border-slate-200/60 relative overflow-hidden" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:ocb6x8">
    <div class="container mx-auto px-6" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fjg">
      <div class="grid lg:grid-cols-2 gap-20 items-center" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fjh">
        <div class="relative" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fji">
          <div class="absolute -top-12 -left-12 w-24 h-24 bg-blue-100/50 rounded-full blur-2xl" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fjj"></div>
          <h2 class="text-4xl md:text-5xl font-bold text-slate-900 leading-[1.15] relative" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:drf4ug">
            Built for suppliers whose products enter <span class="italic font-serif text-blue-600" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:sn01x9">EU supply chains.</span>
          </h2>
          <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-1 gap-8" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fk5">
             <div class="flex gap-6 group bg-white/50 backdrop-blur-sm p-6 rounded-2xl border border-slate-200 transition-all hover:border-blue-200 hover:shadow-lg hover:shadow-blue-50" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fk6">
                <div class="w-12 h-12 rounded-xl bg-blue-600 flex items-center justify-center shrink-0 shadow-lg shadow-blue-100" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fk7">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trending-up"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
                </div>
                <div data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fk8">
                  <h4 class="font-bold text-slate-900 mb-1" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:flepkv">The Operating Landscape</h4>
                  <p class="text-slate-600 text-sm" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:clk1rt">For upstream suppliers, compliance expectations are changing rapidly with short timelines.</p>
                </div>
             </div>
             <div class="flex gap-6 group bg-white/50 backdrop-blur-sm p-6 rounded-2xl border border-slate-200 transition-all hover:border-blue-200 hover:shadow-lg hover:shadow-blue-50" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fk9">
                <div class="w-12 h-12 rounded-xl bg-blue-600 flex items-center justify-center shrink-0 shadow-lg shadow-blue-100" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fka">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-check"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
                </div>
                <div data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fkb">
                  <h4 class="font-bold text-slate-900 mb-1" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:flepku">Downstream Formats</h4>
                  <p class="text-slate-600 text-sm" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:clk1rs">Spreadsheets and email attachments do not scale. Manual documentation lacks version history.</p>
                </div>
             </div>
          </div>
        </div>
        <div class="relative" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fkc">
          <div class="bg-white p-8 md:p-12 rounded-[2rem] border border-slate-200 shadow-2xl shadow-slate-200/50" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fkd">
            <p class="text-2xl text-slate-800 leading-relaxed mb-8 font-medium" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:clk1rr">
              If you manufacture materials, fabrics, components, or semi-finished goods that are incorporated into products sold in the EU, Digital Product Passport requirements will affect you. <br/><br/><strong>Even if you do not sell directly to consumers.</strong>
            </p>
            <div class="h-px bg-slate-100 mb-8" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fke"></div>
            <div class="grid gap-6" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fl0">
              <div class="flex items-start gap-4" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fl1">
                <span class="w-2 h-2 rounded-full bg-blue-600 mt-2.5 shrink-0" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:sn01x8"></span>
                <p class="text-slate-600 text-lg" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:clk1rq">Obligations apply to products placed on the EU market. Data requirements extend upstream.</p>
              </div>
              <div class="flex items-start gap-4" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fl2">
                <span class="w-2 h-2 rounded-full bg-blue-600 mt-2.5 shrink-0" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:sn01x7"></span>
                <p class="text-slate-600 text-lg" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:clk1rp">TieBack supports structured contribution of product data without exposing internal systems or commercial sensitivity.</p>
              </div>
            </div>
          </div>
          <!-- Decorative element -->
          <div class="absolute -bottom-6 -right-6 w-32 h-32 border-b-2 border-r-2 border-blue-100 rounded-br-3xl pointer-events-none" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fl3"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. The Solution / Capabilities (3-Column Card Grid) -->
  <section class="py-32 bg-white" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:ocb6x7">
    <div class="container mx-auto px-6" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fl4">
      <div class="max-w-3xl mb-20" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fl5">
        <span class="text-blue-600 font-bold uppercase tracking-wider text-xs block mb-4" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:sn01x6">Capabilities</span>
        <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:drf4uh">How TieBack applies to upstream suppliers.</h2>
        <p class="text-slate-600 text-xl leading-relaxed" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:clk1ro">Digital Product Passport requirements introduce structure and permanence to the materials and components entering the supply chain.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fl6">
        <!-- Card 1 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fl7">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fl8"></div>
          <div class="w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fl9">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:wzsd8">Structured Records</h3>
          <p class="text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:clk1rn">Create structured digital records aligned to materials, components, and attributes suitable for downstream passport integration.</p>
          <ul class="space-y-4 text-slate-700 font-medium">
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:nneyug"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Material composition details</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:nneyuh"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Traceability attributes</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:nneyui"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Regulatory declarations</li>
          </ul>
        </div>

        <!-- Card 2 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4flv">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4flw"></div>
          <div class="w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4flx">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:wzsd7">Controlled Contribution</h3>
          <p class="text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:clk1rm">Suppliers contribute data once. Brands and importers can ingest supplier-provided data into their finished product passports.</p>
          <ul class="space-y-4 text-slate-700 font-medium">
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:nneyuj"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Clear attribution of data</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:nneyuk"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Visibility of updates</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:nneyul"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Audit-ready history</li>
          </ul>
        </div>

        <!-- Card 3 -->
        <div class="group relative bg-white p-10 rounded-3xl border border-slate-200 hover:border-blue-200 transition-all duration-300 hover:shadow-2xl hover:shadow-blue-100/30 overflow-hidden" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fly">
          <div class="absolute top-0 right-0 w-32 h-32 bg-blue-50/50 rounded-bl-full translate-x-16 -translate-y-16 group-hover:translate-x-12 group-hover:-translate-y-12 transition-transform" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4flz"></div>
          <div class="w-14 h-14 bg-blue-600 rounded-2xl flex items-center justify-center mb-8 shadow-lg shadow-blue-200" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fm0">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:wzsd6">Baseline Mode</h3>
          <p class="text-slate-600 mb-8 leading-relaxed" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:clk1rl">Where mandates are not yet in force, establish baseline structures. Prepare without over-commitment until enforcement aligns.</p>
          <ul class="space-y-4 text-slate-700 font-medium">
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:nneyum"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Visible but unenforced fields</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:nneyv8"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Staged preparation</li>
            <li class="flex items-center gap-3" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:nneyv9"><svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Validated delegated acts</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Visual Separator Section: The Evidence Model -->
  <section class="py-24 bg-slate-950 text-white relative overflow-hidden" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:ocb6x6">
    <div class="absolute inset-0 opacity-30" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fm1">
      <img crossorigin="anonymous"
        src="https://images.unsplash.com/photo-1639034741369-1e0c771adaeb?auto=format&w=1200&q=80"
        srcset="https://images.unsplash.com/photo-1639034741369-1e0c771adaeb?auto=format&w=320&q=80 320w, https://images.unsplash.com/photo-1639034741369-1e0c771adaeb?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1639034741369-1e0c771adaeb?auto=format&w=640&q=80 640w, https://images.unsplash.com/photo-1639034741369-1e0c771adaeb?auto=format&w=768&q=80 768w, https://images.unsplash.com/photo-1639034741369-1e0c771adaeb?auto=format&w=1024&q=80 1024w, https://images.unsplash.com/photo-1639034741369-1e0c771adaeb?auto=format&w=1280&q=80 1280w, https://images.unsplash.com/photo-1639034741369-1e0c771adaeb?auto=format&w=1920&q=80 1920w"
        sizes="100vw"
        alt="Digital supply chain network" class="w-full h-full object-cover" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:nwvb72" />
      <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/80 to-transparent" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fm2"></div>
    </div>
    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fm3">
      <div class="max-w-5xl mx-auto" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fm4">
        <h2 class="text-3xl md:text-5xl font-bold mb-16 text-center" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:drf4v3">Preparing without overexposure.</h2>
        <div class="grid lg:grid-cols-2 gap-16 items-center" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fmq">
           <div class="bg-white/5 backdrop-blur-xl p-10 rounded-[2.5rem] border border-white/10 shadow-2xl" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fmr">
             <div class="flex items-center gap-4 mb-8" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fms">
               <div class="w-10 h-10 rounded-xl bg-blue-500/20 flex items-center justify-center" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fmt">
                 <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#60a5fa" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-database"><path d="M3 5c0 1.7 4.5 3 10 3s10-1.3 10-3-4.5-3-10-3-10 1.3-10 3Z"/><path d="M3 5v14c0 1.7 4.5 3 10 3s10-1.3 10-3V5"/><path d="M3 12c0 1.7 4.5 3 10 3s10-1.3 10-3"/></svg>
               </div>
               <h4 class="text-blue-400 font-bold uppercase tracking-widest text-xs" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:flepkt">What this enables</h4>
             </div>
             <ul class="space-y-6">
               <li class="flex items-center gap-4 group" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:nneyva">
                 <div class="w-2 h-2 rounded-full bg-blue-500 shadow-[0_0_10px_#3b82f6]" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fmu"></div>
                 <span class="text-lg font-medium text-slate-200" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:sn01x5">Structured data contribution</span>
               </li>
               <li class="flex items-center gap-4 group" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:nneyvb">
                 <div class="w-2 h-2 rounded-full bg-blue-500 shadow-[0_0_10px_#3b82f6]" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fmv"></div>
                 <span class="text-lg font-medium text-slate-200" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:sn01x4">Reduced friction with EU buyers</span>
               </li>
               <li class="flex items-center gap-4 group" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:nneyvc">
                 <div class="w-2 h-2 rounded-full bg-blue-500 shadow-[0_0_10px_#3b82f6]" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fmw"></div>
                 <span class="text-lg font-medium text-slate-200" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:sn01x3">Predictable regulatory alignment</span>
               </li>
             </ul>
           </div>
           <div class="flex flex-col justify-center" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fmx">
             <h3 class="text-2xl font-bold mb-6" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:wzsd5">Importers and Economic Operators</h3>
             <p class="text-slate-400 text-lg leading-relaxed mb-8" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:clk1rk">
               Importers often carry responsibility for ensuring products meet regulatory requirements. TieBack provides visibility into completeness, structured readiness indicators, and clear audit history.
               <br/><br/>Compliance becomes inspectable — not interpretive. Identity and structure can exist independently of marketing presentation. You retain control over what data is shared.
             </p>
             <div class="flex items-center gap-6" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fmy">
                <div data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fmz">
                  <div class="text-3xl font-bold text-blue-400" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:lh2hbx">100%</div>
                  <div class="text-xs uppercase tracking-widest text-slate-400 font-bold" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:lh2hby">Audit History</div>
                </div>
                <div class="w-px h-10 bg-white/10" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:lh2hbz"></div>
                <div data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:lh2hc0">
                  <div class="text-3xl font-bold text-blue-400" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:lh2hc1">True</div>
                  <div class="text-xs uppercase tracking-widest text-slate-400 font-bold" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:lh2hc2">Data Control</div>
                </div>
             </div>
           </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Final CTA (Premium Styling) -->
  <section id="request-access" class="py-32 bg-white relative overflow-hidden" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:ocb6x5">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_left,_var(--tw-gradient-stops))] from-blue-50/50 via-transparent to-transparent pointer-events-none" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:lh2hc3"></div>
    <div class="container mx-auto px-6 relative z-10 text-center" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:lh2hc4">
      <div class="max-w-4xl mx-auto" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:lh2hc5">
        <h2 class="text-5xl md:text-6xl font-bold text-slate-900 mb-8 tracking-tight" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:drf4v4">Designed for <span class="text-blue-600" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:sn01x2">evolving obligations.</span></h2>
        <p class="text-xl text-slate-600 mb-12 max-w-2xl mx-auto leading-relaxed" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:clk1qy">
          See how TieBack supports upstream suppliers and manufacturers preparing for Digital Product Passport requirements. Materials entering EU supply chains carry structured, versioned data.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-6" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:lh2hc6">
          <button class="w-full sm:w-auto px-12 py-5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-2xl transition-all duration-300 shadow-2xl shadow-blue-200 hover:-translate-y-1" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:muwomh">
            Request Access
          </button>
          <a href="/platform/security/" class="group text-slate-900 font-bold flex items-center gap-3 transition-colors hover:text-blue-600" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:s3u3do">
            Platform Security <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
,---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/config/site';

const title = "Upstream Suppliers & Manufacturers — TieBack";
const description = "TieBack supports structured contribution of product data for suppliers whose materials and components enter EU supply chains.";
---
,<BaseLayout title={title} description={description}>
  <!-- 1. Use Case Hero (Enhanced with Depth) -->
  <section class="relative pt-32 pb-24 md:pt-52 md:pb-40 overflow-hidden bg-white" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:ocb6x9">
    <!-- Subtle Background Accents -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full max-w-7xl pointer-events-none" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fio">
      <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-blue-50/50 blur-[120px]" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fja"></div>
      <div class="absolute bottom-[10%] right-[-5%] w-[30%] h-[30%] rounded-full bg-slate-50 blur-[100px]" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fjb"></div>
    </div>

    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/use-cases/suppliers-upstream-manufacturers.astro:qf4fjc">
