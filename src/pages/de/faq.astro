---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/config/site';

const title = "EU Digital Product Passport (EU DPP) FAQ — TieBack";
const description = "Practical EU DPP FAQ for compliance, product, and operations teams — what the regulation expects and how TieBack makes rollout calm and controlled.";

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the EU Digital Product Passport (EU DPP)?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "EU DPP is a structured digital record that makes key product information persistent, updateable, and inspectable over time for products placed on the EU market."
      }
    },
    {
      "@type": "Question",
      "name": "What regulation drives EU DPP?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "EU DPP is introduced under the EU Ecodesign for Sustainable Products Regulation (ESPR)."
      }
    },
    {
      "@type": "Question",
      "name": "When does EU DPP start and how does rollout work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Rollout is phased by product group through delegated acts under ESPR."
      }
    },
    {
      "@type": "Question",
      "name": "Who must comply — is it EU companies only?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Compliance is market-based: if you place in-scope products on the EU market, obligations apply regardless of where you are headquartered."
      }
    },
    {
      "@type": "Question",
      "name": "Does EU DPP apply to B2B products?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Depending on product category and delegated acts, EU DPP can apply to products placed on the market in both B2C and B2B contexts."
      }
    },
    {
      "@type": "Question",
      "name": "What data will we need in a passport?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Requirements vary by category, but most programmes converge on structured identification, composition and materials data, sustainability and circularity guidance, and evidence that records remain current."
      }
    },
    {
      "@type": "Question",
      "name": "Do we need item-level serialisation?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Not always. Some categories may accept product-model or batch-level structures."
      }
    },
    {
      "@type": "Question",
      "name": "What identifiers should we use — SKU vs GTIN/EAN/UPC?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A practical strategy uses both SKU and standards-based identifiers."
      }
    },
    {
      "@type": "Question",
      "name": "What is GS1 Digital Link and why does it matter?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "GS1 Digital Link enables web-resolvable product identifiers that work across markets and systems."
      }
    },
    {
      "@type": "Question",
      "name": "How do we avoid building something brittle that breaks when requirements change?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Treat EU DPP as a living system. TieBack provides the infrastructure that adapts as delegated acts evolve, ensuring your passport remains compliant without rebuilding your core data pipelines."
      }
    },
    {
      "@type": "Question",
      "name": "What does \"audit-ready\" mean in practice?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Audit-ready means you can show what was published, when it changed, who changed it, and which rules were in force at the time. It's about data integrity and provenance."
      }
    },
    {
      "@type": "Question",
      "name": "Will this disrupt operations and production workflows?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "EU DPP should not become a shop-floor burden. TieBack integrates with existing PLM, ERP, and production systems to automate data flow rather than requiring manual entry."
      }
    },
    {
      "@type": "Question",
      "name": "Do we have to expose sensitive supplier or commercial data?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Not by default. Transparency is governed. You control who sees what — public consumers might see circularity data, while regulators see technical compliance evidence."
      }
    },
    {
      "@type": "Question",
      "name": "How do safety notices and recalls work with EU DPP?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A passport becomes a persistent communication channel. If a recall is necessary, you can update the passport content instantly to notify any scanner of the specific safety status."
      }
    },
    {
      "@type": "Question",
      "name": "What's the difference between readiness and enforcement?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Readiness prepares your data model, workflows, and governance structures. Enforcement is when required fields and validation must be satisfied for market access."
      }
    },
    {
      "@type": "Question",
      "name": "Why buy instead of building in-house?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "EU DPP compliance requires a living platform — market-aware updates, versioning, auditability, and governance — sustained over time. Building is easy; maintaining regulatory parity is the hard part."
      }
    },
    {
      "@type": "Question",
      "name": "Is TieBack a 'wallet' or 'token' based system?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. TieBack is an enterprise SaaS platform built on standard web technologies and GS1 Digital Link. There are no crypto-wallets or tokens required for consumers or manufacturers to interact with product passports."
      }
    },
    {
      "@type": "Question",
      "name": "What is 'Market Aware' compliance?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Market Aware means the platform automatically adjusts which data is shown and which rules are enforced based on where the product is scanned or sold, helping you manage global compliance from a single record."
      }
    },
    {
      "@type": "Question",
      "name": "How does TieBack handle 'Resale Visibility'?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "TieBack allows you to maintain a connection to the product throughout its lifecycle. When a product is scanned in a resale context, the passport can surface authenticity proof and original composition data to support the circular economy."
      }
    },
    {
      "@type": "Question",
      "name": "What is 'Ownership Continuity'?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ownership Continuity allows the digital record to be transferred or verified during second-hand sales without revealing personal data of previous owners, maintaining the chain of trust for the physical item."
      }
    }
  ]
};
---






<BaseLayout title={title} description={description} jsonLd={faqLd}>
