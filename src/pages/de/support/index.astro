              Submit Ticket
            </button>
          </form>
        </section>
      </div>

      <div class="lg:col-span-1" data-ps="src/pages/support/index.astro:pd8mlb">
         <div class="bg-slate-900 border border-slate-800 rounded-2xl p-8 sticky top-32 shadow-xl" data-ps="src/pages/support/index.astro:pd8mlc">
            <h3 class="text-xl font-bold text-white mb-6" data-ps="src/pages/support/index.astro:m4ehum">We're here for you</h3>
            
            <div class="space-y-6" data-ps="src/pages/support/index.astro:pd8mld">
              <div class="flex items-start gap-4" data-ps="src/pages/support/index.astro:pd8mle">
                <div class="w-10 h-10 rounded-full bg-slate-800 flex items-center justify-center flex-shrink-0 border border-slate-700" data-ps="src/pages/support/index.astro:pd8mlf">
                  <svg class="w-5 h-5 text-[#0080FF]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div data-ps="src/pages/support/index.astro:pd8mlg">
                  <p class="text-sm text-slate-400 mb-1" data-ps="src/pages/support/index.astro:orqn8h">Email Support</p>
                  <a href="mailto:support@tieback.io" class="text-white font-medium hover:text-[#0080FF] transition-colors" data-ps="src/pages/support/index.astro:hnsqja">support@tieback.io</a>
                </div>
              </div>

              <div class="flex items-start gap-4" data-ps="src/pages/support/index.astro:pd8mlh">
                <div class="w-10 h-10 rounded-full bg-slate-800 flex items-center justify-center flex-shrink-0 border border-slate-700" data-ps="src/pages/support/index.astro:pd8mli">
                  <svg class="w-5 h-5 text-[#0080FF]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div data-ps="src/pages/support/index.astro:pd8mlj">
                  <p class="text-sm text-slate-400 mb-1" data-ps="src/pages/support/index.astro:orqn8g">Response Time</p>
                  <p class="text-white font-medium" data-ps="src/pages/support/index.astro:orqn8f">Personal reply within 24 hours</p>
                </div>
              </div>
            </div>

            <div class="mt-8 bg-slate-950/50 rounded-xl p-6 border border-slate-800" data-ps="src/pages/support/index.astro:pd8mlk">
               <h4 class="font-medium text-white mb-3 flex items-center gap-2" data-ps="src/pages/support/index.astro:7fzkn1">
                 <svg class="w-5 h-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                   <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
                 </svg>
                 Our promise
               </h4>
               <p class="text-sm text-slate-400 leading-relaxed" data-ps="src/pages/support/index.astro:orqn8e">
                 Every message is read and answered by a real person from our team. We want you to succeed with tieback.io
               </p>
            </div>
         </div>
      </div>
    </div>
  </div>
</BaseLayout>---


