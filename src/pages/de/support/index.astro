---,
export const prerender = false;

import BaseLayout from '@/layouts/BaseLayout.astro';

const runtime = Astro.locals.runtime;
if (!runtime?.env?.DB) {
  return new Response('Service unavailable', { status: 503 });
}

const db = runtime.env.DB;
let error = '';
let success = false;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const email = formData.get('email')?.toString();
  const subject = formData.get('subject')?.toString();
  const message = formData.get('message')?.toString();

  if (!email || !subject || !message) {
    error = 'Please fill in all fields.';
  } else {
    try {
      const ticketId = crypto.randomUUID();
      const messageId = crypto.randomUUID();
      const ticketNumber = 'TKT-' + Math.floor(1000 + Math.random() * 9000);
      
      await db.prepare('INSERT INTO support_tickets (id, ticket_number, email, subject, status, created_at, updated_at) VALUES (?, ?, ?, ?, ?, datetime("now"), datetime("now"))')
        .bind(ticketId, ticketNumber, email, subject, 'Open').run();
      
      await db.prepare('INSERT INTO support_messages (id, ticket_id, sender, message, created_at) VALUES (?, ?, ?, ?, datetime("now"))')
        .bind(messageId, ticketId, 'User', message).run();
      
      success = true;
    } catch(err) {
      error = 'Failed to create ticket.';
      console.error(err);
    }
  }
}
,

<BaseLayout title="Support | TieBack" description="Contact TieBack Support">
  <div class="max-w-7xl mx-auto px-6 py-16" data-ps="src/pages/support/index.astro:526urk">
