---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredPost = posts.find(post => post.data.featured) || posts[0];
const remainingPosts = posts.filter(post => post.slug !== featuredPost?.slug);

const categories = ['All', 'Compliance', 'Digital Identity', 'Engineering', 'News'];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Journal | TieBack",
  "description": "Perspectives on Digital Product Passports, connected supply chains, and the future of physical product identity.",
  "url": "https://tieback.io/journal/"
};
---

<BaseLayout title="Journal | TieBack" description="Perspectives on Digital Product Passports, connected supply chains, and the future of physical product identity." jsonLd={jsonLd}>
  <main class="bg-white text-slate-900 pt-32 pb-24" data-ps="src/pages/journal/index.astro:1p6sm1">
    <div class="max-w-7xl mx-auto px-6" data-ps="src/pages/journal/index.astro:7upzwn">
      <!-- Hero -->
      <header class="mb-16" data-ps="src/pages/journal/index.astro:hjyx1z">
        <h1 class="text-5xl md:text-6xl font-bold tracking-tight text-slate-950 mb-6" data-ps="src/pages/journal/index.astro:tserto">Journal</h1>
        <p class="text-xl text-slate-600 max-w-2xl leading-relaxed" data-ps="src/pages/journal/index.astro:65kvq2">
          Perspectives on Digital Product Passports, connected supply chains, and the future of physical product identity.
        </p>
      </header>

      <!-- Featured Article -->
      {featuredPost && (
        <section class="mb-20" data-ps="src/pages/journal/index.astro:kkbiog">
          <a href={`/journal/${featuredPost.slug}/`} class="group grid md:grid-cols-2 gap-8 lg:gap-12 items-center" data-ps="src/pages/journal/index.astro:yd0yy">
            <div class="relative aspect-[16/9] overflow-hidden rounded-2xl bg-slate-100 border border-slate-200 shadow-sm transition-all duration-300 group-hover:shadow-md" data-ps="src/pages/journal/index.astro:7upzwm">
              <img 
                src={featuredPost.data.image || "https://images.pexels.com/photos/17485706/pexels-photo-17485706.png?auto=compress&cs=tinysrgb&w=1200"} 
                alt={featuredPost.data.title}
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" data-ps="src/pages/journal/index.astro:wvave7" />
            </div>
            <div data-ps="src/pages/journal/index.astro:7upzwl">
              <span class="inline-block px-3 py-1 rounded-full bg-blue-50 text-blue-600 text-xs font-bold uppercase tracking-wider mb-4" data-ps="src/pages/journal/index.astro:q3gzl1">
                {featuredPost.data.category || 'Featured'}
              </span>
              <h2 class="text-3xl md:text-4xl font-bold text-slate-950 mb-4 group-hover:text-blue-600 transition-colors" data-ps="src/pages/journal/index.astro:qkacxv">
                {featuredPost.data.title}
              </h2>
              <p class="text-lg text-slate-600 mb-6 line-clamp-3" data-ps="src/pages/journal/index.astro:65kvq1">
                {featuredPost.data.description}
              </p>
              <div class="flex items-center gap-4" data-ps="src/pages/journal/index.astro:7upzwk">
                <span class="text-sm font-semibold text-slate-900" data-ps="src/pages/journal/index.astro:q3gzl2">Read Article</span>
                <svg class="w-4 h-4 text-blue-600 transform transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </div>
            </div>
          </a>
        </section>
      )}

      <!-- Category Filter -->
      <nav class="flex flex-wrap gap-2 mb-12 border-b border-slate-100 pb-8" data-ps="src/pages/journal/index.astro:sinyr0">
        {categories.map((cat, __psIdx) => (
          <button class="px-5 py-2 rounded-full border border-slate-200 text-sm font-medium text-slate-600 hover:border-slate-900 hover:text-slate-900 transition-all duration-200" data-ps={`src/pages/journal/index.astro:jf150f-${__psIdx}`}>
            {cat}
          </button>
        ))}
      </nav>

      <!-- Article Grid -->
      <div class="space-y-20" data-ps="src/pages/journal/index.astro:7upzwj">
        {remainingPosts.map((post, __psIdx) => (
          <section data-ps={`src/pages/journal/index.astro:95mslv-${__psIdx}`}>
            <a href={`/journal/${post.slug}/`} class="group grid md:grid-cols-2 gap-8 lg:gap-12 items-center" data-ps={`src/pages/journal/index.astro:yd0yz-${__psIdx}`}>
              <div class="relative aspect-[16/9] overflow-hidden rounded-2xl bg-slate-100 border border-slate-200 shadow-sm transition-all duration-300 group-hover:shadow-md" data-ps={`src/pages/journal/index.astro:wvave6-${__psIdx}`}>
                <img 
                  src={post.data.image || "https://images.pexels.com/photos/5380618/pexels-photo-5380618.jpeg?auto=compress&cs=tinysrgb&w=1200"} 
                  alt={post.data.title}
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy" data-ps={`src/pages/journal/index.astro:xb53fe-${__psIdx}`} />
              </div>
              <div data-ps={`src/pages/journal/index.astro:7upzwh-${__psIdx}`}>
                <span class="inline-block px-3 py-1 rounded-full bg-blue-50 text-blue-600 text-xs font-bold uppercase tracking-wider mb-4" data-ps={`src/pages/journal/index.astro:umn5gi-${__psIdx}`}>
                  {post.data.category || 'News'}
                </span>
                <h2 class="text-3xl md:text-4xl font-bold text-slate-950 mb-4 group-hover:text-blue-600 transition-colors" data-ps={`src/pages/journal/index.astro:3q4km3-${__psIdx}`}>
                  {post.data.title}
                </h2>
                <p class="text-lg text-slate-600 mb-6 line-clamp-3" data-ps={`src/pages/journal/index.astro:n40tj6-${__psIdx}`}>
                  {post.data.description}
                </p>
                <div class="flex items-center gap-4" data-ps={`src/pages/journal/index.astro:7upzwg-${__psIdx}`}>
                  <span class="text-sm font-semibold text-slate-900" data-ps={`src/pages/journal/index.astro:umn5gj-${__psIdx}`}>Read Article</span>
                  <svg class="w-4 h-4 text-blue-600 transform transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                </div>
              </div>
            </a>
          </section>
        ))}
      </div>
    </div>
  </main>
</BaseLayout>
