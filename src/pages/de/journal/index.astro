          <section data-ps={`src/pages/journal/index.astro:95mslv-${__psIdx}
        `}&gt;
            <a href=<astro-expr id="39">
              /`} class=&quot;group grid md:grid-cols-2 gap-8 lg:gap-12 items-center&quot; data-ps={`src/pages/journal/index.astro:yd0yz-${__psIdx}
              `}&gt;
              <div class="relative aspect-[16/9] overflow-hidden rounded-2xl bg-slate-100 border border-slate-200 shadow-sm transition-all duration-300 group-hover:shadow-md" data-ps=<astro-expr id="41">`}&gt;
