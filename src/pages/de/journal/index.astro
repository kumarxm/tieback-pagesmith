                  alt={post.data.title}
                  class=&quot;absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105&quot;
                  loading=&quot;lazy&quot; data-ps={`src/pages/journal/index.astro:xb53fe-${__psIdx}
                  `} /&gt;
              </div>
              <div data-ps=<astro-expr id="45">`}&gt;
                <span class="inline-block px-3 py-1 rounded-full bg-blue-50 text-blue-600 text-xs font-bold uppercase tracking-wider mb-4" data-ps=<astro-expr id="46">`}&gt;
