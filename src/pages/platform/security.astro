---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/config/site';

const architectureFeatures = [
  {
    title: "Role-Based Access",
    description: "Granular permissions enforced at the API and database layers. Define exactly who can manage products, activate identities, or view scan analytics.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`
  },
  {
    title: "Isolated Brand Workspaces",
    description: "Multi-tenant architecture ensuring physical and logical data separation. Your product identities, customer data, and event logs never mix with other brands.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>`
  },
  {
    title: "Tamper-Resistant Event Records",
    description: "Every critical lifecycle event—from minting to ownership transfer—is logged with cryptographic hashing to ensure an immutable audit trail.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>`
  },
  {
    title: "GS1 Digital Link Native",
    description: "Standardized routing that works with existing infrastructure while providing enterprise-grade resolution security and redirection control.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>`
  }
];

const complianceChecklist = [
  "EU ESPR (Ecodesign for Sustainable Products Regulation) ready",
  "GS1 Digital Link Resolution Standard compliant",
  "GDPR compliant data handling and residency",
  "SOC2 Type II aligned security controls",
  "Encrypted data at rest and in transit (AES-256/TLS 1.3)",
  "Continuous automated vulnerability scanning",
  "Comprehensive audit logs for all administrative actions"
];
---

<BaseLayout 
  title="Security & Trust | TieBack" 
  description="Enterprise-grade security and digital identity trust for physical products. Built for EU ESPR readiness and global scale."
>
  {/* Hero Section */}
  <section class="relative pt-32 pb-20 md:pt-48 md:pb-32 bg-white overflow-hidden" data-ps="src/pages/platform/security.astro:3bza4e">
    <div class="absolute inset-0 z-0 opacity-[0.03] pointer-events-none" data-ps="src/pages/platform/security.astro:hero-bg">
      <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1664526936810-ec0856d31b92?auto=format&w=1200&q=80" srcset="https://images.unsplash.com/photo-1664526936810-ec0856d31b92?auto=format&w=320&q=80 320w, https://images.unsplash.com/photo-1664526936810-ec0856d31b92?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1664526936810-ec0856d31b92?auto=format&w=640&q=80 640w, https://images.unsplash.com/photo-1664526936810-ec0856d31b92?auto=format&w=768&q=80 768w, https://images.unsplash.com/photo-1664526936810-ec0856d31b92?auto=format&w=1024&q=80 1024w, https://images.unsplash.com/photo-1664526936810-ec0856d31b92?auto=format&w=1280&q=80 1280w, https://images.unsplash.com/photo-1664526936810-ec0856d31b92?auto=format&w=1920&q=80 1920w" sizes="100vw" alt="Security abstract background" class="w-full h-full object-cover" data-ps="src/pages/platform/security.astro:yj48j6" />
    </div>
    
    <div class="container mx-auto px-6 text-center max-w-4xl relative z-10" data-ps="src/pages/platform/security.astro:7i7n8w">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-50 border border-blue-100 text-blue-700 text-sm font-bold mb-8 animate-fade-in" data-ps="src/pages/platform/security.astro:badge">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
        Enterprise Grade
      </div>
      <h1 class="text-5xl md:text-7xl font-bold tracking-tight text-slate-900 mb-8 balance" data-ps="src/pages/platform/security.astro:bhs72l">
        Enterprise security.<br /><span class="text-blue-600" data-ps="src/pages/platform/security.astro:l9dul5">Calm by design.</span>
      </h1>
      <p class="text-xl text-slate-600 mb-10 leading-relaxed max-w-2xl mx-auto" data-ps="src/pages/platform/security.astro:k89gyz">
        TieBack is a production-ready platform built for item-level trust. From isolated brand workspaces to immutable event logs, we provide the infrastructure needed for global rollout.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4" data-ps="src/pages/platform/security.astro:7i7n8x">
        <a href="#request" class="px-8 py-4 bg-blue-700 text-white font-bold rounded-xl hover:bg-blue-800 transition-all shadow-lg hover:shadow-blue-200 active:scale-95" data-ps="src/pages/platform/security.astro:d4bk9b">
          Request Access
        </a>
        <a href="#architecture" class="px-8 py-4 bg-white text-slate-900 font-bold rounded-xl border border-slate-200 hover:border-slate-300 transition-all" data-ps="src/pages/platform/security.astro:secondary-cta">
          Explore Architecture
        </a>
      </div>
    </div>
  </section>

  {/* Bento Grid Architecture */}
  <section id="architecture" class="py-24 bg-slate-50 border-y border-slate-200 relative overflow-hidden" data-ps="src/pages/platform/security.astro:3bza4f">
    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/platform/security.astro:7i7n8y">
      <div class="mb-16 text-center md:text-left max-w-2xl" data-ps="src/pages/platform/security.astro:7i7n8z">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 tracking-tight" data-ps="src/pages/platform/security.astro:36mq54">Architecture of Trust</h2>
        <p class="text-lg text-slate-600" data-ps="src/pages/platform/security.astro:k89gyy">Built with deep technical layers to ensure your data and your brand stay protected.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-12 gap-6" data-ps="src/pages/platform/security.astro:7i7n90">
        <div class="md:col-span-8 p-10 bg-white border border-slate-200 rounded-3xl flex flex-col justify-between group hover:border-blue-400 transition-all hover:shadow-xl hover:shadow-blue-50/50" data-ps="src/pages/platform/security.astro:7i7n91">
          <div data-ps="src/pages/platform/security.astro:7i7n92">
            <div class="w-14 h-14 rounded-2xl bg-blue-50 flex items-center justify-center text-blue-600 mb-8 group-hover:bg-blue-700 group-hover:text-white transition-all duration-300" data-ps="src/pages/platform/security.astro:7i7n9o">
              <Fragment set:html={architectureFeatures[0].icon} />
            </div>
            <h3 class="text-3xl font-bold text-slate-900 mb-4" data-ps="src/pages/platform/security.astro:hv1ndd">{architectureFeatures[0].title}</h3>
            <p class="text-slate-600 text-xl leading-relaxed max-w-lg" data-ps="src/pages/platform/security.astro:k89gyx">{architectureFeatures[0].description}</p>
          </div>
          <div class="mt-12 flex gap-2" data-ps="src/pages/platform/security.astro:7i7n93">
            <div class="h-1.5 w-12 bg-blue-600 rounded-full" data-ps="src/pages/platform/security.astro:7i7n94"></div>
            <div class="h-1.5 w-12 bg-slate-100 rounded-full" data-ps="src/pages/platform/security.astro:7i7n95"></div>
            <div class="h-1.5 w-12 bg-slate-100 rounded-full" data-ps="src/pages/platform/security.astro:7i7n96"></div>
          </div>
        </div>
        
        <div class="md:col-span-4 p-10 bg-white border border-slate-200 rounded-3xl flex flex-col group hover:border-blue-400 transition-all hover:shadow-xl hover:shadow-blue-50/50" data-ps="src/pages/platform/security.astro:7i7n9p">
          <div class="w-14 h-14 rounded-2xl bg-blue-50 flex items-center justify-center text-blue-600 mb-8 group-hover:bg-blue-700 group-hover:text-white transition-all duration-300" data-ps="src/pages/platform/security.astro:7i7n9q">
            <Fragment set:html={architectureFeatures[1].icon} />
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/platform/security.astro:hv1ndc">{architectureFeatures[1].title}</h3>
          <p class="text-slate-600 leading-relaxed" data-ps="src/pages/platform/security.astro:k89gyb">{architectureFeatures[1].description}</p>
        </div>

        <div class="md:col-span-4 p-10 bg-white border border-slate-200 rounded-3xl flex flex-col group hover:border-blue-400 transition-all hover:shadow-xl hover:shadow-blue-50/50" data-ps="src/pages/platform/security.astro:7i7n9r">
          <div class="w-14 h-14 rounded-2xl bg-blue-50 flex items-center justify-center text-blue-600 mb-8 group-hover:bg-blue-700 group-hover:text-white transition-all duration-300" data-ps="src/pages/platform/security.astro:7i7n9s">
            <Fragment set:html={architectureFeatures[2].icon} />
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-4" data-ps="src/pages/platform/security.astro:hv1ncq">{architectureFeatures[2].title}</h3>
          <p class="text-slate-600 leading-relaxed" data-ps="src/pages/platform/security.astro:k89gya">{architectureFeatures[2].description}</p>
        </div>

        <div class="md:col-span-8 p-10 bg-slate-900 border border-slate-800 rounded-3xl flex flex-col md:flex-row gap-10 items-center overflow-hidden group hover:border-blue-500/50 transition-all" data-ps="src/pages/platform/security.astro:7i7n9t">
          <div class="flex-1 relative z-10" data-ps="src/pages/platform/security.astro:7i7n9u">
            <div class="w-14 h-14 rounded-2xl bg-blue-700 flex items-center justify-center text-white mb-8 shadow-lg shadow-blue-700/20" data-ps="src/pages/platform/security.astro:7i7n9v">
              <Fragment set:html={architectureFeatures[3].icon} />
            </div>
            <h3 class="text-3xl font-bold text-white mb-4" data-ps="src/pages/platform/security.astro:hv1ncp">{architectureFeatures[3].title}</h3>
            <p class="text-slate-400 text-lg leading-relaxed" data-ps="src/pages/platform/security.astro:k89gy9">{architectureFeatures[3].description}</p>
          </div>
          <div class="flex-1 w-full md:w-auto opacity-50 grayscale group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500" data-ps="src/pages/platform/security.astro:7i7n9w">
             <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1586126530777-eefae13ebe34?auto=format&w=600&q=80" srcset="https://images.unsplash.com/photo-1586126530777-eefae13ebe34?auto=format&w=200&auto=format&q=80 200w, https://images.unsplash.com/photo-1586126530777-eefae13ebe34?auto=format&w=400&auto=format&q=80 400w, https://images.unsplash.com/photo-1586126530777-eefae13ebe34?auto=format&w=600&auto=format&q=80 600w" sizes="(max-width: 768px) 100vw, 33vw" alt="Security hardware" class="w-full h-48 object-cover rounded-2xl" loading="lazy" data-ps="src/pages/platform/security.astro:yj48j7" />
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* AI & Trust Layer */}
  <section class="py-32 bg-white overflow-hidden" data-ps="src/pages/platform/security.astro:3bza51">
    <div class="container mx-auto px-6" data-ps="src/pages/platform/security.astro:7i7n9w">
      <div class="flex flex-col lg:flex-row items-center gap-20 mb-32" data-ps="src/pages/platform/security.astro:7i7n9x">
        <div class="flex-1 max-w-xl" data-ps="src/pages/platform/security.astro:7i7naj">
          <div class="inline-flex items-center gap-2 text-blue-600 font-bold tracking-widest uppercase text-xs mb-6" data-ps="src/pages/platform/security.astro:l9duqd">
             <span class="w-8 h-px bg-blue-600" data-ps="src/pages/platform/security.astro:l9dul4"></span> Anomaly Detection
          </div>
          <h2 class="text-5xl font-bold text-slate-900 mb-8 leading-[1.1]" data-ps="src/pages/platform/security.astro:36mq53">Every scan is a<br /><span class="text-blue-600" data-ps="src/pages/platform/security.astro:l9dul3">trust signal.</span></h2>
          <p class="text-xl text-slate-600 leading-relaxed mb-8" data-ps="src/pages/platform/security.astro:k89gy8">
            TieBack treats every scan as a rich data event. Our AI continuously evaluates patterns—location jumps, abnormal frequencies, or suspicious reuse—surfacing potential counterfeits in real time.
          </p>
          <ul class="space-y-4" data-ps="src/pages/platform/security.astro:ai-list">
            {['Geo-velocity validation', 'Impossible scan frequency alerts', 'Cryptographic verification chaining'].map((item, __psIdx) => (
              <li class="flex items-center gap-3 text-slate-700 font-medium" data-ps={`src/pages/platform/security.astro:2fntiy-${__psIdx}`}>
                <div class="w-1.5 h-1.5 rounded-full bg-blue-600" data-ps={`src/pages/platform/security.astro:6mqusn-${__psIdx}`}></div>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="flex-1 relative group" data-ps="src/pages/platform/security.astro:7i7nak">
           <img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3w4MTQzNzh8MHwxfHNlYXJjaHwxfHxkYXNoYm9hcmR8ZW58MHx8fHwxNzczMzM3MjgyfDA&ixlib=rb-4.1.0&q=80&w=1200&auto=format" sizes="(max-width: 768px) 100vw, 50vw" alt="dashboard" class="w-full h-full object-cover rounded-[2rem] shadow-2xl border border-slate-100 group-hover:scale-[1.02] transition-transform duration-500" loading="eager" fetchpriority="high" data-ps="src/pages/platform/security.astro:yj48j8" crossorigin="anonymous" />
           <div class="absolute -bottom-6 -left-6 bg-white p-6 rounded-2xl shadow-xl border border-slate-100 max-w-[200px] animate-float" data-ps="src/pages/platform/security.astro:floating-card">
              <p class="text-xs font-bold text-slate-600 uppercase tracking-wider mb-2" data-ps="src/pages/platform/security.astro:7iydih">Live Status</p>
              <div class="flex items-center gap-2 text-green-700 font-bold" data-ps="src/pages/platform/security.astro:6mqusm">
                <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse" data-ps="src/pages/platform/security.astro:l9dul2"></span>
                Monitoring Active
              </div>
           </div>
        </div>
      </div>
    </div>
  </section>

  {/* Compliance Standards */}
  <section class="py-32 bg-slate-900 relative overflow-hidden" data-ps="src/pages/platform/security.astro:3bza52">
    <div class="container mx-auto px-6 relative z-10" data-ps="src/pages/platform/security.astro:6mqusr">
      <div class="flex flex-col lg:flex-row gap-20 items-start" data-ps="src/pages/platform/security.astro:6mqusl">
        <div class="flex-1 sticky top-32" data-ps="src/pages/platform/security.astro:6mqusq">
          <h2 class="text-5xl font-bold text-white mb-8 tracking-tight" data-ps="src/pages/platform/security.astro:36mq51">Ready for the<br /><span class="text-blue-400" data-ps="src/pages/platform/security.astro:l9dul1">regulatory wave.</span></h2>
          <p class="text-xl text-slate-400 leading-relaxed mb-10" data-ps="src/pages/platform/security.astro:k89gy5">
            EU ESPR and global Digital Product Passport mandates are coming. TieBack provides the compliance-ready foundation you need to launch with confidence.
          </p>
          <div class="flex flex-wrap gap-4" data-ps="src/pages/platform/security.astro:badges">
            <div class="px-4 py-2 bg-slate-800 border border-slate-700 rounded-full text-slate-300 text-sm font-bold" data-ps="src/pages/platform/security.astro:6mqusk">EU ESPR Compliant</div>
            <div class="px-4 py-2 bg-slate-800 border border-slate-700 rounded-full text-slate-300 text-sm font-bold" data-ps="src/pages/platform/security.astro:6mqusj">GS1 Standard Native</div>
            <div class="px-4 py-2 bg-slate-800 border border-slate-700 rounded-full text-slate-300 text-sm font-bold" data-ps="src/pages/platform/security.astro:6mqusi">GDPR Secure</div>
          </div>
        </div>
        <div class="flex-1 w-full" data-ps="src/pages/platform/security.astro:6mqusp">
          <div class="grid grid-cols-1 gap-4" data-ps="src/pages/platform/security.astro:checklist">
            {complianceChecklist.map((item, __psIdx) => (
              <div class="group flex items-center justify-between p-6 bg-slate-800/50 border border-slate-700/50 rounded-2xl hover:bg-slate-800 hover:border-slate-600 transition-all cursor-default" data-ps={`src/pages/platform/security.astro:6mquso-${__psIdx}`}>
                <span class="text-slate-300 font-medium text-lg" data-ps={`src/pages/platform/security.astro:l9duqa-${__psIdx}`}>{item}</span>
                <div class="w-6 h-6 rounded-full bg-blue-600/10 flex items-center justify-center text-blue-400 group-hover:bg-blue-700 group-hover:text-white transition-all" data-ps={`src/pages/platform/security.astro:6mqusn-${__psIdx}`}>
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
    {/* Background Pattern */}
    <div class="absolute inset-0 z-0 opacity-20 pointer-events-none" style="background-image: radial-gradient(circle at 2px 2px, rgba(59, 130, 246, 0.15) 1px, transparent 0); background-size: 40px 40px;" data-ps="src/pages/platform/security.astro:grid"></div>
  </section>

  {/* Bottom CTA */}
  <section id="request" class="py-24 bg-white" data-ps="src/pages/platform/security.astro:3bza53">
    <div class="container mx-auto px-6 text-center" data-ps="src/pages/platform/security.astro:6mqusm">
      <div class="max-w-4xl mx-auto bg-gradient-to-br from-blue-600 to-blue-800 rounded-[3rem] p-12 md:p-20 text-white relative overflow-hidden shadow-2xl shadow-blue-200" data-ps="src/pages/platform/security.astro:6mqusl">
        <div class="relative z-10" data-ps="src/pages/platform/security.astro:6mqusk">
          <h2 class="text-4xl md:text-6xl font-bold mb-8 balance tracking-tight" data-ps="src/pages/platform/security.astro:36mq50">Secure your product lifecycle today.</h2>
          <p class="text-xl text-blue-100 mb-12 max-w-2xl mx-auto" data-ps="src/pages/platform/security.astro:k89gy4">
            Join the enterprise cohort defining the next generation of physical-digital product trust.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-6" data-ps="src/pages/platform/security.astro:cta-buttons">
            <a href="#" class="px-10 py-5 bg-white text-blue-600 font-bold rounded-2xl hover:bg-blue-50 transition-all shadow-xl hover:translate-y-[-2px]" data-ps="src/pages/platform/security.astro:d4bk9a">
              Request Full Access
            </a>
            <a href="#" class="text-blue-50 font-bold hover:text-white transition-colors" data-ps="src/pages/platform/security.astro:talk-sales">
              Talk to Security Experts &rarr;
            </a>
          </div>
        </div>
        {/* Decorative elements */}
        <div class="absolute top-0 right-0 w-96 h-96 bg-white/10 rounded-full -mr-32 -mt-32 blur-[80px]" data-ps="src/pages/platform/security.astro:6mqusj"></div>
        <div class="absolute bottom-0 left-0 w-96 h-96 bg-blue-400/20 rounded-full -ml-32 -mb-32 blur-[80px]" data-ps="src/pages/platform/security.astro:6mqusi"></div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .balance { text-wrap: balance; }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  .animate-float { animation: float 6s ease-in-out infinite; }
</style>
